DATABASE_URL="postgresql://housekeeping:changeme@localhost:5432/housekeeping"
JWT_SECRET="changeme_use_openssl_rand_base64_32"
# Sprint SEC-α — bug MT-8. Reduced from 7d to 24h. Refresh tokens en v1.1.
JWT_EXPIRES_IN="24h"
PORT=3000
NODE_ENV="development"
EXPO_ACCESS_TOKEN=""
CLOUDBEDS_WEBHOOK_SECRET=""

# Stripe — card-on-file / no-show charges
# Test mode keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret: stripe listen --forward-to localhost:3000/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# Channex.io — channel manager
# API key from: https://app.channex.io/settings/api_keys
CHANNEX_API_KEY=""
CHANNEX_BASE_URL="https://app.channex.io/api/v1"
# KEK (Key Encryption Key) AES-256-GCM para cifrar credenciales OTA del cliente
# (§192). 32 bytes base64: `openssl rand -base64 32`. SIN esto, el provisioning
# de OTAs cae a 'pending_credentials'. NUNCA commitear el valor real.
CHANNEX_CREDENTIALS_KEK=""
# ── Certificación Channex Stage 4 (solo sandbox) ──────────────────────────────
# Para correr el smoke test de los cert tests contra staging.channex.io:
#   1. CHANNEX_BASE_URL debe apuntar a https://staging.channex.io/api/v1
#   2. Setear estos 3 IDs de recurso (NO son secretos — son UUIDs del sandbox).
#      Se obtienen corriendo: prisma/scripts/seed-channex-sandbox.ts
#   3. set -a && source .env && set +a && npx jest channex.cert-tests.integration
#   Sin estos, los Tests 2-10 se saltan; con ellos → 21/21 verde.
CHANNEX_SANDBOX_PROPERTY_ID=""
CHANNEX_SANDBOX_ROOM_TYPE_ID=""
CHANNEX_SANDBOX_RATE_PLAN_ID=""

# CORS — dominios autorizados del panel/PMS en PRODUCCIÓN (coma-separados).
# El motor público /api/v1/public/* abre CORS aparte (cualquier origen). Sólo
# se aplica esta lista cuando NODE_ENV=production.
ALLOWED_ORIGINS="https://app.zenix.com,https://nova.zenix.com"

# Nova (interfaz consultor) — base URL para links en emails de Nova.
NOVA_BASE_URL="https://nova.zenix.com"

# Banxico SF43718 (FIX) — tipo de cambio oficial MX (cron diario). Token gratis:
# https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=""

# Day 18 — Resend transactional email (setup link auto-send + SMTP health check).
# REST API directo (no SDK). Si RESEND_API_KEY vacío → SetupEmailService loguea
# el envío y retorna stub success (preserva flujo dev sin credentials).
# Get key from: https://resend.com/api-keys (requires verified domain)
RESEND_API_KEY=""
# Format Resend espera: "Display Name <email@verified-domain.com>"
RESEND_FROM_ADDRESS="Zenix Activate <noreply@zenix.app>"
# From address para emails de billing (facturas/recordatorios de cobro Zenix).
RESEND_BILLING_FROM="Zenix Billing <billing@zenix.app>"
# Base URL del cliente PMS — usado en setup link emails. Configura por env:
# - dev: http://localhost:5173
# - prod: https://app.zenix.com
APP_BASE_URL="https://app.zenix.com"


# Google Places API (New) — búsqueda real de hoteles para Compset Settings.
# Sin esta key, searchHotel cae al StubCompsetAdapter (datos fake "X Hotel").
# Activar en Google Cloud Console: APIs & Services → Library → "Places API (New)" → Enable.
# Crear API key restricted a Places API + restringir por HTTP referrer del backend Render.
# SKU Text Search: $0.032/req. Free tier: ~10k/mes con $200 monthly credit del Map Tier 1.
GOOGLE_PLACES_API_KEY=
