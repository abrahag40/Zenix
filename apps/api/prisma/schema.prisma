// ─── BOOKING-ENGINE B0 (2026-06-11) — "Zenix Booking" direct booking engine ──
// Config 1:1 con Property que habilita la página pública de reservas directas
// `book.zenix.com/{slug}` + la API pública (source='DIRECT_WEB', cero comisión
// OTA). Configurada consultor-led desde el Wizard Step 5.5 (ver
// docs/sprints/BOOKING-ENGINE-wizard-integration.md) o Settings post-onboarding.
//
// SECUENCIA OPCIÓN B (decisión owner 2026-06-11): Fase 1 arranca PAY_AT_HOTEL-
// only. `paymentPolicy` existe en el schema con los 4 valores, pero hasta que
// PAY-CORE (v1.0.1) aterrice el ÚNICO valor operativo es PAY_AT_HOTEL — los
// demás se exponen deshabilitados en la UI ("próximamente"). El prepago se
// enchufa después sin reescribir el flujo de reserva.
model BookingEngineConfig {
  id         String  @id @default(uuid())
  propertyId String  @unique @map("property_id")
  // Identificador público en la URL: book.zenix.com/{slug}. Único global.
  // Derivado del nombre de la property al crear (slugify), editable en wizard.
  slug       String  @unique
  // Master switch. Hasta que el consultor publica, la página pública responde 404.
  enabled    Boolean @default(false)

  // ── Política de pago ──────────────────────────────────────────────────────
  // FULL_PREPAY | DEPOSIT_30 | DEPOSIT_50 | PAY_AT_HOTEL.
  // Opción B: locked a PAY_AT_HOTEL en Fase 1 (los demás requieren PAY-CORE).
  paymentPolicy  String @default("PAY_AT_HOTEL") @map("payment_policy")
  // TTL del hold de inventario para una reserva sin confirmar (minutos). El
  // scheduler libera la noche si la reserva no se confirma/cobra a tiempo.
  // Default 24h — alineado con voucher OXXO/SPEI (24-72h) cuando llegue prepago.
  holdTtlMinutes Int    @default(1440) @map("hold_ttl_minutes")

  // ── Branding (consultor lo llena en wizard Step 5.5) ─────────────────────
  logoUrl      String? @map("logo_url")
  primaryColor String? @map("primary_color") // hex, ej. "#0f766e"
  accentColor  String? @map("accent_color")
  fontFamily   String? @map("font_family")

  // ── Copy & políticas ──────────────────────────────────────────────────────
  heroTitle    String? @map("hero_title")
  heroSubtitle String? @map("hero_subtitle")
  termsUrl     String? @map("terms_url")
  // Hook a la política de cancelación (GROUP-BILLING Fase C). String suelto
  // (patrón "espiral" §95) para evitar migration cuando se formalice el FK.
  cancellationPolicyId String? @map("cancellation_policy_id")

  // ── Display ───────────────────────────────────────────────────────────────
  defaultLanguage String  @default("es-MX") @map("default_language")
  displayCurrency String? @map("display_currency") // fallback a LegalEntity.baseCurrency

  // ── Marketplace Tier 2 (§6 del plan) — opt-in comisión 3-5% ──────────────
  marketplaceListingEnabled Boolean @default(false) @map("marketplace_listing_enabled")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([slug], map: "idx_booking_engine_config_slug")
  @@map("booking_engine_config")
}

// ─── BOOKING-ENGINE B2 (2026-06-11) — API key pública (Tier 3 + write auth) ──
// Autentica los POST de reservas desde websites externos. Patrón Stripe restricted
// key: la llave completa es `pk_{env}_{keyId(16hex)}{secret(32hex)}`. Persistimos
// `keyId` plano (lookup O(1)) + `keyHash` = bcrypt(secret) (el secreto NUNCA se
// guarda en claro; el plaintext sólo existe en el momento de generarla). CORS
// dinámico: cada llave declara `allowedOrigins[]` — origen no listado → 403.
model BookingApiKey {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  environment String   @default("live") // 'live' | 'test'
  keyId       String   @unique @map("key_id") // 16 hex — lookup público
  keyHash     String   @map("key_hash") // bcrypt(secret)
  keyPrefix   String   @map("key_prefix") // display: "pk_live_a1b2c3…"
  label       String
  // Dominios autorizados a llamar con esta llave (CORS). Vacío = sin restricción
  // de origen (uso server-to-server donde no hay header Origin).
  allowedOrigins String[] @default([]) @map("allowed_origins")
  active      Boolean  @default(true)
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId], map: "idx_booking_api_key_property")
  @@map("booking_api_keys")
}

// ─── BOOKING-ENGINE B2 — idempotencia de POST /reservations ──────────────────
// El cliente manda `Idempotency-Key` (UUID) por reserva. Si reintenta (doble
// click, retry de red) con la MISMA key → devolvemos la respuesta cacheada en
// vez de crear una reserva duplicada. `requestHash` detecta reuso de la misma
// key con body distinto → 409 (contrato Stripe).
model BookingIdempotencyRecord {
  id             String   @id @default(uuid())
  apiKeyId       String   @map("api_key_id")
  idempotencyKey String   @map("idempotency_key")
  requestHash    String   @map("request_hash") // sha256(body)
  responseJson   Json     @map("response_json")
  statusCode     Int      @map("status_code")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([apiKeyId, idempotencyKey], map: "uniq_booking_idempotency")
  @@map("booking_idempotency_records")
}

// ─── BOOKING-ENGINE B3 (2026-06-11) — webhooks outbound ──────────────────────
// El website del hotel se suscribe a eventos (`reservation.created`,
// `availability.changed`, …). Zenix le hace POST firmado (HMAC SHA256) cuando
// ocurren → el sitio mantiene su calendario en sync sin polling. Patrón idéntico
// al outbound de Channex (§144): cola + backoff + dead-letter.
model WebhookSubscription {
  id           String   @id @default(uuid())
  propertyId   String   @map("property_id")
  url          String
  // Eventos suscritos: 'reservation.created' | 'availability.changed' | ...
  events       String[]
  secret       String // HMAC signing key (el cliente verifica X-Zenix-Signature)
  active       Boolean  @default(true)
  failureCount Int      @default(0) @map("failure_count")
  lastDeliveryAt DateTime? @map("last_delivery_at")
  disabledAt   DateTime? @map("disabled_at")
  createdAt    DateTime @default(now()) @map("created_at")

  property  Property          @relation(fields: [propertyId], references: [id])
  deliveries WebhookDelivery[]

  @@index([propertyId], map: "idx_webhook_sub_property")
  @@map("webhook_subscriptions")
}

// Una entrega individual. Append-only-ish: status avanza PENDING → DELIVERED |
// FAILED → (retry) → DELIVERED | DEAD_LETTER. Forense + retry state.
model WebhookDelivery {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  event          String
  payload        Json
  status         String   @default("PENDING") // PENDING | DELIVERED | FAILED | DEAD_LETTER
  attempts       Int      @default(0)
  nextAttemptAt  DateTime? @map("next_attempt_at")
  lastError      String?  @map("last_error")
  statusCode     Int?     @map("status_code")
  createdAt      DateTime @default(now()) @map("created_at")
  deliveredAt    DateTime? @map("delivered_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([status, nextAttemptAt], map: "idx_webhook_delivery_retry")
  @@index([subscriptionId], map: "idx_webhook_delivery_sub")
  @@map("webhook_deliveries")
}

// ─── CHANNEX-AUTO-PROVISION Day 2 — OTA channel connections ───────────────
// Cada conexión a un OTA (Booking, Expedia, Airbnb, etc.) vive como Channel
// row con `settingsEncrypted` (AES-256-GCM ciphertext de credentials del
// cliente, KEK en .env). NUNCA logear plain credentials.
//
// Status state machine:
//   inactive            — creado en Channex pero no published (default)
//   pending_credentials — creado sin settings (cliente las completará)
//   connected           — fully active (push activado, recibe reservas)
//   requires_oauth      — Airbnb (siempre, regla regulatoria 2022)
//   error               — Channex marcó error en última sync
model Channel {
  id                String    @id @default(uuid())
  propertyId        String    @map("property_id")
  channexChannelId  String    @unique @map("channex_channel_id")
  type              String // 'BookingCom' | 'ExpediaCom' | 'AirbnbCom' | ...
  title             String
  status            String    @default("inactive")
  settingsEncrypted String?   @map("settings_encrypted") @db.Text
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId], map: "idx_channels_property")
  @@index([status], map: "idx_channels_status")
  @@map("channels")
}

model Room {
  id                String       @id @default(uuid())
  organizationId    String?      @map("organization_id")
  propertyId        String
  number            String
  floor             Int?
  category          RoomCategory
  capacity          Int
  status            RoomStatus   @default(AVAILABLE) @map("room_status")
  roomTypeId        String?      @map("room_type_id")
  channexRoomTypeId String?      @map("channex_room_type_id") // ID del room type en Channex.io (Sprint 8)
  notes             String?
  deletedAt         DateTime?    @map("deleted_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  property           Property            @relation(fields: [propertyId], references: [id])
  roomType           RoomType?           @relation(fields: [roomTypeId], references: [id])
  units              Unit[]
  checkouts          Checkout[]
  guestStays         GuestStay[]
  readinessTasks     RoomReadinessTask[]
  staySegments       StaySegment[]
  blocks             RoomBlock[]
  // ── Sprint 8H — quién cubre esta habitación por defecto ───────────────────
  staffCoverages     StaffCoverage[]
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  maintenanceTickets MaintenanceTicket[] @relation("TicketRoom")

  @@unique([propertyId, number])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([status])
  @@map("rooms")
}

model Unit {
  id             String     @id @default(uuid())
  organizationId String?    @map("organization_id")
  label          String
  roomId         String
  status         UnitStatus @default(AVAILABLE)
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  room               Room                @relation(fields: [roomId], references: [id])
  cleaningTasks      CleaningTask[]
  discrepancies      UnitDiscrepancy[]
  blocks             RoomBlock[]
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  // Ticket a nivel unidad (e.g. solo cama 2 del dorm tiene problema mecánico)
  maintenanceTickets MaintenanceTicket[] @relation("TicketUnit")

  @@index([organizationId])
  @@map("units")
}

/**
 * Staff — miembro del personal del hotel (cualquier área, cualquier nivel).
 * Renombrado desde `HousekeepingStaff` (2026-05-08, Sprint 9): el nombre
 * legacy era engañoso. Este modelo representa a TODO el personal:
 * recamaristas, recepcionistas, mantenimiento, áreas públicas, etc.
 * Industry standard naming:
 * - AHLEI / USALI 12ª: "Staff" o "Employee"
 * - Mews / Cloudbeds: "User" (mezclado con app account)
 * - Opera: "Employee"
 * Elegimos "Staff" — conciso, distinto de "User" (app account ≠ persona).
 * Tabla SQL `housekeeping_staff` permanece via @@map para evitar migración
 * destructiva. Renombrar la tabla cuando haya ventana de deploy controlada.
 * Tres ejes de identidad:
 * 1. department  (HOUSEKEEPING | MAINTENANCE | RECEPTION | ...)
 * 2. role        (HOUSEKEEPER | SUPERVISOR | RECEPTIONIST) — legacy
 * 3. level       (LEAD | COLLABORATOR) — nuevo Sprint 9, autoridad
 * Permission matrix derivada de (department, level) — ver
 * apps/api/src/common/permissions/staff-permissions.ts.
 */
model Staff {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  userId         String?      @map("user_id")
  propertyId     String
  name           String
  email          String       @unique
  passwordHash   String
  role           StaffRole
  department     Department   @default(HOUSEKEEPING) @map("department")
  // Sprint 9 — eje jerárquico ortogonal a role/department.
  // Default COLLABORATOR — el seed/migración promueve a LEAD a quienes
  // tenían role=SUPERVISOR en HOUSEKEEPING (mapeo legacy).
  level          StaffLevel   @default(COLLABORATOR) @map("level")
  // Self-referential FK para árbol jerárquico (futuro org-tree visual).
  // Null = no reporta a nadie (top of department o solo-staff property).
  reportsToId    String?      @map("reports_to_id")
  reportsTo      Staff?       @relation("StaffReports", fields: [reportsToId], references: [id])
  reports        Staff[]      @relation("StaffReports")
  active         Boolean      @default(true)
  capabilities   Capability[]
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now())
  // Notifications hybrid pattern (FB+LinkedIn, NN/g 2023) — timestamp del último
  // "acknowledge" del panel. Bell counter = notifs creadas DESPUÉS de este ts y
  // sin AppNotificationRead. Permite "vi la lista" sin marcar cada item leído.
  notificationsAckedAt DateTime? @map("notifications_acked_at")

  organization            Organization?              @relation(fields: [organizationId], references: [id])
  user                    User?                      @relation(fields: [userId], references: [id])
  property                Property                   @relation(fields: [propertyId], references: [id])
  tasks                   CleaningTask[]             @relation("AssignedTasks")
  verifiedTasks           CleaningTask[]             @relation("VerifiedTasks")
  taskLogs                TaskLog[]
  cleaningNotes           CleaningNote[]
  pushTokens              PushToken[]
  checkouts               Checkout[]                 @relation("ManualCheckouts")
  issues                  MaintenanceIssue[]
  reportedDiscrepancies   UnitDiscrepancy[]          @relation("DiscrepancyReporter")
  resolvedDiscrepancies   UnitDiscrepancy[]          @relation("DiscrepancyResolver")
  requestedBlocks         RoomBlock[]                @relation("BlocksRequested")
  approvedBlocks          RoomBlock[]                @relation("BlocksApproved")
  blockLogs               BlockLog[]                 @relation("BlockLogs")
  contactLogs             GuestContactLog[]          @relation("ContactLogs")
  notificationsTriggered  AppNotification[]          @relation("NotifTriggeredBy")
  notificationReads       AppNotificationRead[]      @relation("NotifReadBy")
  notificationApprovals   AppNotificationApproval[]  @relation("NotifApprovedBy")
  collectedPayments       PaymentLog[]               @relation("PaymentCollectedBy")
  approvedPayments        PaymentLog[]               @relation("PaymentApprovedBy")
  voidedPayments          PaymentLog[]               @relation("PaymentVoidedBy")
  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  shifts                  StaffShift[]
  shiftExceptions         StaffShiftException[]      @relation("ShiftExceptionsForStaff")
  approvedShiftExceptions StaffShiftException[]      @relation("ShiftExceptionsApprovedBy")
  coverages               StaffCoverage[]
  shiftClocks             StaffShiftClock[]
  preferences             StaffPreferences?
  preferenceChangesMade   StaffPreferenceLog[]       @relation("PreferenceChangesByStaff")
  // ── Sprint 8I-J — Hub Recamarista gamificación (privacy-respecting) ─────
  streak                  StaffStreak?
  personalRecords         StaffPersonalRecord[]
  dailyActivity           StaffDailyActivity[]
  // ── Feature flags audit trail ────────────────────────────────────────────
  featureFlagsUpdated     FeatureFlag[]
  featureFlagAudits       FeatureFlagAuditLog[]
  // ── Sprint Mx-1 — Módulo de Mantenimiento ─────────────────────────────────
  // Un staff puede aparecer en múltiples roles dentro del ciclo de vida de un
  // ticket (reporta, asignado, resuelve, verifica) — cada relación es independiente.
  // Department.MAINTENANCE identifica al staff que es técnico de mantenimiento.
  ticketsReported         MaintenanceTicket[]        @relation("TicketsReported")
  ticketsAssigned         MaintenanceTicket[]        @relation("TicketsAssigned")
  ticketsResolved         MaintenanceTicket[]        @relation("TicketsResolved")
  ticketsVerified         MaintenanceTicket[]        @relation("TicketsVerified")
  ticketsApproved         MaintenanceTicket[]        @relation("TicketsApproved")
  ticketPhotosUploaded    MaintenanceTicketPhoto[]   @relation("TicketPhotoUploader")
  ticketCommentsAuthored  MaintenanceTicketComment[] @relation("TicketCommentAuthor")
  ticketLogsBy            MaintenanceTicketLog[]     @relation("TicketLogActor")

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("housekeeping_staff")
}

model Checkout {
  id                String         @id @default(uuid())
  organizationId    String?        @map("organization_id")
  roomId            String
  guestName         String?
  actualCheckoutAt  DateTime
  source            CheckoutSource
  isEarlyCheckout   Boolean        @default(false)
  hasSameDayCheckIn Boolean        @default(false)
  notes             String?
  enteredById       String?
  cancelled         Boolean        @default(false)
  cancelledAt       DateTime?
  createdAt         DateTime       @default(now())

  organization Organization?  @relation(fields: [organizationId], references: [id])
  room         Room           @relation(fields: [roomId], references: [id])
  enteredBy    Staff?         @relation("ManualCheckouts", fields: [enteredById], references: [id])
  tasks        CleaningTask[]

  @@index([organizationId])
  @@map("checkouts")
}

// TODO(hotel-room-granularity): CleaningTask fue diseñado hostel-first — unitId es NOT NULL
// y la tarea siempre se vincula a una unidad, nunca directamente a una habitación.
// Para hoteles con habitaciones dobles/twin (2 unidades, 1 unidad vendible), un bloqueo
// de habitación genera hoy N tareas MAINTENANCE (una por unidad) cuando debería ser 1.
// Refactor requerido:
//   1. Hacer unitId opcional: `unitId String?`
//   2. Añadir `roomId String?` (XOR con unitId — exactamente uno debe estar presente)
//   3. Actualizar TasksService, CleaningTaskDto, KanbanPage y mobile task/[id].tsx
//      para renderizar roomId cuando unitId sea null (tareas de bloqueo room-level)
//   4. Migración Prisma: no hay datos existentes de tipo MAINTENANCE, safe to migrate
model CleaningTask {
  id                 String         @id @default(uuid())
  organizationId     String?        @map("organization_id")
  unitId             String
  checkoutId         String?
  assignedToId       String?
  status             CleaningStatus @default(PENDING)
  taskType           TaskType       @default(CLEANING)
  // TODO(housekeeping-pms-bridge): agregar sourceType para distinguir el origen de la tarea.
  // Descomentar y migrar cuando se implemente el bridge PMS → Housekeeping (Sprint 7A/7B).
  // sourceType         CleaningTaskSource @default(CHECKOUT)
  // enum CleaningTaskSource { CHECKOUT, STAYOVER, ROOM_CHANGE, EXTENSION }
  requiredCapability Capability     @default(CLEANING)
  priority           Priority       @default(MEDIUM)
  hasSameDayCheckIn  Boolean        @default(false)
  startedAt          DateTime?
  finishedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  scheduledFor        DateTime?             @map("scheduled_for") @db.Date // fecha lógica del roster (idempotencia + queries)
  carryoverFromDate   DateTime?             @map("carryover_from_date") @db.Date
  carryoverFromTaskId String?               @map("carryover_from_task_id")
  autoAssignmentRule  String?               @map("auto_assignment_rule") // 'COVERAGE_PRIMARY' | 'COVERAGE_BACKUP' | 'ROUND_ROBIN' | null
  cancelledReason     CleaningCancelReason? @map("cancelled_reason")
  cancelledAt         DateTime?             @map("cancelled_at")
  extensionFlag       ExtensionFlag?        @map("extension_flag") // D12 — re-etiqueta cuando extension aplica

  // ── Sprint 9 / EC-6 — Skip-and-retry (AHLEI Sec. 4.3) ────────────────────
  deferredAt     DateTime?            @map("deferred_at")
  deferredReason CleaningDeferReason? @map("deferred_reason")
  // Hora a la que la tarea debe re-promoverse a READY/UNASSIGNED automáticamente.
  // El cron `*/5 * * * *` la chequea contra `now`. Default 30 min post-defer (AHLEI).
  retryAt        DateTime?            @map("retry_at")
  // Contador acumulado de deferrals. ≥3 → status=BLOCKED + notif tier-2.5 supervisor.
  deferredCount  Int                  @default(0) @map("deferred_count")

  // ── Sprint 9 / EC-3 — Late checkout (huésped sale a hora distinta) ───────
  // Si la recepción aprobó late checkout, este timestamp guarda la nueva
  // hora prevista. Mobile lo usa para re-calcular prioridad: la tarea no
  // es URGENT hasta que `now >= lateCheckoutAt - 1h`.
  lateCheckoutAt DateTime? @map("late_checkout_at")

  // ── Sprint 9 / D15 — Override flags (OperationalOverridesPage) ────────────
  // Limpieza profunda — cambia el template de checklist + duración estimada.
  // Operativo: el housekeeper recibe pack diferente (sábanas + manta + cortinas
  // vs solo sábanas) y debe documentar más fotos.
  deepClean  Boolean   @default(false) @map("deep_clean")
  // Hold por extensión sin formalizar (huésped pidió quedarse pero aún no paga).
  // Estado: la tarea se mantiene PENDING (no se inicia limpieza). El housekeeper
  // ve el badge "⏸ En espera de extensión". Al formalizar la extensión: D12
  // resuelve (con/sin limpieza). Al cancelar el hold: vuelve a estado normal.
  holdReason String?   @map("hold_reason")
  heldAt     DateTime? @map("held_at")
  heldById   String?   @map("held_by_id")

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  unit               Unit                @relation(fields: [unitId], references: [id])
  checkout           Checkout?           @relation(fields: [checkoutId], references: [id])
  assignedTo         Staff?              @relation("AssignedTasks", fields: [assignedToId], references: [id])
  verifiedBy         Staff?              @relation("VerifiedTasks", fields: [verifiedById], references: [id])
  logs               TaskLog[]
  notes              CleaningNote[]
  issues             MaintenanceIssue[]
  block              RoomBlock?          @relation("BlockTask")
  // Self-relation for carryover audit chain (CleaningTask → original CleaningTask de ayer)
  carryoverFromTask  CleaningTask?       @relation("TaskCarryover", fields: [carryoverFromTaskId], references: [id])
  carryoverChildren  CleaningTask[]      @relation("TaskCarryover")
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  // Tickets levantados durante esta tarea de limpieza (housekeeper detecta
  // problemas en cuarto). Vínculo via MaintenanceTicket.sourceTaskId.
  maintenanceTickets MaintenanceTicket[] @relation("TicketSourceTask")

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId, status])
  @@index([unitId])
  @@index([checkoutId])
  @@index([scheduledFor, status])
  @@index([carryoverFromDate])
  @@index([cancelledReason])
  @@map("cleaning_tasks")
}

model TaskLog {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  taskId         String
  staffId        String?
  event          TaskLogEvent
  note           String?
  // metadata: snapshot opcional del evento. Caso principal:
  //   COMPLETED { checklist: [{ id, label, completed }] }  → para reportes
  //   PAUSED    { reason: '...' }                         → opcional
  // Queryable con operadores JSONB de Postgres en reports.
  metadata       Json?
  createdAt      DateTime     @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  task         CleaningTask  @relation(fields: [taskId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@index([taskId])
  @@map("task_logs")
}

model CleaningNote {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  taskId         String
  staffId        String
  content        String
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  task         CleaningTask  @relation(fields: [taskId], references: [id])
  staff        Staff         @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("cleaning_notes")
