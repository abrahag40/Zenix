model GuestStay {
  id                    String              @id @default(uuid())
  // Human-readable booking reference: MX-D-001-2604-0134
  // Segments: [country]-[source]-[propCode]-[YYMM]-[seq]
  bookingRef            String?             @unique @map("booking_ref")
  organizationId        String              @map("organization_id")
  propertyId            String              @map("property_id")
  roomId                String              @map("room_id")
  guestName             String              @map("guest_name")
  // Sprint CHECK-IN C1.12 (2026-05-29) — split BI: nombre/apellido separados.
  // Capturados al confirmar check-in (recepción ve documento físico). Si null,
  // guestName se usa como fallback en reportes (backward compat con stays
  // viejos pre-split). UI deriva default de guestName.split(' ',2) al editar.
  guestFirstName        String?             @map("guest_first_name")
  guestLastName         String?             @map("guest_last_name")
  guestEmail            String?             @map("guest_email")
  guestPhone            String?             @map("guest_phone")
  documentType          String?             @map("document_type")
  documentNumber        String?             @map("document_number")
  nationality           String?
  // Sex/gender del huésped principal — Sprint 2026-05-20.
  // Captura opcional al crear reserva. Útil para BI analytics + reportes
  // demográficos (no-show rates per cohort, length-of-stay correlations, etc.).
  // Valores: 'M' (male), 'F' (female), 'O' (other / non-binary),
  // 'N' (prefer not to say). String libre por flexibilidad cultural LATAM
  // (algunas jurisdicciones requieren third gender option vs binary).
  // GDPR/LFPDPPP: PII sensible — enmascarado en exports B2B (TODO §10
  // docs/vision/10-data-strategy-abi.md anonymization policy).
  guestSex              String?             @map("guest_sex")
  paxCount              Int                 @default(1) @map("pax_count")
  checkinAt             DateTime            @map("checkin_at")
  scheduledCheckout     DateTime            @map("scheduled_checkout")
  actualCheckout        DateTime?           @map("actual_checkout")
  actualCheckin         DateTime?           @map("actual_checkin")
  checkinConfirmedById  String?             @map("checkin_confirmed_by_id")
  ratePerNight          Decimal             @map("rate_per_night") @db.Decimal(10, 2)
  currency              String              @default("USD")
  totalAmount           Decimal             @map("total_amount") @db.Decimal(10, 2)
  amountPaid            Decimal             @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentStatus         PaymentStatus       @default(PENDING) @map("payment_status")
  // Sprint CHECK-IN-α §106 — driver de OTA-collect detection. Default seguro
  // = HOTEL_COLLECT (no rebaja guards existentes). Channex inbound (sprint
  // próximo) escribe OTA_COLLECT cuando `payment_collect=ota`.
  paymentModel          PaymentModel        @default(HOTEL_COLLECT) @map("payment_model")
  source                String?
  notes                 String?
  checkedInById         String              @map("checked_in_by_id")
  checkedOutById        String?             @map("checked_out_by_id")
  // ── No-show fields ───────────────────────────────────────────────────────
  // noShowAt != null indica que el huésped no se presentó y fue marcado.
  // La disponibilidad de la habitación excluye stays con noShowAt != null
  // (ver checkAvailability). El cargo se registra en noShowFeeAmount y su
  // estado en noShowChargeStatus (PENDING → CHARGED | FAILED | WAIVED).
  noShowAt              DateTime?           @map("no_show_at")
  noShowById            String?             @map("no_show_by_id")
  noShowReason          String?             @map("no_show_reason")
  noShowFeeAmount       Decimal?            @map("no_show_fee_amount") @db.Decimal(10, 2)
  noShowFeeCurrency     String?             @map("no_show_fee_currency")
  noShowChargeStatus    NoShowChargeStatus? @map("no_show_charge_status")
  // Sprint POST-NETFLIX-TRIAL (2026-05-29) — flujo admin del cobro manual.
  // Recepción cobra fuera de Zenix (efectivo, OTA card via Booking VCC /
  // Expedia Collect, transferencia, etc.) y registra el outcome aquí vía
  // POST /v1/guest-stays/:id/register-noshow-charge. NO usa Stripe.
  noShowChargeMethod    String?             @map("no_show_charge_method") // cash | transfer | ota_card | manual_card | ota_collect | other
  noShowChargeReference String?             @map("no_show_charge_reference") // POS approval ID, transfer ID, etc.
  noShowChargeAt        DateTime?           @map("no_show_charge_at")
  noShowChargeById      String?             @map("no_show_charge_by_id")
  noShowChargeReason    String?             @map("no_show_charge_reason") // obligatorio si status=WAIVED
  noShowRevertedAt      DateTime?           @map("no_show_reverted_at")
  noShowRevertedById    String?             @map("no_show_reverted_by_id")
  // ── Late checkout escalation (Sprint 9) ─────────────────────────────────
  // Tracking de cuál tier de notificación ya se disparó para esta stay.
  // Evita duplicar notifs en cada corrida del cron. Reset al hacer
  // confirmDeparture o checkout (la stay sale del flujo de escalación).
  // 0 = ningún tier disparado; 1 = Tier 1 (RECEPTIONIST); 2 = Tier 2 (SUPERVISOR).
  lateCheckoutTier      Int?                @default(0) @map("late_checkout_tier")
  lateCheckoutFlaggedAt DateTime?           @map("late_checkout_flagged_at")
  // ── Check-in extended fields (Sprint 9) ─────────────────────────────────
  arrivalNotes          String?             @map("arrival_notes")
  keyType               KeyDeliveryType?    @map("key_type")
  // Sprint CHECK-IN-α — foto del documento capturada al check-in. Hoy data
  // URI base64 (mismo patrón que MaintenanceTicket.photos, deuda MAINT-11
  // a resolver en v1.0.3 IMG con S3+Sharp). Visa CRR 13.1/13.7 chargeback
  // evidence: la foto demuestra que el huésped se presentó físicamente con
  // documento válido.
  documentPhotoUrl      String?             @map("document_photo_url")
  // ── Reports — pace/lead-time analytics (Sprint 9 research recommendation) ─
  // Días entre creación de la reserva y check-in. Calculado al crear.
  // Habilita pace/lead-time analysis (top wanted report en cross-research)
  // sin recomputar `differenceInDays` en cada query agregada. Trivial cost.
  bookingLeadDays       Int?                @map("booking_lead_days")
  // ── Stripe card-on-file ELIMINADO 2026-05-29 ─────────────────────────────
  // Los campos stripeCustomerId, stripePaymentMethodId y stripePaymentIntentId
  // del GuestStay fueron eliminados porque el no-show charging via Stripe
  // (Sprint Mx-1) estaba fuera del scope productivo.
  //
  // VISIÓN ZENIX para Stripe (confirmada 2026-05-29):
  //   1. Cobro al dueño del hotel — suscripción SaaS Zenix (flow Netflix-trial)
  //   2. Booking Engine (sprint futuro) — huésped paga reserva online + se
  //      genera el bloque GuestStay automáticamente. SIN tarjeta del huésped
  //      retenida en check-in.
  //
  // El tracking interno del no-show (noShowChargeStatus, noShowFeeAmount)
  // SE MANTIENE para que recepción registre el cargo manual (efectivo, OTA
  // pre-paid, cobro al checkout, etc.) sin pasar por Stripe.
  deletedAt             DateTime?           @map("deleted_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // ── TODO(sprint8-pricing): campos para gestión de tarifas y channel manager ──
  // Descomentar y migrar cuando se implemente Sprint 8. Ver CLAUDE.md §Sprint 8.
  //
  // ratePlanId         String?    @map("rate_plan_id")         // FK → RatePlan
  // rateOverride       Decimal?   @map("rate_override") @db.Decimal(10, 2)
  // rateOverrideReason String?    @map("rate_override_reason")
  // channexRateId      String?    @map("channex_rate_id")      // ID en Channex.io
  // commissionRate     Decimal?   @map("commission_rate") @db.Decimal(5, 4)   // e.g. 0.15 = 15%
  //
  // TODO(sprint8-pricing): Nuevo modelo RatePlan (separado de GuestStay)
  // model RatePlan {
  //   id                String   @id @default(uuid())
  //   propertyId        String
  //   roomTypeId        String?
  //   name              String
  //   baseRate          Decimal  @db.Decimal(10, 2)
  //   currency          String   @default("MXN")
  //   channexRatePlanId String?
  //   isActive          Boolean  @default(true)
  //   markup            Decimal? @db.Decimal(5, 4)  // markup sobre tarifa base OTA
  //   createdAt         DateTime @default(now())
  //   updatedAt         DateTime @updatedAt
  // }

  // ── Cancel-Archive (Sprint CANCEL-ARCHIVE) ────────────────────────────
  // Patrón soft-delete obligatorio. Una stay cancelada permanece en DB con
  // `cancelledAt != null`. AvailabilityService excluye cancelled stays.
  //
  // Diseño "espiral": campos son strings (no enums) y JSON metadata para
  // permitir agregar valores sin migration. FK hooks listos para integrar
  // PAY-CORE (v1.0.1), CFDI-CORE (v1.0.2), Channex outbound sin schema
  // change. Soporta hotel boutique / hostal / STR (Airbnb-style) con el
  // mismo modelo: STR persiste `cancelMetadata.airbnbCancelCode` sin
  // afectar el flujo principal.
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledById         String?   @map("cancelled_by_id")
  // 'GUEST' | 'HOTEL' | 'OTA' | 'ADMIN_ERROR' | 'SYSTEM' (string, no enum)
  cancelInitiator       String?   @map("cancel_initiator")
  // Texto libre + opcional motivo de dropdown via cancelReasonCode
  cancelReason          String?   @map("cancel_reason")
  cancelReasonCode      String?   @map("cancel_reason_code")
  // OTA cancel codes, refund refs, host fees (STR), email refs, etc.
  cancelMetadata        Json?     @map("cancel_metadata")
  // 'PMS_DIRECT' | 'CHANNEX_WEBHOOK' | 'AUTO_SYSTEM'
  cancelledFromChannel  String?   @map("cancelled_from_channel")
  // FK hook para CancellationPolicy (relación real desde Fase C — ver abajo)
  cancellationPolicyId  String?   @map("cancellation_policy_id")
  // GROUP-BILLING Fase C (D-GRP-C4/C5) — outcome de la política calculado AL
  // cancelar (snapshot inmutable): cuánto retiene el hotel y cuánto se reembolsa.
  // El reembolso se REGISTRA administrativamente (no Stripe, §195/§C5): el
  // operador lo procesa fuera (OTA VCC / transferencia / efectivo) y registra
  // method + reference + status. Append-only (solo se sobrescribe desde PENDING).
  cancelRetentionAmount Decimal?  @map("cancel_retention_amount") @db.Decimal(10, 2)
  cancelRefundAmount    Decimal?  @map("cancel_refund_amount") @db.Decimal(10, 2)
  // NONE (nada que reembolsar) | PENDING | REFUNDED | WAIVED
  cancelRefundStatus    String?   @map("cancel_refund_status")
  // cash | transfer | ota_card | manual_card | ota_collect | other
  cancelRefundMethod    String?   @map("cancel_refund_method")
  cancelRefundReference String?   @map("cancel_refund_reference")
  cancelRefundAt        DateTime? @map("cancel_refund_at")
  cancelRefundById      String?   @map("cancel_refund_by_id")
  cancelRefundReason    String?   @map("cancel_refund_reason")
  // Sembrado para v1.0.2 CFDI-CORE — emite CFDI E + FormaPago=15 si folio
  // origen tuvo CFDI I previo y cancelInitiator != 'ADMIN_ERROR'
  requiresFiscalReview  Boolean   @default(false) @map("requires_fiscal_review")
  // Sembrado para anonymization scheduler v1.0.4 NS-UI
  anonymizedAt          DateTime? @map("anonymized_at")
  // ──────────────────────────────────────────────────────────────────────

  // ── Channex inbound (Sprint CHANNEX-INBOUND, D-CHX2) ─────────────────────
  // Idempotency key for OTA webhook deliveries. UNIQUE — replays no duplican.
  // channexRevision tracks payload version for modify/cancel ordering.
  // channexConflict = true marca stays con overlap pendientes de resolución
  // humana (D-CHX5). AvailabilityService NO los excluye — siguen visibles
  // como "reservas en disputa" hasta que un humano decida.
  channexBookingId     String?   @unique @map("channex_booking_id")
  // Código de reserva de la OTA (Booking.com/Expedia/Airbnb) — el número que ve
  // el huésped y que el personal teclea en el extranet de la OTA para encontrar
  // la MISMA reserva. Channex lo manda como `ota_reservation_code`. Distinto del
  // channexBookingId (UUID interno de Channex, inútil para el personal). Buscable.
  otaReservationCode   String?   @map("ota_reservation_code")
  channexRevision      Int?      @map("channex_revision")
  channexConflict      Boolean   @default(false) @map("channex_conflict")
  channexLastSyncAt    DateTime? @map("channex_last_sync_at")
  channexOtaName       String?   @map("channex_ota_name") // booking.com | expedia | airbnb | hostelworld | ...
  // Cert audit C9 fix (2026-05-22) — virtual card persistence Booking.com Genius.
  // Channex envía guarantee.card_number MASKED (e.g. "****1234"), is_virtual,
  // expiration_date, meta.virtual_card_*. Persistimos para chargeback evidence
  // Visa CRR §5.9.2. PCI-safe: nunca PAN clear-text (Channex pre-enmascara).
  // Shape: { cardType, masked, expirationDate, isVirtual, meta:{...virtualCard*...} }
  channexGuaranteeMeta Json?     @map("channex_guarantee_meta")
  // ──────────────────────────────────────────────────────────────────────

  // ── Reservation Group (Sprint CHECK-IN C2, 2026-05-29) ───────────────────
  // Cuando una reserva OTA viene con `rooms.length > 1` (familia, grupo
  // corporativo, hostal multi-cama), creamos UN ReservationGroup que agrega
  // las N GuestStays. groupRoomIndex (1-based) indica posición de esta stay
  // dentro del grupo para UI ("Hab X/Y"). reservationGroupId nullable
  // porque la mayoría de stays son singles. §153-§158 CLAUDE.md.
  reservationGroupId String?           @map("reservation_group_id")
  groupRoomIndex     Int?              @map("group_room_index")
  reservationGroup   ReservationGroup? @relation(fields: [reservationGroupId], references: [id], onDelete: SetNull)

  // Sprint AUTO-CHECKIN (2026-06-11) — pre-arrival identity capture. El huésped
  // recibe un email con link token-gated (`/precheckin/:token`) para corregir sus
  // datos (pre-cargados de Channex) + subir foto de ID antes de llegar. Carga
  // OPCIONAL; agiliza (no elimina) el check-in en recepción. El token raw NUNCA
  // se persiste — solo su SHA256 (patrón setupTokenHash §179, anti-IDOR).
  precheckinTokenHash      String?   @unique @map("precheckin_token_hash")
  precheckinTokenExpiresAt DateTime? @map("precheckin_token_expires_at")
  precheckinSentAt         DateTime? @map("precheckin_sent_at")       // email enviado
  precheckinSubmittedAt    DateTime? @map("precheckin_submitted_at")  // huésped completó
  precheckinReminderSentAt DateTime? @map("precheckin_reminder_sent_at") // recordatorio 24h
  // Campos que el huésped confirmó/corrigió en el pre-checkin. El BookingModify
  // de Channex (§136) NO debe sobrescribir estos (la corrección del huésped gana).
  guestVerifiedFields      String[]  @default([]) @map("guest_verified_fields")

  organization       Organization        @relation(fields: [organizationId], references: [id])
  room               Room                @relation(fields: [roomId], references: [id])
  stayJourney        StayJourney?
  staySegments       StaySegment[]
  contactLogs        GuestContactLog[]
  paymentLogs        PaymentLog[]        @relation("StayPayments")
  // GROUP-PAYMENTS Fase A — pagos que ESTA stay entregó por OTRAS habitaciones
  // del grupo (Juan paga la habitación de María). Inverso de PaymentLog.paidByStay.
  paymentsPaidFor    PaymentLog[]        @relation("StayPaidByPayments")
  guestStayLogs      GuestStayLog[]
  noteThread         GuestStayNote[]
  channexWebhookLogs ChannexWebhookLog[]
  // GROUP-BILLING Fase C — política de cancelación aplicable (FK real; el hook
  // cancellationPolicyId existía desde CANCEL-ARCHIVE §95 como string suelto).
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id], onDelete: SetNull)
  // MIGRATION-CORE (Zenix Onboard) — trazabilidad + idempotencia de migración.
  // source='MIGRATED' marca reservas importadas desde otro PMS; migrationSourceId
  // = id en el PMS origen; UNIQUE (job, source) evita duplicar en re-run del load.
  migrationSourceId  String?       @map("migration_source_id")
  migrationJobId     String?       @map("migration_job_id")
  migrationJob       MigrationJob? @relation(fields: [migrationJobId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([roomId])
  @@index([paymentStatus])
  @@index([noShowAt])
  @@index([cancelledAt])
  @@index([channexConflict])
  @@index([otaReservationCode])
  @@index([reservationGroupId])
  @@unique([migrationJobId, migrationSourceId])
  @@index([migrationJobId])
  // Sprint testing BUG #21 — calendar timeline + overstayed widget rendering
  // hacían SEQ SCAN sobre guest_stays. A 78 rows = 0.16 ms; proyección 100k
  // = ~200 ms p95. Calendar query usa propertyId + checkinAt range; overstayed
  // usa propertyId + scheduledCheckout < today + actualCheckout IS NULL.
  @@index([propertyId, checkinAt])
  @@index([propertyId, scheduledCheckout, actualCheckout])
  @@map("guest_stays")
}

// ====== MIGRATION-CORE / Zenix Onboard (Sprint 0, 2026-06-13) ================
// Motor de migración desde otro PMS. Plan: docs/sprints/MIGRATION-CORE-plan.md.
// organizationId/propertyId/uploadedById son escalares denormalizados (§66) — sin
// @relation para no inflar Organization/Property. Todo el staging es DESCARTABLE:
// borrar un MigrationJob pre-load no deja rastro en producción (cascade).
// Status/enums se guardan como String (valores en packages/shared/enums.ts) —
// filosofía "espiral" (§95): evita migration churn mientras el módulo evoluciona.

model MigrationJob {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  /** MigrationSource: GENERIC_CSV | CLOUDBEDS | MEWS | … */
  sourceSystem   String   @map("source_system")
  /** MigrationJobStatus: DRAFT | PARSING | VALIDATING | PREVIEW_READY | LOADING | COMPLETED | PARTIAL | FAILED */
  status         String   @default("DRAFT")
  fileName       String?  @map("file_name")
  /** sha256 del archivo subido — idempotencia de re-subida. */
  fileHash       String?  @map("file_hash")
  uploadedById   String   @map("uploaded_by_id")
  /** Mapeo de columnas usado (GenericCsvAdapter / pre-map del adapter). */
  columnMapping  Json?    @map("column_mapping")
  /** Conteos: { parsed, ok, warn, error, loaded, skipped, failed }. */
  counts         Json?
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  stagingReservations MigrationStagingReservation[]
  stagingGuests       MigrationStagingGuest[]
  conflicts           MigrationConflict[]
  /** Reservas productivas creadas por este job (trazabilidad + idempotencia). */
  migratedStays       GuestStay[]

  @@index([organizationId, propertyId])
  @@index([status])
  @@index([propertyId, fileHash])
  @@map("migration_jobs")
}

model MigrationStagingReservation {
  id         String       @id @default(uuid())
  jobId      String       @map("job_id")
  job        MigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex   Int          @map("row_index")
  /** Fila cruda original del archivo (auditoría del mapeo). */
  rawJson    Json         @map("raw_json")
  /** MigrationReservationDto normalizado (post-adapter + normalizer). */
  mapped     Json?
  /** MigrationRowStatus: OK | WARN | ERROR */
  validationStatus String  @default("OK") @map("validation_status")
  /** Issues tipados de validación: [{type, message}]. */
  issues     Json?
  /** MigrationResolution: PENDING | SKIP | ACCEPT | REASSIGN */
  resolution String       @default("PENDING")
  /** Habitación destino al resolver REASSIGN. */
  targetRoomId String?    @map("target_room_id")
  resolutionReason String? @map("resolution_reason")

  @@index([jobId])
  @@index([jobId, validationStatus])
  @@map("migration_staging_reservations")
}

model MigrationStagingGuest {
  id        String       @id @default(uuid())
  jobId     String       @map("job_id")
  job       MigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rawJson   Json         @map("raw_json")
  mapped    Json?
  /** Si es duplicado, id del huésped Zenix con el que se fusiona. */
  mergeIntoGuestId String? @map("merge_into_guest_id")

  @@index([jobId])
  @@map("migration_staging_guests")
}

model MigrationConflict {
  id        String       @id @default(uuid())
  jobId     String       @map("job_id")
  job       MigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /** MigrationConflictType: ROOM_OVERLAP | BED_OVERLAP | DUP_GUEST | NO_ROOM_MATCH | UNMAPPED_RATE | BAD_DATE | NEGATIVE_AMOUNT */
  type      String
  /** MigrationConflictSeverity: WARN | ERROR */
  severity  String       @default("WARN")
  /** Referencias a las filas staging involucradas (ej. los 2 lados de un empalme). */
  rowRefs   Json         @map("row_refs")
  message   String?
  /** Sugerencia de resolución (ej. habitación libre alternativa). */
  suggestion Json?
  resolvedAt DateTime?   @map("resolved_at")

  @@index([jobId])
  @@index([jobId, type])
  @@map("migration_conflicts")
}

// ====== Cancellation Policy (Sprint GROUP-BILLING Fase C, 2026-06-01) =========
//
// Política de cancelación per-property (per-rate-plan en v1.0.1 cuando exista
// RatePlan de RATES-METRICS). Define la ventana gratuita + tramos de penalización
// por tiempo-al-check-in. El motor CancellationPolicyService.computeOutcome()
// calcula retención/reembolso; el reembolso se REGISTRA (no se procesa por
// Stripe, §195/§C5). D-GRP-C1/C2.
model CancellationPolicy {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  propertyId      String   @map("property_id")
  name            String
  // Política por defecto de la property (se asigna a reservas nuevas sin policy
  // explícita). Una sola default por property (enforce a nivel app).
  isDefault       Boolean  @default(false) @map("is_default")
  // Cancelación gratuita si faltan >= freeWindowHours para el check-in.
  freeWindowHours Int      @default(48) @map("free_window_hours")
  // Tramos de penalización por tiempo-al-check-in, ordenados de mayor a menor
  // antelación. Cada tramo: { fromHours, toHours, chargeType, value }.
  //   chargeType: 'NIGHTS' (value = nº noches × ratePerNight)
  //             | 'PERCENT' (value = % del totalAmount)
  //             | 'FIXED'   (value = monto absoluto en la moneda del folio)
  // El último tramo (toHours = 0) cubre el no-show. Ej:
  //   [{fromHours:48,toHours:24,chargeType:'NIGHTS',value:1},
  //    {fromHours:24,toHours:0, chargeType:'PERCENT',value:100}]
  tiers           Json
  // Informativo/derivado: FULL | PARTIAL | NONE (qué se reembolsa típicamente).
  refundMode      String   @default("PARTIAL") @map("refund_mode")
  // Override per-grupo (ventana más larga + depósito, per industria). Mismo
  // shape que el nivel raíz; null = usa los tramos base. D-GRP-C7.
  groupOverride   Json?    @map("group_override")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  stays        GuestStay[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([propertyId, isDefault])
  @@map("cancellation_policies")
}

// ====== Reservation Group (Sprint CHECK-IN C2, 2026-05-29) ===================
//
// Entidad de primera clase para reservas OTA multi-room. Diferenciador único
// LATAM: ningún PMS competidor (Mews, Cloudbeds, Opera, Little Hotelier,
// RoomRaccoon, Sirvoy) cubre simultáneamente auto-detección + bracket
// visual calendar + check-in 3-modos hostal per-bed + cancel parcial como
// MODIFY a Channex.
//
// Decisiones §153-§158 CLAUDE.md:
//  · channexBookingId @unique — idempotency natural (1 group por reserva OTA)
//  · primaryGuestName/Email/Phone — datos del titular común a todas las rooms
//  · groupSize = total personas; roomCount = total habitaciones
//  · groupCheckIn/Out = rango agregado (min/max de las stays)
//  · cancelledAt = cuando TODAS las stays están canceladas (cascade desde
//    la última stay activa que se cancela)
//  · masterFolioId reservado para v1.0.1 PAY-CORE (folio agregado por grupo)
//
// Backward compat: reservationGroupId es NULLABLE en GuestStay. Stays single
// existentes NO se tocan. Solo nuevas reservas OTA con rooms > 1 crean group.
model ReservationGroup {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  propertyId     String @map("property_id")

  // Channex OTA reference. UNIQUE garantiza idempotency (webhook replay no
  // crea group duplicado). Null si el grupo nace de un flow manual futuro.
  channexBookingId String? @unique @map("channex_booking_id")
  channexOtaName   String? @map("channex_ota_name")
  // Código de reserva de la OTA visible al personal (Booking/Expedia confirmation).
  otaReservationCode String? @map("ota_reservation_code")

  // Datos del titular (común para todas las rooms del grupo). Vienen de
  // revision.customer en Channex inbound.
  primaryGuestName  String  @map("primary_guest_name")
  primaryGuestEmail String? @map("primary_guest_email")
  primaryGuestPhone String? @map("primary_guest_phone")

  // Tamaño del grupo
  groupSize Int @map("group_size") // total personas (sum occupancy)
  roomCount Int @map("room_count") // total habitaciones

  // Fechas del journey grupal (rango agregado)
  groupCheckIn  DateTime @map("group_check_in")
  groupCheckOut DateTime @map("group_check_out")

  // Cancel state — cascade desde stays. cancelledAt != null cuando TODAS
  // las stays del grupo están canceladas.
  cancelledAt DateTime? @map("cancelled_at")

  // Hook v1.0.1 PAY-CORE — master folio agregado del grupo. Permite que el
  // titular pague una sola cuenta consolidada en lugar de N folios separados.
  // masterFolioId  String?      @map("master_folio_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  stays        GuestStay[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([channexBookingId])
  @@index([cancelledAt])
  @@map("reservation_groups")
}

// ===================== CHANNEX INBOUND (Sprint CHANNEX-INBOUND) =====================
//
// Append-only audit log of every webhook received from Channex.io.
// D-CHX4: inmutable — fiscal-grade trace para chargeback Visa §5.9.2.
// Cubre los 4 event types: booking_new, booking_modify, booking_cancel,
// availability_modify. Cada delivery deja entry, incluso si auth header
// inválido (signatureValid=false) para forense de intentos de inyección.
//
// IMPORTANTE — Channex NO firma payloads con HMAC. El campo signatureValid
// captura el resultado del custom-header bearer token (PropertySettings
// .channexWebhookSecret) que NOSOTROS configuramos al registrar el webhook
// en Channex. La verdadera autenticación inbound ocurre cuando llamamos de
// vuelta a Channex con user-api-key para hacer pull de la revision.

model ChannexWebhookLog {
  id               String    @id @default(uuid())
  propertyId       String    @map("property_id")
  eventType        String    @map("event_type") // booking_new | booking_modify | booking_cancel | availability_modify
  channexBookingId String?   @map("channex_booking_id")
  channexRevision  Int?      @map("channex_revision")
  payload          Json
  signatureValid   Boolean   @map("signature_valid")
  receivedAt       DateTime  @default(now()) @map("received_at")
  processedAt      DateTime? @map("processed_at")
  // 'created' | 'updated' | 'cancelled' | 'conflict' | 'rejected' | 'pending' | 'unassigned'
  result           String?
  errorMessage     String?   @map("error_message")
  resultingStayId  String?   @map("resulting_stay_id")

  resultingStay GuestStay? @relation(fields: [resultingStayId], references: [id])

  @@index([propertyId, receivedAt])
  @@index([channexBookingId])
  @@index([eventType])
  @@map("channex_webhook_logs")
}

// ===================== CHANNEX OUTBOX (Sprint CHANNEX-INBOUND, D-CHX10) =====================
//
// Postgres-based async queue para procesamiento de webhooks Channex.
// Patrón "transactional outbox" — el webhook controller persiste en
// MISMA transacción ChannexWebhookLog + ChannexOutbox(PENDING). Esto
// garantiza que cada webhook recibido tendrá un job de procesamiento
// (no se pierde si crashea el worker antes de procesar).
//
// Por qué Postgres y no Redis/BullMQ en v1.0.0:
//   - Evita dependencia Redis (dispararía fase 2 de infra antes de tiempo
//     según §73-§75 CLAUDE.md — Vercel+Render+Neon es la fase 1).
//   - Suficiente para 1-10 properties (<100 webhooks/día típico).
//   - LISTEN/NOTIFY o cron 30s polling. Empezamos con cron por simplicidad.
//
// Status machine:
//   PENDING       → recién encolado por el webhook controller
//   IN_PROGRESS   → worker tomó el row (UPDATE ... WHERE status=PENDING
//                   FOR UPDATE SKIP LOCKED → no race entre workers)
//   SUCCEEDED     → pull+save+ack completados; terminal
//   FAILED        → reintento programado en nextAttemptAt (backoff expo)
//   DEAD_LETTER   → max attempts (5) excedido; requiere acción humana
//
// Auditabilidad: cada transición se loggea en el campo `lastError` y
// `attempts` se incrementa atómicamente. Append-only en spirit (no
// borramos rows SUCCEEDED — los purgamos en cron nocturno post-30d
// para no inflar la tabla).

enum ChannexOutboxStatus {
  PENDING
  IN_PROGRESS
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

// ===================== CHANNEX OUTBOUND (Sprint CHANNEX-OUTBOUND-CERT) =====================
//
// Estructuralmente separa AVAILABILITY (POST /availability) de
// RATES_RESTRICTIONS (POST /restrictions, que incluye tanto rates como
// CTA/CTD/min_stay/max_stay/stop_sell según docs Channex). La separación
// hace AP-2.8 (mixed payload) imposible — el worker drena cada kind como
// mensaje HTTP separado.
//
// Anti-patterns mitigated:
//   · AP-3 (full-sync timer) → solo FullSyncOrchestrator puede setear
//     payload completo, y respeta channexLastFullSyncAt 24h gate.
//   · AP-4 (per-date loops) → payload.entries es array; el worker batch.
//   · AP-2.2 (direct API call) → save handlers emiten event → builder
//     persiste row → worker async drena. Save no se bloquea si Channex cae.
//   · AP-2.8 → kind separa los dos endpoints estructuralmente.
//
// payloadHash sirve para dedup: si el mismo delta llega 2× en 5s por un
// double-click del recepcionista, solo encolamos uno (anti-flood).
//
// priority: AVAILABILITY=100 (Channex doc dice "push these updates to the
// front of the queue"), RATES_RESTRICTIONS=50.

enum ChannexOutboundKind {
  AVAILABILITY // POST /api/v1/availability — count per [property, room_type, date]
  RATES_RESTRICTIONS // POST /api/v1/restrictions — rates + min/max stay + CTA/CTD + stop_sell per [property, rate_plan, date]
  BOOKING_CANCEL // PUT /api/v1/bookings/:id status=cancelled — manual cancel from PMS, propagates to OTA (Sprint CHANNEX-UX-E2-E3 §150)
}

enum ChannexOutboundStatus {
  PENDING
  IN_PROGRESS
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

model ChannexOutboundQueue {
  id            String                @id @default(uuid())
  propertyId    String                @map("property_id")
  kind          ChannexOutboundKind
  // Delta-only payload (AP-3): { entries: [{...}] }. NUNCA dump completo
  // salvo el FullSyncOrchestrator que tiene su propia idempotencia 24h.
  payload       Json
  status        ChannexOutboundStatus @default(PENDING)
  // AVAILABILITY=100, RATES_RESTRICTIONS=50 (Channex prioriza avail)
  priority      Int                   @default(50)
  attempts      Int                   @default(0)
  lastError     String?               @map("last_error")
  // Backoff: tras 429 respeta Retry-After; tras 5xx 2^attempts seconds
  nextAttemptAt DateTime              @default(now()) @map("next_attempt_at")
  // Lock holder identifier (hostname:pid) para multi-worker debug
  lockedAt      DateTime?             @map("locked_at")
  lockedBy      String?               @map("locked_by")
  processedAt   DateTime?             @map("processed_at")
  // Anti-flood: SHA-256 del payload (kind+propertyId+entries normalizadas).
  // Si llega outro row con mismo hash en estado PENDING/IN_PROGRESS, lo
  // descartamos como duplicado.
  payloadHash   String                @map("payload_hash")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  // Worker pickup query: WHERE status IN (PENDING, FAILED) AND nextAttemptAt <= NOW()
  // ORDER BY priority DESC, nextAttemptAt ASC
  @@index([status, priority, nextAttemptAt])
  @@index([propertyId, status])
  @@index([payloadHash])
  @@map("channex_outbound_queue")
}

model ChannexOutbox {
  id                String              @id @default(uuid())
  propertyId        String              @map("property_id")
  eventType         String              @map("event_type")
  channexBookingId  String?             @map("channex_booking_id")
  channexRevisionId String?             @map("channex_revision_id")
  webhookLogId      String?             @map("webhook_log_id") // FK informal a ChannexWebhookLog
  status            ChannexOutboxStatus @default(PENDING)
  attempts          Int                 @default(0)
  lastError         String?             @map("last_error")
  // Cuando este row está disponible para procesarse. Permite backoff
  // exponencial: tras un FAILED se actualiza a now() + 2^attempts segundos.
  nextAttemptAt     DateTime            @default(now()) @map("next_attempt_at")
  // Lock holder identifier (hostname:pid) — debug + force-release manual.
  lockedBy          String?             @map("locked_by")
  lockedAt          DateTime?           @map("locked_at")
  processedAt       DateTime?           @map("processed_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  // Query principal del worker: pick the oldest PENDING/FAILED ready to run.
  @@index([status, nextAttemptAt])
  @@index([propertyId, status])
  @@index([channexBookingId])
  @@map("channex_outbox")
}

// ===================== PRE-CHECKIN QUALITY SYSTEM =====================
//
// Restaurado desde migration 20260402192948_add_pre_checkin_quality_system.
// Workflow: al hacer checkout de un huésped (OnEvent 'checkout.confirmed'),
// se crea automáticamente un RoomReadinessTask con items copiados del
// RoomTypeChecklist activo para la propiedad. Housekeeping los marca (PENDING
// → DONE | ISSUE_FOUND | SKIPPED) antes del siguiente check-in.

enum ReadinessStatus {
  PENDING
  IN_PROGRESS
  NEEDS_MAINTENANCE
  READY
  APPROVED
}

enum ItemStatus {
  PENDING
  DONE
  ISSUE_FOUND
  SKIPPED
}

model RoomTypeChecklist {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  roomTypeId     String?  @map("room_type_id")
  name           String
  triggerOn      String   @default("checkout")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization        @relation(fields: [organizationId], references: [id])
  items          ChecklistItem[]
  readinessTasks RoomReadinessTask[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_type_checklists")
}

model ChecklistItem {
  id            String  @id @default(uuid())
  checklistId   String  @map("checklist_id")
  category      String
  description   String
  isRequired    Boolean @default(true) @map("is_required")
  requiresPhoto Boolean @default(false) @map("requires_photo")
  sortOrder     Int     @default(0) @map("sort_order")

  checklist RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  taskItems RoomReadinessTaskItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model RoomReadinessTask {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  propertyId     String          @map("property_id")
  roomId         String          @map("room_id")
  checklistId    String          @map("checklist_id")
  assignedToId   String?         @map("assigned_to_id")
  triggeredBy    String          @map("triggered_by")
  status         ReadinessStatus @default(PENDING)
  dueBy          DateTime?       @map("due_by")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id])
  room         Room                    @relation(fields: [roomId], references: [id])
  checklist    RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  items        RoomReadinessTaskItem[]

  @@index([organizationId])
  @@index([roomId, status])
  @@map("room_readiness_tasks")
}

model RoomReadinessTaskItem {
  id                  String     @id @default(uuid())
  taskId              String     @map("task_id")
  checklistItemId     String     @map("checklist_item_id")
  status              ItemStatus @default(PENDING)
  completedById       String?    @map("completed_by_id")
  completedAt         DateTime?  @map("completed_at")
  photoUrl            String?    @map("photo_url")
  notes               String?
  // ── Sprint Mx-1 — vínculo con ticket levantado al detectar problema ─────
  // El housekeeper marca un item del checklist como "issue detected" → se crea
  // automáticamente un MaintenanceTicket con sourceTaskId = task.cleaningTaskId
  // (si aplica) y se guarda el id aquí para auditoría inversa.
  maintenanceTicketId String?    @map("maintenance_ticket_id")

  task              RoomReadinessTask  @relation(fields: [taskId], references: [id])
  checklistItem     ChecklistItem      @relation(fields: [checklistItemId], references: [id])
  maintenanceTicket MaintenanceTicket? @relation("ItemMaintenanceTicket", fields: [maintenanceTicketId], references: [id])

  @@index([taskId])
  @@index([maintenanceTicketId])
  @@map("room_readiness_task_items")
}

// ======================== STAY JOURNEY MODEL =========================
//
// Restaurado desde migration 20260410000000_add_stay_journey_model.
// Modela una estadía completa como journey + segmentos (permite extensiones
// y mudanzas de habitación) + nights (ingresos diarios para reporting).

enum StayJourneyStatus {
  ACTIVE
  CHECKED_OUT
  CANCELLED
  NO_SHOW

  @@map("stay_journey_status")
}

enum SegmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("segment_status")
}

enum SegmentReason {
  ORIGINAL
  EXTENSION_SAME_ROOM
  EXTENSION_NEW_ROOM
  ROOM_MOVE
  SPLIT

  @@map("segment_reason")
}

enum NightStatus {
  PENDING
  POSTED
  LOCKED

  @@map("night_status")
}

enum JourneyEventType {
  JOURNEY_CREATED
  SEGMENT_ADDED
  SEGMENT_LOCKED
  ROOM_MOVE_EXECUTED
  EXTENSION_APPROVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW_MARKED
  NO_SHOW_REVERTED
  JOURNEY_SPLIT
  RESTORED

  @@map("journey_event_type")
}

// ── Payment method for front-desk transactions ────────────────────────────────
// CARD_TERMINAL: POS físico externo — Zenix guarda solo el número de referencia
// del comprobante, nunca datos de tarjeta (PCI DSS fuera de alcance para TERMINAL).
enum PaymentMethod {
  CASH
  CARD_TERMINAL
  BANK_TRANSFER
  OTA_PREPAID
  COMP

  @@map("payment_method")
}

// ── Tipo de acceso físico entregado al huésped en check-in ────────────────────
enum KeyDeliveryType {
  PHYSICAL // llave física tradicional
  CARD // tarjeta magnética / RFID
  CODE // PIN / código numérico
  MOBILE // link o app móvil

  @@map("key_delivery_type")
}

// ── No-Show charge lifecycle ──────────────────────────────────────────────────
// NOT_APPLICABLE → policy = NONE (tarifa gratuita)
// PENDING        → registrado, esperando procesamiento de pago
// CHARGED        → cobro procesado exitosamente
// FAILED         → tarjeta rechazada (requiere acción manual)
// WAIVED         → exonerado por supervisor (fee perdonado)
enum NoShowChargeStatus {
  NOT_APPLICABLE
  PENDING
  CHARGED
  FAILED
  WAIVED
}

// Audit trail append-only para eventos de ciclo de vida de una reserva.
// Patrón análogo a §28 PaymentLog: never UPDATE, never DELETE — solo INSERT.
// `event` y `actorType` son strings (no enums) para extensión sin migration.
// Eventos esperados v1.0.0: CREATED, CANCELLED, RESTORED, MODIFIED, ANONYMIZED.
// Futuros: CFDI_E_ISSUED (v1.0.2), CHANNEX_ACK (Channex sprint), REFUND_PROCESSED (v1.0.1).
model GuestStayLog {
  id         String   @id @default(uuid())
  stayId     String   @map("stay_id")
  event      String
  actorId    String?  @map("actor_id")
  actorType  String   @default("USER") @map("actor_type")
  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at")

  stay GuestStay @relation(fields: [stayId], references: [id])

  @@index([stayId, occurredAt])
  @@index([event])
  @@map("guest_stay_logs")
}

// ── GuestStayNote — bitácora/chat humano de la reserva ────────────────────
// Sprint EDIT-RESERVATION. Diferente de GuestStayLog (audit automático del
// sistema). Las notas son creadas por staff (recep / housekeeper / supervisor)
// con propósito de comunicación intra-turno. Patrón análogo a
// MaintenanceTicketComment. Append-only.
//
// Editable hasta 5 minutos post-creación por el mismo autor (anti-typo); no
// hay delete — si la nota está mal, se agrega otra nota corrigiendo.
model GuestStayNote {
  id        String    @id @default(uuid())
  stayId    String    @map("stay_id")
  authorId  String    @map("author_id")
  content   String    @db.Text
  // Channel hint para filtrado UI: 'GENERAL' | 'GUEST_REQUEST' | 'HOUSEKEEPING' | 'INTERNAL'
  // Default GENERAL. No enum — patrón "espiral" §95 para evolución sin migration.
  channel   String    @default("GENERAL")
  // Sprint 2026-05-20 — kind discriminator:
  //   'CHAT'   — mensaje de bitácora team (default). Telegram-style chat UI.
  //   'STICKY' — postit pinned, siempre visible en el sidebar derecho.
  //   'SYSTEM' — mensaje automático de Zenix (audit + futuro AI agents).
  //              authorId NULL/empty cuando kind=SYSTEM.
  kind      String    @default("CHAT")
  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")

  stay GuestStay @relation(fields: [stayId], references: [id])

  @@index([stayId, createdAt])
  @@index([stayId, kind])
  @@map("guest_stay_notes")
}

model StayJourney {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  propertyId      String            @map("property_id")
  guestStayId     String?           @unique @map("guest_stay_id")
  guestName       String            @map("guest_name")
  guestEmail      String?           @map("guest_email")
  status          StayJourneyStatus @default(ACTIVE)
  journeyCheckIn  DateTime          @map("journey_check_in")
  journeyCheckOut DateTime          @map("journey_check_out")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  property     Property           @relation(fields: [propertyId], references: [id])
  guestStay    GuestStay?         @relation(fields: [guestStayId], references: [id])
  segments     StaySegment[]
  events       StayJourneyEvent[]

  @@index([organizationId, status])
  @@index([propertyId, journeyCheckIn, journeyCheckOut])
  @@map("stay_journeys")
}

model StaySegment {
  id           String        @id @default(uuid())
  journeyId    String        @map("journey_id")
  roomId       String        @map("room_id")
  guestStayId  String?       @map("guest_stay_id")
  checkIn      DateTime      @map("check_in")
  checkOut     DateTime      @map("check_out")
  status       SegmentStatus @default(PENDING)
  locked       Boolean       @default(false)
  reason       SegmentReason @default(ORIGINAL)
  rateSnapshot Decimal?      @map("rate_snapshot") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  /// Timestamp en que recepción confirmó FÍSICAMENTE que el guest cambió de
  /// habitación (le entregaron la nueva llave). Solo aplica a segments con
  /// reason en [EXTENSION_NEW_ROOM, ROOM_MOVE]. NULL = mudanza pendiente o no
  /// aplica. Sprint MOVE-CONFIRM 2026-05-18: separa el flow operativo (mudanza
  /// hecha = HK puede limpiar room previa) del flow contable (segment activo).
  moveConfirmedAt   DateTime? @map("move_confirmed_at")
  moveConfirmedById String?   @map("move_confirmed_by_id")

  journey   StayJourney    @relation(fields: [journeyId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  guestStay GuestStay?     @relation(fields: [guestStayId], references: [id])
  nights    SegmentNight[]

  @@index([journeyId])
  @@index([roomId, checkIn, checkOut])
  @@index([status, locked])
  @@index([moveConfirmedAt])
  @@map("stay_segments")
}

model SegmentNight {
  id        String      @id @default(uuid())
  segmentId String      @map("segment_id")
  date      DateTime    @db.Date
  rate      Decimal     @db.Decimal(10, 2)
  status    NightStatus @default(PENDING)
  locked    Boolean     @default(false)

  segment StaySegment @relation(fields: [segmentId], references: [id])

  @@unique([segmentId, date])
  @@index([date])
  @@index([segmentId, locked])
  @@map("segment_nights")
}

model StayJourneyEvent {
  id         String           @id @default(uuid())
  journeyId  String           @map("journey_id")
  eventType  JourneyEventType @map("event_type")
  actorId    String?          @map("actor_id")
  payload    Json
  occurredAt DateTime         @default(now()) @map("occurred_at")

  journey StayJourney @relation(fields: [journeyId], references: [id])

  @@index([journeyId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("stay_journey_events")
}

// ======================= SMARTBLOCK =======================

enum BlockSemantic {
  OUT_OF_SERVICE
  OUT_OF_ORDER
  OUT_OF_INVENTORY
  HOUSE_USE
}

enum BlockReason {
  MAINTENANCE
  DEEP_CLEANING
  INSPECTION
  PHOTOGRAPHY
  VIP_SETUP
  PEST_CONTROL
  WATER_DAMAGE
  ELECTRICAL
  PLUMBING
  STRUCTURAL
  RENOVATION
  OWNER_STAY
  STAFF_USE
  OTHER
}

enum BlockStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EXPIRED
  CANCELLED
  REJECTED
}

enum BlockLogEvent {
  CREATED
  APPROVED
  REJECTED
  ACTIVATED
  EXTENDED
  EARLY_RELEASE
  CANCELLED
  EXPIRED
  NOTE_ADDED
}

/**
 * RoomBlock — bloqueo de unidad o habitación con workflow de aprobación.
 * Granularidad:
 * unitId != null → bloqueo de unidad individual (dormitorios compartidos)
 * unitId == null → bloqueo de habitación completa
 * Semánticas:
 * OUT_OF_SERVICE   → problema menor, no impacta RevPAR
 * OUT_OF_ORDER     → inhabilitada, impacta RevPAR, requiere aprobación
 * OUT_OF_INVENTORY → largo plazo, excluida del inventario operativo
 * HOUSE_USE        → uso interno (fotos, staff)
 * Al activarse (APPROVED → ACTIVE):
 * 1. Se crea CleaningTask(MAINTENANCE, UNASSIGNED)
 * 2. unit.status = BLOCKED
 * 3. SSE: block:activated
 * Auto-aprobación:
 * OOS + actor = SUPERVISOR → APPROVED inmediato (sin pasar por PENDING)
 * HOUSE_USE + actor = SUPERVISOR → APPROVED inmediato
 * Cualquier otro caso → PENDING_APPROVAL
 */
model RoomBlock {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  propertyId     String  @map("property_id")
  roomId         String? @map("room_id") // null = solo unidad
  unitId         String? @map("unit_id") // null = habitación completa

  semantic BlockSemantic
  reason   BlockReason
  status   BlockStatus   @default(PENDING_APPROVAL)

  notes         String? // visible para housekeeping
  internalNotes String? @map("internal_notes") // solo supervisores

  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date // null = indefinido

  requestedById String    @map("requested_by_id")
  approvedById  String?   @map("approved_by_id")
  approvalNotes String?   @map("approval_notes")
  approvedAt    DateTime? @map("approved_at")

  // Tarea de mantenimiento creada automáticamente al activar el bloqueo
  cleaningTaskId String? @unique @map("cleaning_task_id")

  // ── Sprint Mx-1 — Mantenimiento (Bridge crítico inventario ↔ tickets) ───
  // FK al ticket que disparó este bloqueo automático (TicketPriority.CRITICAL).
  // Se coloca del lado del bloque para evitar dependencia FK circular con
  // MaintenanceTicket. La reverse relation `MaintenanceTicket.autoBlock` no
  // tiene FK propia. @unique garantiza 1 bloque automático por ticket.
  maintenanceTicketId String? @unique @map("maintenance_ticket_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id])
  room              Room?              @relation(fields: [roomId], references: [id])
  unit              Unit?              @relation(fields: [unitId], references: [id])
  requestedBy       Staff              @relation("BlocksRequested", fields: [requestedById], references: [id])
  approvedBy        Staff?             @relation("BlocksApproved", fields: [approvedById], references: [id])
  cleaningTask      CleaningTask?      @relation("BlockTask", fields: [cleaningTaskId], references: [id])
  maintenanceTicket MaintenanceTicket? @relation("BlockMaintenanceTicket", fields: [maintenanceTicketId], references: [id])
  logs              BlockLog[]

  @@index([organizationId, propertyId, status])
  @@index([unitId, status])
  @@index([roomId, status])
  @@index([startDate, endDate])
  @@map("room_blocks")
}

/**
 * BlockLog — bitácora inmutable de cambios de estado.
 * staffId es null para eventos del sistema (cron, auto-activación).
 */
model BlockLog {
  id        String        @id @default(uuid())
  blockId   String        @map("block_id")
  staffId   String?       @map("staff_id")
  event     BlockLogEvent
  note      String?
  metadata  Json? // contexto adicional: { previousStatus, reason, etc }
  createdAt DateTime      @default(now()) @map("created_at")

  block RoomBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  staff Staff?    @relation("BlockLogs", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([blockId])
  @@index([createdAt])
  @@map("block_logs")
}

// ── Guest contact channel ─────────────────────────────────────────────────────
enum ContactChannel {
  WHATSAPP
  EMAIL
  PHONE
}

// ── Guest contact log (append-only, for dispute documentation) ───────────────
// Cada intento de contacto queda registrado: quién lo hizo, cuándo, por qué canal.
// Usar como evidencia ante chargebacks u otras disputas con OTAs.
model GuestContactLog {
  id             String         @id @default(uuid())
  stayId         String         @map("stay_id")
  channel        ContactChannel
  // sentById es null para envíos automáticos del sistema (cron de potencial no-show).
  // Non-null para envíos manuales desde BookingDetailSheet (recepcionista identificado).
  sentById       String?        @map("sent_by_id")
  sentAt         DateTime       @default(now()) @map("sent_at")
  messagePreview String?        @map("message_preview")

  stay   GuestStay @relation(fields: [stayId], references: [id])
  sentBy Staff?    @relation("ContactLogs", fields: [sentById], references: [id])

  @@index([stayId])
  @@index([sentAt])
  @@map("guest_contact_logs")
}

// ======================= NOTIFICATION CENTER =======================
//
// Persistent, stored notifications with full audit trail (Facebook-style).
// Separate from NotificationsModule which provides ephemeral SSE streaming.
//
// Recipient targeting:
//   USER         → recipientId = staffId (personal notification)
//   ROLE         → recipientRole = StaffRole (fan-out to role)
//   PROPERTY_ALL → all staff in the property
//
// Type lifecycle:
//   INFORMATIONAL    → read-only, no action needed
//   ACTION_REQUIRED  → surfaced prominently until read
//   APPROVAL_REQUIRED → records decision in AppNotificationApproval

model AppNotification {
  id             String                  @id @default(uuid())
  organizationId String                  @map("organization_id")
  propertyId     String?                 @map("property_id")
  type           AppNotificationType
  category       AppNotificationCategory
  priority       AppNotificationPriority @default(MEDIUM)
  title          String
  body           String
  metadata       Json?
  actionUrl      String?                 @map("action_url")
  recipientType  NotificationRecipient   @map("recipient_type")
  recipientId    String?                 @map("recipient_id")
  recipientRole  StaffRole?              @map("recipient_role")
  triggeredById  String?                 @map("triggered_by_id")
  expiresAt      DateTime?               @map("expires_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  organization Organization              @relation(fields: [organizationId], references: [id])
  property     Property?                 @relation(fields: [propertyId], references: [id])
  triggeredBy  Staff?                    @relation("NotifTriggeredBy", fields: [triggeredById], references: [id])
  reads        AppNotificationRead[]
  approvals    AppNotificationApproval[]

  @@index([organizationId, propertyId, createdAt(sort: Desc)])
  @@index([recipientId])
  @@index([recipientRole])
  @@map("app_notifications")
}

model AppNotificationRead {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  readById       String   @map("read_by_id")
  readAt         DateTime @default(now()) @map("read_at")

  notification AppNotification @relation(fields: [notificationId], references: [id])
  readBy       Staff           @relation("NotifReadBy", fields: [readById], references: [id])

  @@unique([notificationId, readById])
  @@map("app_notification_reads")
}

model AppNotificationApproval {
  id             String           @id @default(uuid())
  notificationId String           @map("notification_id")
  action         ApprovalDecision
  actionById     String           @map("action_by_id")
  actionAt       DateTime         @default(now()) @map("action_at")
  reason         String?

  notification AppNotification @relation(fields: [notificationId], references: [id])
  actionBy     Staff           @relation("NotifApprovedBy", fields: [actionById], references: [id])

  @@map("app_notification_approvals")
}

// ======================= PAYMENT LOG =======================
//
// Registro inmutable de pagos recibidos en recepción (USALI-compliant).
// Reglas de inmutabilidad:
//   - No hay campo updatedAt — Prisma no genera rutas UPDATE para este modelo.
//   - La capa de servicio solo permite create(). Nunca update().
//   - Las anulaciones crean un nuevo registro con isVoid=true y amount negativo.
//   - El registro original permanece intacto (trail auditnable).
//
// Anti-fraude:
//   - collectedById identifica al recepcionista que cobró.
//   - COMP / amount=0 requieren approvedById + approvalReason obligatorios.
//   - shiftDate permite reconciliar por turno: sum(CASH, isVoid=false) vs. efectivo físico.
//   - reference = número de autorización del terminal (6-8 dígitos del comprobante),
//     nunca PAN / CVV / track data. Zenix está fuera del flujo de datos de tarjeta.

model PaymentLog {
  id                 String        @id @default(uuid())
  organizationId     String        @map("organization_id")
  propertyId         String        @map("property_id")
  stayId             String        @map("stay_id")
  method             PaymentMethod
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("MXN")
  reference          String? // autorización terminal / referencia bancaria
  approvedById       String?       @map("approved_by_id")
  approvalReason     String?       @map("approval_reason")
  isVoid             Boolean       @default(false) @map("is_void")
  voidedAt           DateTime?     @map("voided_at")
  voidedById         String?       @map("voided_by_id")
  voidReason         String?       @map("void_reason")
  voidsLogId         String?       @unique @map("voids_log_id")
  shiftDate          DateTime      @map("shift_date") @db.Date
  collectedById      String        @map("collected_by_id")
  // GROUP-PAYMENTS Fase A (D-GRP-A1) — cuando un huésped paga por OTRA habitación
  // del mismo grupo, el PaymentLog se registra contra la stay PAGADA (reduce su
  // balance) pero paidByStayId apunta a QUIÉN entregó el dinero. Arqueo correcto
  // + balance correcto sin folio agregado. Null = pago de la propia stay.
  paidByStayId       String?       @map("paid_by_stay_id")
  // Agrupa los N PaymentLogs de un mismo cobro (titular paga varias habitaciones
  // en una transacción). Comparten transactionGroupId para reconciliación.
  transactionGroupId String?       @map("transaction_group_id")
  createdAt          DateTime      @default(now()) @map("created_at")

  stay        GuestStay   @relation("StayPayments", fields: [stayId], references: [id])
  paidByStay  GuestStay?  @relation("StayPaidByPayments", fields: [paidByStayId], references: [id])
  collectedBy Staff       @relation("PaymentCollectedBy", fields: [collectedById], references: [id])
  approvedBy  Staff?      @relation("PaymentApprovedBy", fields: [approvedById], references: [id])
  voidedBy    Staff?      @relation("PaymentVoidedBy", fields: [voidedById], references: [id])
  voidsEntry  PaymentLog? @relation("VoidOf", fields: [voidsLogId], references: [id])
  voidedByLog PaymentLog? @relation("VoidOf")

  @@index([stayId])
  @@index([paidByStayId])
  @@index([transactionGroupId])
  @@index([organizationId, propertyId, shiftDate])
  @@index([collectedById, shiftDate])
  @@map("payment_logs")
}

// ======================= HOUSEKEEPING SCHEDULING (Sprint 8H) =======================
//
// Modelos que sustentan el módulo de recamaristas como diferenciador competitivo:
//   StaffShift            — turno semanal recurrente
//   StaffShiftException   — excepción puntual (vacación, día libre, turno extra)
//   StaffCoverage         — cobertura habitación↔staff (primary/backup)
//   StaffShiftClock       — clock-in/out real (USALI compliance)
//   StaffPreferences      — preferencias del staff (gamificación gestionada por supervisor)
//   StaffPreferenceLog    — audit append-only de cambios a preferences
//
// Decisiones documentadas en CLAUDE.md §35-§46 (D1-D12) y plan vamos-a-comenzar-a-federated-kitten.md.

/**
 * StaffShift — turno semanal recurrente del staff. Fuente de verdad de "quién está en turno".
 * Las excepciones puntuales viven en StaffShiftException (D5: ausencia explícita, etc.)
 * Ejemplo: María trabaja Lun-Vie 7-15.
 * { staffId: 'maria', dayOfWeek: 1, startTime: '07:00', endTime: '15:00', active: true }
 * { staffId: 'maria', dayOfWeek: 2, ... }
 * ...
 */
model StaffShift {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  propertyId     String    @map("property_id")
  staffId        String    @map("staff_id")
  dayOfWeek      Int       @map("day_of_week") // 0 (Sun) - 6 (Sat)
  startTime      String    @map("start_time") // "HH:mm" — local de la propiedad
  endTime        String    @map("end_time") // "HH:mm" — local de la propiedad
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveUntil DateTime? @map("effective_until") @db.Date
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])
  staff        Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([propertyId, dayOfWeek, active])
  @@index([staffId, active])
  @@map("staff_shifts")
}

enum ShiftExceptionType {
  OFF // día libre solicitado / ausencia
  EXTRA // turno adicional cubriendo a alguien
  MODIFIED // misma fecha pero distintas horas
}

/**
 * StaffShiftException — excepción puntual al horario semanal (D5).
 * Tipo OFF se usa también para registrar AUSENCIAS marcadas por el receptionist
 * a través del endpoint POST /v1/scheduling/absences.
 */
model StaffShiftException {
  id           String             @id @default(uuid())
  staffId      String             @map("staff_id")
  date         DateTime           @db.Date
  type         ShiftExceptionType
  startTime    String?            @map("start_time") // null si OFF
  endTime      String?            @map("end_time")
  reason       String?
  approvedById String?            @map("approved_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  staff      Staff  @relation("ShiftExceptionsForStaff", fields: [staffId], references: [id], onDelete: Cascade)
  approvedBy Staff? @relation("ShiftExceptionsApprovedBy", fields: [approvedById], references: [id])

  @@unique([staffId, date])
  @@index([date])
  @@map("staff_shift_exceptions")
}

/**
 * StaffCoverage — qué habitaciones limpia esta recamarista por defecto (D5: soft, no hard).
 * Una habitación puede tener múltiples staff cubriéndola: 1 primary + N backups.
 * El AssignmentService prefiere primary; si no en turno, baja a backup; si nadie cubre, round-robin.
 */
model StaffCoverage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  staffId    String   @map("staff_id")
  roomId     String   @map("room_id")
  isPrimary  Boolean  @default(true) @map("is_primary")
  weight     Int      @default(1) // tiebreaker para round-robin secundario
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // Un staff no puede tener dos coverages para la misma room en el mismo nivel (primary vs backup).
  @@unique([staffId, roomId, isPrimary])
  @@index([propertyId, roomId])
  @@index([roomId, isPrimary])
  @@map("staff_coverages")
}

enum ClockSource {
  MOBILE
  WEB
  MANUAL_SUPERVISOR
}

/**
 * StaffShiftClock — registro real de clock-in/out (USALI auditability).
 * Append-only: nunca se actualiza un clock-in pasado.
 * Para correcciones, el supervisor crea un nuevo registro con source=MANUAL_SUPERVISOR.
 */
model StaffShiftClock {
  id         String      @id @default(uuid())
  staffId    String      @map("staff_id")
  propertyId String      @map("property_id")
  clockInAt  DateTime    @map("clock_in_at")
  clockOutAt DateTime?   @map("clock_out_at")
  source     ClockSource
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")

  staff    Staff    @relation(fields: [staffId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@index([staffId, clockInAt])
  @@index([propertyId, clockInAt])
  @@map("staff_shift_clocks")
}

enum GamificationLevel {
  OFF
  SUBTLE
  STANDARD
}

/**
 * StaffPreferences — preferencias del staff. NOTA: gamificationLevel solo es
 * editable por SUPERVISOR (D9). El staff puede leer su propio registro pero no
 * escribirlo. hapticEnabled / soundEnabled SÍ son self-managed.
 */
model StaffPreferences {
  id                String            @id @default(uuid())
  staffId           String            @unique @map("staff_id")
  gamificationLevel GamificationLevel @default(STANDARD) @map("gamification_level")
  language          String            @default("es-MX")
  hapticEnabled     Boolean           @default(true) @map("haptic_enabled")
  soundEnabled      Boolean           @default(true) @map("sound_enabled")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  staff Staff                @relation(fields: [staffId], references: [id], onDelete: Cascade)
  logs  StaffPreferenceLog[]

  @@map("staff_preferences")
}

/**
 * StaffPreferenceLog — append-only log de cambios a StaffPreferences.
 * Cumple USALI auditability + traza decisiones laborales (quién cambió qué, cuándo, por qué).
 * Útil para cumplir LFPDPPP MX / GDPR / LGPD si un staff cuestiona la configuración.
 */
model StaffPreferenceLog {
  id            String   @id @default(uuid())
  preferencesId String   @map("preferences_id")
  staffId       String   @map("staff_id") // denormalizado para queries directas
  field         String // 'gamificationLevel' | 'language' | etc.
  oldValue      String?  @map("old_value")
  newValue      String   @map("new_value")
  changedById   String   @map("changed_by_id") // siempre presente — sin cambios automáticos
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")

  preferences StaffPreferences @relation(fields: [preferencesId], references: [id], onDelete: Cascade)
  changedBy   Staff            @relation("PreferenceChangesByStaff", fields: [changedById], references: [id])

  @@index([staffId, createdAt])
  @@map("staff_preference_logs")
}

// ============================================================================
// SPRINT 9 — REPORTS / CHANNEL COMMISSIONS
// ============================================================================

/**
 * ChannelCommission — comisión que cada OTA cobra por reserva.
 * Justificación (CLAUDE.md §29 + revenue-data-mapping.md):
 * - Booking típicamente 15%, Airbnb 14-16%, Expedia 18-22%
 * - El % varía por contrato y temporada — no es constante
 * - Necesario para el frame "COMISIONES OTA HOY" del Revenue Carousel
 * - Histórico relevante (effectiveFrom/effectiveUntil) para reportes
 * fiscales correctos cuando un cliente revisa períodos pasados
 * Source uses the same string values as GuestStay.source.
 * Sprint 9+ podríamos migrar a un enum BookingSource compartido.
 * Lookup pattern:
 * const rate = await prisma.channelCommission.findFirst({
 * where: {
 * propertyId,
 * source: 'BOOKING',
 * effectiveFrom: { lte: targetDate },
 * OR: [{ effectiveUntil: null }, { effectiveUntil: { gt: targetDate } }],
 * },
 * orderBy: { effectiveFrom: 'desc' },
 * })
 */
model ChannelCommission {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  propertyId     String    @map("property_id")
  /**
   * Channel source (matches GuestStay.source string values).
   */
  source         String // 'BOOKING' | 'AIRBNB' | 'EXPEDIA' | 'HOSTELWORLD' | etc.
  /**
   * Commission rate as percent (e.g., 15.00 for 15%). Stored as Decimal
   * for exact arithmetic (CLAUDE.md §17 — no float for money).
   */
  ratePercent    Decimal   @map("rate_percent") @db.Decimal(5, 2)
  /**
   * Effective period — supports historical lookups for past reports.
   */
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveUntil DateTime? @map("effective_until") @db.Date
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([propertyId, source, effectiveFrom])
  @@map("channel_commissions")
}

// ============================================================================
// SPRINT 8I-J — HUB RECAMARISTA · GAMIFICACIÓN (privacy-respecting)
// ============================================================================
//
// Anclado a docs/research-housekeeping-hub.md.
// Principios SDT (Deci & Ryan 1985) + privacy peer-to-peer estricta (D9).
//
// NUNCA expuestos a pares ni listados públicamente. Solo:
//   - El propio staff (en su Hub)
//   - Su supervisor (audit trail / coaching)

/**
 * StaffStreak — racha diaria estilo Duolingo, sin shame al romperse.
 * Loss aversion suave (Tversky-Kahneman 1979): el usuario no quiere
 * romper su racha. Pero usamos `freezesTotal` (2/mes) para vacaciones
 * o ausencias justificadas — autonomía SDT preservada.
 */
model StaffStreak {
  id             String    @id @default(uuid())
  staffId        String    @unique @map("staff_id")
  /**
   * Días consecutivos con al menos 1 tarea completada (o freeze activo).
   */
  currentDays    Int       @default(0) @map("current_days")
  /**
   * Récord histórico — para celebrar al superarlo (Strava-style).
   */
  longestDays    Int       @default(0) @map("longest_days")
  /**
   * Última fecha (DATE local) en que el staff trabajó tareas.
   */
  lastWorkDate   DateTime? @map("last_work_date") @db.Date
  /**
   * Freezes usados este mes — ausencias que no rompen la racha.
   */
  freezesUsed    Int       @default(0) @map("freezes_used")
  /**
   * Budget mensual de freezes. Default 2 — generoso pero acotado.
   */
  freezesTotal   Int       @default(2) @map("freezes_total")
  /**
   * Reset mensual del contador de freezes (1° del mes).
   */
  freezesResetAt DateTime? @map("freezes_reset_at") @db.Date
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@map("staff_streaks")
}

/**
 * StaffPersonalRecord — récord personal por categoría de habitación.
 * Strava PR pattern. Self-vs-self. No es ranking ni comparación peer.
 * Una row por staff por categoría — siempre el mejor tiempo histórico.
 * `roomCategory` usa los valores de `RoomCategory` (PRIVATE | SHARED) o
 * un id de RoomType cuando exista (Sprint 9+).
 */
model StaffPersonalRecord {
  id           String   @id @default(uuid())
  staffId      String   @map("staff_id")
  /**
   * Bucketing key.
   */
  roomCategory String   @map("room_category")
  /**
   * Best cleaning duration in minutes.
   */
  bestMinutes  Int      @map("best_minutes")
  /**
   * When the PR was set.
   */
  achievedAt   DateTime @map("achieved_at")
  /**
   * Reference to the task that set the record (audit trail).
   */
  taskId       String   @map("task_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, roomCategory])
  @@map("staff_personal_records")
}

/**
 * StaffDailyActivity — granular día-a-día por staff para Activity Rings.
 * Apple Fitness pattern: 3 rings = (tareas, tiempo eficiente,
 * verificaciones positivas). Una row por staff por día. Permite
 * GitHub-style contribution graph en /me sin re-computar.
 */
model StaffDailyActivity {
  id                   String   @id @default(uuid())
  staffId              String   @map("staff_id")
  date                 DateTime @db.Date
  tasksCompleted       Int      @default(0) @map("tasks_completed")
  tasksVerified        Int      @default(0) @map("tasks_verified")
  totalCleaningMinutes Int      @default(0) @map("total_cleaning_minutes")
  /**
   * Whether the user closed all 3 rings this day (Day Completion Ritual).
   */
  ringsCompleted       Boolean  @default(false) @map("rings_completed")
  /**
   * Cached daily target for ring 1 (tasks). Derived at roster time.
   */
  tasksTarget          Int      @default(0) @map("tasks_target")
  /**
   * Cached daily target for ring 2 (efficient minutes).
   */
  minutesTarget        Int      @default(0) @map("minutes_target")
  /**
   * Cached daily target for ring 3 (verified count).
   */
  verifiedTarget       Int      @default(0) @map("verified_target")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId, date])
  @@map("staff_daily_activity")
}

/**
 * FeatureFlag — toggles persistentes server-side para testing y rollouts.
 * Por qué server-side y no localStorage:
 * - Multi-device coherence: un admin que activa "test.alarm" desde web
 * debe afectar al backend (cron) y a todos los clientes mobile/web
 * simultáneamente. localStorage solo afecta al navegador del actor.
 * - Audit fiscal-grade: registro de quién encendió qué cuándo (ver
 * FeatureFlagAuditLog). Esto es trazabilidad de operación, no de UI.
 * Naming convention:
 * - test.*    → entornos/flujos de prueba (test.alarm, test.no_show, ...)
 * - feature.* → feature flags futuros con rollout gradual
 * - debug.*   → logs/diagnostics que en prod están off por defecto
 * Kill-switch de seguridad:
 * - Las variables de entorno SIEMPRE ganan sobre el DB flag.
 * Si `TEST_ALARM_ENABLED=false` por env, el cron NO se activa
 * aunque el flag esté ON en BD. Esto permite a ops apagar
 * un flag inmediatamente sin acceso a la base.
 * Scope:
 * - propertyId nullable: flag global a toda la organización si null,
 * o restringido a una propiedad si está seteado.
 * Solo SUPERVISOR puede crear/editar (Roles guard en el controller).
 * Referencia: Martin Fowler — *Feature Toggles* (2017),
 * https://martinfowler.com/articles/feature-toggles.html
 */
model FeatureFlag {
  id          String   @id @default(uuid())
  /**
   * Identificador único del flag (e.g. "test.alarm", "feature.x").
   */
  key         String   @unique
  enabled     Boolean  @default(false)
  /**
   * Restringir el flag a una propiedad específica. null = global.
   */
  propertyId  String?  @map("property_id")
  /**
   * Configuración libre por flag (e.g. { intervalMin: 5, staffEmail: "m@z.co" }).
   */
  config      Json?
  /**
   * Texto humano para que admin recuerde qué hace este flag.
   */
  description String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  property  Property?             @relation(fields: [propertyId], references: [id])
  updatedBy Staff?                @relation(fields: [updatedById], references: [id])
  auditLogs FeatureFlagAuditLog[]

  @@index([key])
  @@index([propertyId])
  @@map("feature_flags")
}

/**
 * FeatureFlagAuditLog — append-only audit trail de cambios.
 * Append-only: nunca se borra ni edita. Cumple con §11 (registros
 * inmutables). Permite responder "¿quién dejó test.alarm encendido en
 * producción 3 horas?" en cualquier postmortem.
 */
model FeatureFlagAuditLog {
  id            String   @id @default(uuid())
  flagId        String   @map("flag_id")
  flagKey       String   @map("flag_key") // duplicado para queries sin join
  action        String // 'CREATED' | 'ENABLED' | 'DISABLED' | 'CONFIG_UPDATED'
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  actorId       String?  @map("actor_id")
  actorRole     String?  @map("actor_role")
  createdAt     DateTime @default(now()) @map("created_at")

  flag  FeatureFlag @relation(fields: [flagId], references: [id])
  actor Staff?      @relation(fields: [actorId], references: [id])

  @@index([flagKey, createdAt])
  @@index([actorId])
  @@map("feature_flag_audit_logs")
}

/**
 * DailyPropertyMetrics — snapshot diario inmutable de KPIs operativos.
 * Recomendación basada en investigación cross-referencia (Sprint 9):
 * Mews/Cloudbeds engineering blogs + STR + USALI 12th + reviews G2/Capterra.
 * El "Manager Report" (Occ + ADR + RevPAR) es el report #4 más usado en la
 * industria. Recomputarlo desde GuestStay + StaySegment + PaymentLog no
 * escala más allá de ~30 días. Snapshot append-only por propiedad por
 * fecha local.
 * Refresh trigger: `NightAuditScheduler` corre per-property en local TZ
 * (CLAUDE.md §14). Añadir paso `computeDailyMetrics(propertyId, localDate)`
 * tras procesar no-shows.
 * Tamaño: 1 row/property/day = ~365 rows/año/propiedad. 50 propiedades
 * × 5 años = 91k rows. Trivial para Postgres con índice (propertyId, date).
 * NO denormaliza datos derivables on-the-fly (ARRIVAL_LIST, IN_HOUSE) —
 * eso es projection sobre GuestStay con índices, no aggregation table.
 */
model DailyPropertyMetrics {
  id                String   @id @default(uuid())
  propertyId        String   @map("property_id")
  /**
   * Fecha local de la propiedad (timezone IANA aplicado). NO UTC.
   */
  date              DateTime @db.Date
  /**
   * Inventario base — habitaciones disponibles para vender ese día.
   */
  roomsAvailable    Int      @map("rooms_available")
  /**
   * Habitaciones vendidas (con stay activo cubriendo la noche).
   */
  roomsSold         Int      @map("rooms_sold")
  /**
   * Habitaciones bloqueadas (mantenimiento, OOS).
   */
  roomsOOO          Int      @map("rooms_ooo")
  /**
   * Revenue de habitaciones (sin F&B, sin extras).
   */
  roomRevenue       Decimal  @map("room_revenue") @db.Decimal(12, 2)
  /**
   * Revenue total (incluye otros departamentos cuando los haya).
   */
  totalRevenue      Decimal  @map("total_revenue") @db.Decimal(12, 2)
  /**
   * ADR = roomRevenue / roomsSold. Snapshot — no se recalcula.
   */
  adr               Decimal  @map("adr") @db.Decimal(10, 2)
  /**
   * Occupancy = roomsSold / roomsAvailable.
   */
  occupancy         Decimal  @db.Decimal(5, 4)
  /**
   * RevPAR = roomRevenue / roomsAvailable.
   */
  revpar            Decimal  @db.Decimal(10, 2)
  /**
   * Eventos del día — counters para reportes diarios.
   */
  arrivalCount      Int      @default(0) @map("arrival_count")
  departureCount    Int      @default(0) @map("departure_count")
  noShowCount       Int      @default(0) @map("no_show_count")
  cancellationCount Int      @default(0) @map("cancellation_count")
  walkInCount       Int      @default(0) @map("walk_in_count")
  /**
   * Currency snapshot (importante en LATAM con multi-property multi-divisa).
   */
  currency          String   @default("MXN")
  computedAt        DateTime @default(now()) @map("computed_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId, date])
  @@map("daily_property_metrics")
}

/**
 * ChannelProductionDaily — agregación diaria por canal de venta.
 * El "Channel Production Report" es report #9 en uso real (cross-research)
 * y crítico para evaluar comisiones OTA vs revenue directo. Recomputarlo
 * por fecha exige scan completo de GuestStay para rangos largos.
 * Granularidad: 1 row/property/date/source. 5 sources típicos
 * (Booking, Expedia, Direct, Airbnb, Walk-in) × 365 días × 50 propiedades
 * = 91k rows/año.
 * Top wanted report cross-research: "cancellation rate by channel +
 * lead-time-to-cancel" — los counters aquí agregados habilitan ese
 * análisis sin scan adicional.
 */
model ChannelProductionDaily {
  id            String   @id @default(uuid())
  propertyId    String   @map("property_id")
  date          DateTime @db.Date
  /**
   * Identificador de canal: 'BOOKING' | 'EXPEDIA' | 'DIRECT' | 'WALK_IN' | 'AIRBNB' | etc.
   */
  source        String
  /**
   * Reservas creadas en ese día/canal (no necesariamente con check-in ese día).
   */
  bookings      Int      @default(0)
  /**
   * Reservas canceladas con fecha de cancelación en ese día.
   */
  cancellations Int      @default(0)
  /**
   * No-shows: GuestStay con noShowAt cayendo en este día/canal.
   */
  noShows       Int      @default(0) @map("no_shows")
  /**
   * Revenue neto del canal en ese día (post-comisión cuando aplique).
   */
  netRevenue    Decimal  @default(0) @map("net_revenue") @db.Decimal(12, 2)
  /**
   * Comisión cobrada por el canal (0 para DIRECT/WALK_IN).
   */
  commission    Decimal  @default(0) @db.Decimal(12, 2)
  /**
   * Lead time promedio en días — habilita análisis de patrones de booking.
   */
  avgLeadDays   Int?     @map("avg_lead_days")
  currency      String   @default("MXN")
  computedAt    DateTime @default(now()) @map("computed_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date, source])
  @@index([propertyId, date])
  @@index([source, date])
  @@map("channel_production_daily")
}

// ============================================================================
// SPRINT Mx-1 — MÓDULO DE MANTENIMIENTO (v1.0.0)
// ============================================================================
//
// Sistema completo de tickets de mantenimiento con control, administración y
// seguimiento en tiempo real. Reemplaza al modelo legacy `MaintenanceIssue`
// (lightweight, vinculado a CleaningTask) que se preserva por compatibilidad
// pero NO debe usarse para nuevas integraciones.
//
// Flujo operativo del ticket:
//
//   [Housekeeper detecta problema durante limpieza]
//                  ↓
//   POST /v1/maintenance/tickets { roomId, category, priority, title, photos[] }
//                  ↓
//   MaintenanceTicket(status: OPEN, sourceTaskId: <CleaningTask>)
//                  ↓
//   ─── ¿priority === CRITICAL? ────────────────┐
//   │ NO                                       │ SÍ
//   ↓                                          ↓
//   AppNotification(MAINTENANCE_TICKET_CREATED) │
//   → técnico mantenimiento                     │
//                                               ↓
//                                        SmartBlockService.createBlock(
//                                          OUT_OF_ORDER, MAINTENANCE,
//                                          maintenanceTicketId: ticket.id
//                                        )
//                                        → room.status = BLOCKED
//                                        → desaparece del calendario PMS
//                                        → SSE: block:activated
//                                        → AppNotification(
//                                            MAINTENANCE_TICKET_CRITICAL,
//                                            ACTION_REQUIRED) → manager
//                                        → TicketLog(BLOCK_AUTO_CREATED)
//
//   [Técnico acknowledge → IN_PROGRESS → RESOLVED]
//                  ↓
//   [Supervisor verifica calidad → VERIFIED]
//                  ↓
//   ─── ¿hubo bloque automático? ───────────────┐
//                                                ↓
//                                        SmartBlockService.releaseBlock()
//                                        → room.status restored
//                                        → TicketLog(BLOCK_AUTO_RELEASED)
//                  ↓
//   [CLOSED — readonly, archivo histórico]
//
// Caso de uso real (Hotel Monica Tulum, 2026-04-09):
//   Mantenimiento inició encerado de Bongaloo B2 sin bloquear la habitación.
//   La habitación se vendió en Booking.com → pérdida + reubicación de huésped.
//   Con este módulo: encerado se levanta como TicketCategory.DEEP_CLEANING +
//   priority=CRITICAL → auto-bloqueo → Channex.io recibe pushInventory →
//   Booking.com cierra disponibilidad → no hay reserva conflictiva.
//
// Multi-tenancy: organizationId presente y obligatorio. Toda query debe
// filtrar por organizationId via TenantContextService.
//
// Integraciones:
//   - NotificationCenterService (notif.send) en cada cambio de estado.
//   - SmartBlockService (createBlock/releaseBlock) en CRITICAL/VERIFIED.
//   - PushService (Expo) al técnico asignado.
//   - SSE: maintenance:ticket:created | :updated | :resolved | :verified.
//   - Channex.io: el bloque automático dispara pushInventory (Sprint 9).
// ============================================================================

model MaintenanceTicket {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  propertyId     String  @map("property_id")
  roomId         String? @map("room_id") // OPCIONAL — null = ticket no-de-habitación (lobby, alberca, vehículos, equipo)
  unitId         String? @map("unit_id") // opcional — solo cuando aplica a unidad específica
  assetTag       String? @map("asset_tag") // identificador libre para tickets no-de-habitación: "Lavadora-2", "Generador", "Camioneta-blanca"

  category TicketCategory
  priority TicketPriority @default(MEDIUM)
  status   TicketStatus   @default(OPEN)

  title       String // resumen corto: "Grifo gotea en baño"
  description String? @db.Text // detalle libre
  guestImpact String? @map("guest_impact") // "huésped reportó al recepcionista" — contexto

  // ── Actores del ciclo de vida ────────────────────────────────────────────
  reportedById String  @map("reported_by_id") // housekeeper / recepcionista que detectó
  assignedToId String? @map("assigned_to_id") // técnico (Staff con department=MAINTENANCE)
  resolvedById String? @map("resolved_by_id") // quien marcó RESOLVED
  verifiedById String? @map("verified_by_id") // supervisor que confirmó VERIFIED

  // ── Workflow de aprobación (Flujo B — bottom-up) ─────────────────────────
  // requiresApproval=true → ticket creado por housekeeper/técnico requiere aprobación
  // del supervisor antes de pasar a ACKNOWLEDGED. El supervisor lo revisa y
  // aprueba (asigna técnico) o rechaza (cierra con razón).
  // Mientras requiresApproval=true && approvedById=null && status=OPEN → "pendiente"
  requiresApproval Boolean   @default(false) @map("requires_approval")
  approvedById     String?   @map("approved_by_id") // supervisor que aprobó
  approvedAt       DateTime? @map("approved_at")
  rejectedReason   String?   @map("rejected_reason") // razón si fue cerrado por rechazo

  // ── Mantenimiento preventivo recurrente (Sprint Mx-2 implementa el cron) ─
  // Si != null, este ticket fue creado por el scheduler de mantenimiento
  // preventivo a partir de un template. Sprint Mx-1 deja el campo + endpoint
  // READ-ONLY de templates; el scheduler queda para Mx-2.
  recurrenceTemplateId String? @map("recurrence_template_id")

  // ── SLA tracking (idempotencia del scheduler) ────────────────────────────
  // Cuando MaintenanceSlaScheduler detecta breach, registra timestamp aquí.
  // Evita re-notificar al supervisor cada 5 minutos.
  slaBreachAt DateTime? @map("sla_breach_at")

  // ── Fecha estimada de fin (Sprint Mx-1B-W1.1) ────────────────────────────
  // Pattern recomendado por Clock PMS+ / Flexkeeping (research 2026-05-10):
  // captura `estimatedEndAt` al crear → se propaga a RoomBlock.endDate cuando
  // hay habitación bloqueada. Channex cierra disponibilidad SOLO ese período,
  // no infinito → ventas futuras protegidas. UI muestra aging color: verde
  // >2d restantes, amber 1d/hoy, rojo vencido. Si vence sin cierre: notif al
  // supervisor (Mx-1B-W2 — extender o cerrar). Si cierra antes: libera bloque
  // temprano (mejor para el negocio). Defaults por categoría en el cliente.
  estimatedEndAt DateTime? @map("estimated_end_at")

  // ── Estimación y tiempo real ─────────────────────────────────────────────
  estimatedMinutes Int? @map("estimated_minutes") // estimación al crear/asignar
  actualMinutes    Int? @map("actual_minutes") // calculado al RESOLVED desde logs

  // ── Costos / refacciones (Sprint Mx-2: integración con inventario) ──────
  // estimatedCost   Decimal?    @db.Decimal(10, 2)
  // actualCost      Decimal?    @db.Decimal(10, 2)
  // partsRequired   Json?                                    // [{ name, qty, supplier?, eta? }]

  // ── Timestamps del ciclo de vida (cada cambio de status escribe aquí) ──
  acknowledgedAt DateTime? @map("acknowledged_at")
  startedAt      DateTime? @map("started_at")
  waitingPartsAt DateTime? @map("waiting_parts_at")
  resolvedAt     DateTime? @map("resolved_at")
  verifiedAt     DateTime? @map("verified_at")
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // ── Vínculo con tarea de limpieza origen (cuando housekeeper lo detectó) ─
  sourceTaskId String? @map("source_task_id")

  // ── Relations ────────────────────────────────────────────────────────────
  organization Organization  @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])
  room         Room?         @relation("TicketRoom", fields: [roomId], references: [id])
  unit         Unit?         @relation("TicketUnit", fields: [unitId], references: [id])
  reportedBy   Staff         @relation("TicketsReported", fields: [reportedById], references: [id])
  assignedTo   Staff?        @relation("TicketsAssigned", fields: [assignedToId], references: [id])
  resolvedBy   Staff?        @relation("TicketsResolved", fields: [resolvedById], references: [id])
  verifiedBy   Staff?        @relation("TicketsVerified", fields: [verifiedById], references: [id])
  approvedBy   Staff?        @relation("TicketsApproved", fields: [approvedById], references: [id])
  sourceTask   CleaningTask? @relation("TicketSourceTask", fields: [sourceTaskId], references: [id])

  recurrenceTemplate MaintenanceRecurrenceTemplate? @relation("TemplateTickets", fields: [recurrenceTemplateId], references: [id])

  // Reverse relations — hijos del ticket
  photos         MaintenanceTicketPhoto[]
  comments       MaintenanceTicketComment[]
  logs           MaintenanceTicketLog[]
  // Reverse: bloque automático creado por este ticket cuando priority=CRITICAL.
  // FK vive en RoomBlock.maintenanceTicketId para evitar dependencia circular.
  // 1 ticket → 0..1 bloque (garantizado por @unique en RoomBlock).
  autoBlock      RoomBlock?                 @relation("BlockMaintenanceTicket")
  // Reverse: items del checklist de readiness que originaron este ticket
  readinessItems RoomReadinessTaskItem[]    @relation("ItemMaintenanceTicket")

  @@index([organizationId, propertyId, status])
  @@index([organizationId, propertyId, priority, status])
  @@index([organizationId, propertyId, requiresApproval, status])
  @@index([assignedToId, status])
  @@index([roomId, status])
  @@index([assetTag])
  @@index([category, status])
  @@index([createdAt])
  @@map("maintenance_tickets")
}

// ─── MaintenanceRecurrenceTemplate ──────────────────────────────────────────
// Pool de templates de mantenimiento preventivo recurrente. Se carga via seed
// con el catálogo estándar de la industria hotelera (24 templates basados en
// AHLEI Hospitality Facilities Management 4ª ed., ASHRAE Guideline 4-2019,
// NFPA 25/72, USALI 12ª ed.).
//
// Sprint Mx-1 entrega:
//   ✅ Modelo + seed de 24 templates
//   ✅ Endpoint GET /v1/maintenance/recurrence-templates (read-only)
//
// Sprint Mx-2 entrega:
//   - MaintenancePreventiveScheduler (cron diario per-property timezone-aware)
//   - UI de gestión de templates (admin puede activar/desactivar/personalizar)
//   - Auto-generación de tickets con priority configurable
// ──────────────────────────────────────────────────────────────────────────
model MaintenanceRecurrenceTemplate {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  name        String // "Limpieza de filtros A/C"
  description String? @db.Text

  category        TicketCategory
  defaultPriority TicketPriority @default(LOW) @map("default_priority")
  intervalDays    Int            @map("interval_days") // 7, 30, 90, 180, 365

  scope           RecurrenceScope @default(PER_ROOM)
  defaultAssetTag String?         @map("default_asset_tag") // p.ej. "Generador" para PER_ASSET

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id])
  tickets      MaintenanceTicket[] @relation("TemplateTickets")

  @@index([organizationId, isActive])
  @@map("maintenance_recurrence_templates")
}

// ── Fotos antes/después de la reparación ─────────────────────────────────
// Se almacenan como URLs (S3 / Cloudinary). El upload pasa por endpoint
// dedicado /v1/uploads que retorna la URL pública firmada.
model MaintenanceTicketPhoto {
  id           String   @id @default(uuid())
  ticketId     String   @map("ticket_id")
  url          String // URL pública del archivo
  caption      String? // "antes" | "después" | descripción libre
  isAfterPhoto Boolean  @default(false) @map("is_after_photo") // true = foto post-reparación
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // ── Soft-delete (Sprint Mx-1B-W2 — W2-04 fix con patrón Instagram).
  // Permite a SUPERVISOR o uploader original "borrar" sin perder audit. El
  // archivo físico permanece 30 días para recuperación; cron Mx-1C hace hard
  // delete después. GDPR/LGPD: SUPERVISOR puede forzar hard-delete inmediato.
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  ticket     MaintenanceTicket @relation(fields: [ticketId], references: [id])
  uploadedBy Staff             @relation("TicketPhotoUploader", fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@index([ticketId, deletedAt]) // optimiza el conteo "fotos vivas" del límite 3
  @@map("maintenance_ticket_photos")
}

// ── Comentarios del ticket (chat interno técnico ↔ supervisor) ──────────
model MaintenanceTicketComment {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id])
  author Staff             @relation("TicketCommentAuthor", fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
  @@map("maintenance_ticket_comments")
}

// ── Audit trail inmutable del ciclo de vida del ticket ──────────────────
// Append-only. Cada cambio de status, asignación, foto o comentario genera
// una entrada. Fuente de verdad para reportes de tiempo de respuesta y
// disputas operativas.
model MaintenanceTicketLog {
  id        String         @id @default(uuid())
  ticketId  String         @map("ticket_id")
  event     TicketLogEvent
  staffId   String?        @map("staff_id") // null = evento del sistema (auto-block)
  // metadata: snapshot del cambio. Ejemplos:
  //   ASSIGNED            { fromStaffId, toStaffId }
  //   STARTED             { estimatedMinutes }
  //   WAITING_PARTS       { reason, expectedEta }
  //   RESOLVED            { resolutionSummary, actualMinutes }
  //   BLOCK_AUTO_CREATED  { roomBlockId, semantic, reason }
  //   BLOCK_AUTO_RELEASED { roomBlockId }
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id])
  staff  Staff?            @relation("TicketLogActor", fields: [staffId], references: [id])

  @@index([ticketId, createdAt])
  @@index([event])
  @@map("maintenance_ticket_logs")
}

// ═════════════════════════════════════════════════════════════════════════
// ── Sprint Rates 3-LEVEL 2026-05-16 — FX (Foreign Exchange) ────────────
// ═════════════════════════════════════════════════════════════════════════

// ExchangeRate — snapshot diario del FX oficial.
// Fuente primaria MX: Banxico SF43718 (FIX) — gratuito, 40k req/día.
// Fallback: Open Exchange Rates si Banxico no responde en 30s.
// CFDI 4.0 Art. 20 CFF: usa FIX del día de la operación.
// Patrón inmutable: una vez fetched, nunca se reescribe (alineado §28).
model ExchangeRate {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  baseCurrency   String   @map("base_currency") // 'USD'
  quoteCurrency  String   @map("quote_currency") // 'MXN'
  rate           Decimal  @db.Decimal(12, 6)
  source         String // 'BANXICO_SF43718' | 'OPEN_EXCHANGE' | 'MANUAL'
  effectiveDate  DateTime @map("effective_date") @db.Date
  fetchedAt      DateTime @default(now()) @map("fetched_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, baseCurrency, quoteCurrency, effectiveDate, source])
  @@index([effectiveDate])
  @@map("exchange_rates")
}

// PropertyFxRate — override comercial del hotel.
// El hotel cobra un rate distinto al oficial Banxico (spread comercial).
// Se persiste como spread relativo O como rate absoluto editable.
// Visible en dashboard al recepcionista junto al rate oficial Banxico.
model PropertyFxRate {
  id                 String    @id @default(uuid())
  propertyId         String    @map("property_id")
  baseCurrency       String    @map("base_currency") // 'USD'
  quoteCurrency      String    @map("quote_currency") // 'MXN'
  rate               Decimal   @db.Decimal(12, 6)
  // Spread relativo: rate = official * (1 + spreadFromOfficial)
  // null = override absoluto sin tracking del spread.
  spreadFromOfficial Decimal?  @map("spread_from_official") @db.Decimal(5, 4)
  validFrom          DateTime  @map("valid_from") @db.Date
  validTo            DateTime? @map("valid_to") @db.Date
  updatedById        String    @map("updated_by_id")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, baseCurrency, quoteCurrency, validFrom])
  @@map("property_fx_rates")
}

// ═════════════════════════════════════════════════════════════════════════════
// NOVA FOUNDATION — Sprint NOVA-CHANNEX-COMMAND-CENTER (Day 1, 2026-05-23)
// ═════════════════════════════════════════════════════════════════════════════
//
// Hierarchy 5-tier: PLATFORM_ADMIN > PARTNER_ADMIN > PARTNER_MEMBER > ORG_OWNER > ORG_STAFF
// Ver docs/architecture/NOVA-architecture.md (2016 líneas ADR fundacional).
// Decisiones §159-§175 CLAUDE.md.
//
// Schema implementa modelo SAP PartnerEdge + SuccessFactors aplicado a hospitality:
//   · Partner = firma consultora (incluye ZaharDev como isInternal=true)
//   · PartnerMember = consultor individual con rol granular (8 valores enum)
//   · PartnerClientAssignment = firm ↔ cliente (N:M)
//   · PartnerMemberAssignment = member ↔ engagement (dentro del firm, N:M)
//   · AuditLog = trail universal append-only (DB trigger + reason REQUIRED on_behalf_of)

model Partner {
  id                String      @id @default(uuid())
  name              String // "ZaharDev" | "Consultoría Caribe SA de CV"
  tier              PartnerTier @default(AUTHORIZED)
  countryCode       String      @map("country_code") // primary país de operación
  contactEmail      String      @map("contact_email")
  contactPhone      String?     @map("contact_phone")
  licenseValidUntil DateTime    @map("license_valid_until")
  parentPartnerId   String?     @map("parent_partner_id") // sub-partner relationships (PLATINUM only)
  // Flag reservado para ZaharDev — solo este Partner puede tener members con
  // role PLATFORM_ADMIN. Constraint app-level + Postgres CHECK en migration.
  isInternal        Boolean     @default(false) @map("is_internal")

  parentPartner     Partner?                  @relation("SubPartners", fields: [parentPartnerId], references: [id])
  subPartners       Partner[]                 @relation("SubPartners")
  members           PartnerMember[]
  clientAssignments PartnerClientAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tier])
  @@index([isInternal])
  @@index([parentPartnerId])
  @@map("partners")
}

model PartnerMember {
  id                 String              @id @default(uuid())
  partnerId          String              @map("partner_id")
  userId             String              @unique @map("user_id") // FK 1:1 a User
  role               PartnerMemberRole
  // Audit H3 fix 2026-05-24: text → enum (controlled vocabulary)
  status             PartnerMemberStatus @default(ACTIVE)
  joinedAt           DateTime            @default(now()) @map("joined_at")
  certifiedAt        DateTime?           @map("certified_at") // fecha cert Zenix Academy
  // Audit L1+H3 fix: text → enum
  certificationLevel CertificationLevel? @map("certification_level")

  partner           Partner                   @relation(fields: [partnerId], references: [id])
  user              User                      @relation(fields: [userId], references: [id])
  clientMemberships PartnerMemberAssignment[]

  @@index([partnerId, role])
  @@index([status])
  @@map("partner_members")
}

model PartnerClientAssignment {
  // firm partner ↔ cliente hotel (N:M)
  id             String          @id @default(uuid())
  partnerId      String          @map("partner_id")
  organizationId String          @map("organization_id")
  // Audit H3 fix 2026-05-24: text → enum
  scope          AssignmentScope @default(FULL)
  // Audit H1 fix: FK a users(id) ON DELETE RESTRICT
  assignedById   String          @map("assigned_by_id")
  assignedAt     DateTime        @default(now()) @map("assigned_at")
  revokedAt      DateTime?       @map("revoked_at")
  revokedById    String?         @map("revoked_by_id")

  partner           Partner                   @relation(fields: [partnerId], references: [id])
  organization      Organization              @relation(fields: [organizationId], references: [id])
  // Audit H1 fix — FK assignedBy/revokedBy → users(id) ON DELETE RESTRICT
  assignedBy        User                      @relation("PartnerAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  revokedBy         User?                     @relation("PartnerAssignmentRevokedBy", fields: [revokedById], references: [id], onDelete: Restrict)
  memberAssignments PartnerMemberAssignment[]

  @@unique([partnerId, organizationId])
  @@index([organizationId])
  @@index([assignedAt])
  @@map("partner_client_assignments")
}

model PartnerMemberAssignment {
  // dentro del partner, qué miembros están en qué cliente engagement (N:M)
  id                        String         @id @default(uuid())
  partnerClientAssignmentId String         @map("partner_client_assignment_id")
  partnerMemberId           String         @map("partner_member_id")
  // Audit H3 fix 2026-05-24: text → enum
  engagementRole            EngagementRole @map("engagement_role")
  assignedAt                DateTime       @default(now()) @map("assigned_at")
  removedAt                 DateTime?      @map("removed_at")

  partnerClientAssignment PartnerClientAssignment @relation(fields: [partnerClientAssignmentId], references: [id])
  member                  PartnerMember           @relation(fields: [partnerMemberId], references: [id])

  @@unique([partnerClientAssignmentId, partnerMemberId])
  @@index([partnerMemberId])
  @@map("partner_member_assignments")
}

// ═════════════════════════════════════════════════════════════════════════════
// AuditLog universal — append-only, fiscal/compliance grade (§165 D-NOVA-7)
// ═════════════════════════════════════════════════════════════════════════════
// Trigger Postgres bloquea UPDATE/DELETE (ver migration SQL).
// `reason` REQUIRED a nivel CHECK constraint cuando `on_behalf_of_id IS NOT NULL`.
// Retention §167: hot table 365d → cold storage partition v1.0.3 REPORTS-CORE.
// Compliance: Visa CRR §5.9.2 (chargeback 120d) + CFDI Art. 30 CFF (5 años) +
// GDPR Art. 17.3.b (legal obligation exception).

model AuditLog {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  // Actor real — siempre el verdadero ejecutor (consultor, ZaharDev, cliente user).
  // Audit H1 fix 2026-05-24: FK a users(id) ON DELETE RESTRICT — referential integrity.
  actorRealId     String            @map("actor_real_id")
  actorRealRole   SystemRole        @map("actor_real_role")
  // Impersonation pattern SAP-style: si actor opera "en nombre de" otro usuario,
  // estos campos lo registran. `reason` es REQUIRED via CHECK constraint
  // cuando onBehalfOfId IS NOT NULL.
  onBehalfOfId    String?           @map("on_behalf_of_id")
  onBehalfOfRole  SystemRole?       @map("on_behalf_of_role")
  // Acción ejecutada — naming convention 'ENTITY_VERB' uppercase.
  // Ej: 'CHANNEX_ROOM_TYPE_CREATE' | 'WIZARD_STEP_4_COMPLETED' | 'CHANNEL_PAUSE'
  action          String
  // Target entity (channex room_type_id, rate_plan_id, wizard step number, etc.)
  target          String?
  // Request payload completo (post-sanitization de PII si aplica)
  payload         Json
  // Response de Channex API (si la acción involucró Channex)
  channexResponse Json?             @map("channex_response")
  // Audit H3 fix 2026-05-24: text → enum (controlled vocabulary)
  status          AuditLogStatus
  // REQUIRED si onBehalfOfId != null (CHECK constraint en migration)
  reason          String?
  errorMessage    String?           @map("error_message")
  // Audit H3 fix: text → enum. Drives v1.0.3 REPORTS-CORE cold storage scheduler.
  retentionPolicy AuditLogRetention @default(STANDARD) @map("retention_policy")
  createdAt       DateTime          @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  // Audit H1 fix 2026-05-24: FK ON DELETE RESTRICT — referential integrity
  // Compliance Visa CRR §5.9.2 + CFDI Art. 30 CFF + GDPR Art. 17.3.b
  actorReal    User         @relation("AuditLogActor", fields: [actorRealId], references: [id], onDelete: Restrict)
  onBehalfOf   User?        @relation("AuditLogOnBehalfOf", fields: [onBehalfOfId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([actorRealId, createdAt])
  @@index([onBehalfOfId])
  @@index([action])
  @@index([retentionPolicy, createdAt])
  @@map("audit_log")
}

// ═════════════════════════════════════════════════════════════════════════════
// CHANNEX COMMAND CENTER — Day 2 schema additions
// ═════════════════════════════════════════════════════════════════════════════
//
// Standalone schema para mapear Channex rate plans + restricciones + history.
// Cuando llegue sprint RATES-METRICS-COMPSET-CORE con el modelo RatePlan
// completo, se agrega FK `RatePlan.channexMappingId → ChannexRatePlanMapping`
// sin tocar este schema. Pattern desacoplado intencionalmente para evitar
// blocking del Command Center por el sprint RATES.

model ChannexRatePlanMapping {
  // Cada fila representa un Rate Plan creado en Channex API (POST /rate_plans).
  // Zenix DB es write-through cache: el consultor crea via Command Center →
  // Channex API request → on success → upsert aquí. Sirve de:
  //   1. Fuente cliente-side para queries fast (sin hit Channex API cada vez)
  //   2. Hook para futuro RatePlan model (RATES sprint agrega FK)
  //   3. Source para Rate Calendar Matrix aggregator (Day 6)
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  propertyId        String   @map("property_id")
  // UUID del rate plan en Channex (e.g. "4aea6806-f0fe-4517-9642-b67600cc01ff")
  channexRatePlanId String   @unique @map("channex_rate_plan_id")
  // FK lógico al room type Channex que este rate plan cubre (1 rate plan ↔ 1 room type)
  channexRoomTypeId String   @map("channex_room_type_id")
  title             String // "BAR — Estándar"
  // Audit H2 fix 2026-05-24: text → CHAR(3) ISO 4217. CHECK regex en migration.
  currency          String   @db.Char(3)
  // sell_mode: 'per_room' (rate fijo por habitación) | 'per_person' (rate × occupancy)
  sellMode          String   @map("sell_mode")
  // rate_mode: 'manual' (operador setea cada rate) | 'derived' (calculado de otro plan)
  rateMode          String   @default("manual") @map("rate_mode")
  // Rate base default cuando se crea — útil para "reset to default" + auto-detect
  // de "rate plan recién creado" en el calendar (no requiere consulta a Channex)
  defaultRate       Decimal  @map("default_rate") @db.Decimal(10, 2)
  defaultOccupancy  Int      @default(2) @map("default_occupancy")
  // Flag para desactivar rate plan sin borrarlo de Channex (preserva history).
  // En Channex no existe "deactivate" — emulamos con stop_sell=true en
  // restrictions. Este flag refleja el estado intencional del operador.
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  // Audit fields — quién creó/actualizó (PARTNER_MEMBER o PLATFORM_ADMIN)
  // Audit H1 fix 2026-05-24: FK ON DELETE RESTRICT
  createdById       String   @map("created_by_id")
  updatedById       String?  @map("updated_by_id")

  property  Property     @relation(fields: [propertyId], references: [id])
  createdBy User         @relation("RatePlanMappingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?        @relation("RatePlanMappingUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  rateCap   RatePlanCap?

  @@index([propertyId, isActive])
  @@index([channexRoomTypeId])
  @@map("channex_rate_plan_mappings")
}

// ─── RatePlanCap — Salesforce Permission Set pattern (§"D-CHX-CC-9") ────────
// Consultor (PLATFORM_ADMIN o PARTNER_ADMIN/MEMBER tier A) define floor + ceiling
// del rate. Supervisor (ORG_OWNER / MANAGER) puede editar rates dentro de caps;
// intento fuera → 400 con mensaje claro. Pattern Salesforce Permission Set
// donde admin define grants y user opera dentro de ellos.

model RatePlanCap {
  id               String   @id @default(uuid())
  channexMappingId String   @unique @map("channex_mapping_id")
  rateCapMin       Decimal? @map("rate_cap_min") @db.Decimal(10, 2)
  rateCapMax       Decimal? @map("rate_cap_max") @db.Decimal(10, 2)
  // Razón opcional explicando los caps. Visible al operador supervisor
  // cuando intenta editar fuera de rango (sirve de educación contextual).
  reason           String?
  // Audit H1 fix 2026-05-24: FK ON DELETE RESTRICT
  setById          String   @map("set_by_id")
  setAt            DateTime @default(now()) @map("set_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  mapping ChannexRatePlanMapping @relation(fields: [channexMappingId], references: [id], onDelete: Cascade)
  setBy   User                   @relation("RatePlanCapSetBy", fields: [setById], references: [id], onDelete: Restrict)

  @@index([setById])
  @@map("rate_plan_caps")
}

// ─── ChannexChannelPause — history log de pause/unpause (§"D-CHX-CC-7") ─────
// Channex API no expone "pause channel" nativo — emulamos via stop_sell=true en
// restrictions per rate plan. Esta tabla registra cada pause/unpause action
// para audit + restore al unpause (guardar previous state).
// Pattern Cloudbeds "Snooze channel".

model ChannexChannelPause {
  id               String    @id @default(uuid())
  propertyId       String    @map("property_id")
  channexChannelId String    @map("channex_channel_id")
  channelName      String    @map("channel_name") // 'booking_com', 'expedia', etc.
  pausedAt         DateTime  @default(now()) @map("paused_at")
  pausedById       String    @map("paused_by_id") // actor
  pauseReason      String?   @map("pause_reason")
  // JSON snapshot del estado pre-pause (stop_sell per rate_plan, restrictions)
  // — usado para restore exacto al unpause. Sin esto, unpause podría dejar
  // ratesplans con stop_sell=true que el operador NO había seteado antes.
  preState         Json?     @map("pre_state")
  unpausedAt       DateTime? @map("unpaused_at")
  unpausedById     String?   @map("unpaused_by_id")
  unpauseReason    String?   @map("unpause_reason")

  property   Property @relation(fields: [propertyId], references: [id])
  // Audit H1 fix 2026-05-24
  pausedBy   User     @relation("ChannelPausePausedBy", fields: [pausedById], references: [id], onDelete: Restrict)
  unpausedBy User?    @relation("ChannelPauseUnpausedBy", fields: [unpausedById], references: [id], onDelete: Restrict)

  @@index([propertyId, pausedAt])
  @@index([channexChannelId])
  @@map("channex_channel_pauses")
}

// ═══════════════════════════════════════════════════════════════════════════
// BILLING-CORE (Sprint v1.1.0)
// ═══════════════════════════════════════════════════════════════════════════
//
// Stripe subscription billing wiring + discount codes negociables + retention
// save offers + dunning + T&C versioned + pricing admin UI.
//
// Plan completo en docs/sprints/BILLING-CORE-plan.md (~600 líneas día-por-día).
// Strategy en docs/vision/15-subscription-billing.md (~840 líneas).
//
// Decisiones D-BILL-1..10 en docs/sprints/BILLING-CORE-plan.md §1.
// ═══════════════════════════════════════════════════════════════════════════

// Suscripción Zenix — 1:1 con Organization (mirror Stripe state local)
model Subscription {
  id                   String @id @default(uuid())
  organizationId       String @unique @map("organization_id")
  stripeCustomerId     String @map("stripe_customer_id")
  stripeSubscriptionId String @unique @map("stripe_subscription_id")

  // Plan + status sync con Stripe
  planTier          String @map("plan_tier") // 'STARTER' | 'PRO' | 'ENTERPRISE'
  // 'pending_payment_method' (Netflix flow pre-card) | 'incomplete' | 'active' | 'past_due' | 'paused' | 'cancelled' | 'unpaid' | 'trialing'
  status            String
  billingCycle      String @default("monthly") @map("billing_cycle") // 'monthly' | 'annual'
  annualDiscountPct Int?   @map("annual_discount_pct") // 20 si annual

  // Período actual
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")

  // Pause
  pausedAt    DateTime? @map("paused_at")
  pausedUntil DateTime? @map("paused_until")

  // Trial
  trialStartedAt    DateTime? @map("trial_started_at")
  trialEndsAt       DateTime? @map("trial_ends_at")
  trialNegotiatedBy String?   @map("trial_negotiated_by") // consultor User id

  // Pricing snapshot — congelado al activar (grandfathered)
  baseMonthlyAmount Decimal @map("base_monthly_amount")
  currency          String  @default("MXN")
  propertyCount     Int     @map("property_count")

  // Renewal
  nextRenewalDate DateTime @map("next_renewal_date")
  autoRenew       Boolean  @default(true) @map("auto_renew")

  // Netflix-style trial flow — config pendiente hasta que webhook setup_intent.succeeded
  // active la subscription real. Mientras status='pending_payment_method', estos
  // campos guardan los args para SubscriptionService.activateAfterSetupIntent().
  pendingCouponId  String?   @map("pending_coupon_id") // Stripe Coupon a attachar al crear Sub
  pendingTrialDays Int?      @map("pending_trial_days") // trial_period_days del wizard Step 7.5
  setupIntentId    String?   @map("setup_intent_id") // Stripe SetupIntent confirmado (audit)
  cardCapturedAt   DateTime? @map("card_captured_at") // timestamp activación post-card

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization           @relation(fields: [organizationId], references: [id])
  discounts    SubscriptionDiscount[]
  events       SubscriptionEvent[]
  invoices     Invoice[]
  saveOffers   RetentionSaveOffer[]

  @@index([status])
  @@index([nextRenewalDate])
  @@index([stripeCustomerId, status], map: "idx_subscriptions_customer_status")
  @@map("subscriptions")
}

// Descuentos aplicados — historial completo + activos. Audit trail per descuento.
model SubscriptionDiscount {
  id                    String  @id @default(uuid())
  subscriptionId        String  @map("subscription_id")
  stripeCouponId        String  @map("stripe_coupon_id")
  stripePromotionCodeId String? @map("stripe_promotion_code_id")
  promotionCode         String  @map("promotion_code") // "ZAHAR-TULUM-2026"

  percentOff       Int?     @map("percent_off") // 0-100
  amountOff        Decimal? @map("amount_off") // si fixed amount
  duration         String // 'once' | 'repeating' | 'forever'
  durationInMonths Int?     @map("duration_in_months")

  generatedById   String    @map("generated_by_id") // consultor User
  generatedByRole String    @map("generated_by_role")
  reason          String    @db.Text // libre — razón del descuento
  approvedById    String?   @map("approved_by_id") // si excedió cap del consultor
  approvedAt      DateTime? @map("approved_at")

  appliedAt DateTime  @default(now()) @map("applied_at")
  expiresAt DateTime? @map("expires_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([generatedById])
  @@map("subscription_discounts")
}

// Eventos lifecycle — append-only audit trail con dedup webhook
model SubscriptionEvent {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  type           String // 'CREATED' | 'PLAN_CHANGED' | 'PAUSED' | 'RESUMED' | 'CANCELLED' | 'PAYMENT_FAILED' | 'PAYMENT_SUCCEEDED' | 'DISCOUNT_APPLIED' | 'SAVE_OFFER_SHOWN' | 'SAVE_OFFER_ACCEPTED' | 'SAVE_OFFER_REJECTED' | 'REMINDER_SENT' | 'DUNNING_ESCALATION' | 'TERMS_ACCEPTED'
  payload        Json
  stripeEventId  String?  @unique @map("stripe_event_id") // dedup webhook
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, type])
  @@map("subscription_events")
}

// Invoices — espejo local de Stripe Invoices
model Invoice {
  id               String    @id @default(uuid())
  subscriptionId   String    @map("subscription_id")
  organizationId   String    @map("organization_id")
  stripeInvoiceId  String    @unique @map("stripe_invoice_id")
  number           String    @unique // "INV-2603"
  status           String // 'draft' | 'open' | 'paid' | 'uncollectible' | 'void'
  total            Decimal
  subtotal         Decimal
  discount         Decimal   @default(0)
  tax              Decimal   @default(0)
  currency         String
  periodStart      DateTime  @map("period_start")
  periodEnd        DateTime  @map("period_end")
  paidAt           DateTime? @map("paid_at")
  dueAt            DateTime  @map("due_at")
  hostedInvoiceUrl String?   @map("hosted_invoice_url")
  invoicePdfUrl    String?   @map("invoice_pdf_url")

  createdAt DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("invoices")
}

// Discount code templates — el consultor puede tener "mis códigos favoritos"
model ConsultorDiscountTemplate {
  id               String  @id @default(uuid())
  consultorId      String  @map("consultor_id") // User PartnerMember
  name             String // "Mi código de bienvenida"
  percentOff       Int
  duration         String // 'once' | 'repeating' | 'forever'
  durationInMonths Int?    @map("duration_in_months")
  isFavorite       Boolean @default(false) @map("is_favorite")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([consultorId])
  @@map("consultor_discount_templates")
}

// Save offer presentations + outcomes — tracking de retention ladder
model RetentionSaveOffer {
  id                 String    @id @default(uuid())
  subscriptionId     String    @map("subscription_id")
  cancellationReason String    @map("cancellation_reason") // del survey
  offerShown         Json      @map("offer_shown") // JSON describing the offer
  outcome            String // 'ACCEPTED' | 'REJECTED' | 'EXPIRED' | 'PENDING'
  acceptedAt         DateTime? @map("accepted_at")
  rejectedAt         DateTime? @map("rejected_at")
  // Si ACCEPTED, link al descuento o pausa aplicado
  appliedDiscountId  String?   @map("applied_discount_id")
  appliedPauseUntil  DateTime? @map("applied_pause_until")

  createdAt DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([cancellationReason])
  @@map("retention_save_offers")
}

// Pricing config — modificable por PLATFORM_ADMIN (ZaharDev) sin deploy
// Grandfather pricing: existing subscriptions tienen Price snapshot en Stripe
// que no cambia. Esta config solo afecta a nuevos clientes activados desde
// el wizard post-cambio.
model BillingPricingConfig {
  id               String  @id @default(uuid())
  tier             String  @unique // 'STARTER' | 'PRO' | 'ENTERPRISE'
  displayName      String  @map("display_name")
  monthlyAmountMxn Decimal @map("monthly_amount_mxn")
  monthlyAmountUsd Decimal @map("monthly_amount_usd")
  features         Json // array of feature flags + descripción
  isActive         Boolean @default(true) @map("is_active")
  stripeProductId  String? @map("stripe_product_id")
  stripePriceIdMxn String? @map("stripe_price_id_mxn")
  stripePriceIdUsd String? @map("stripe_price_id_usd")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") // PLATFORM_ADMIN

  @@map("billing_pricing_config")
}

// Cap per partner tier — máximo discount que un consultor puede otorgar
model BillingPartnerTierCap {
  tier              String   @id // 'AUTHORIZED' | 'SILVER' | 'GOLD' | 'PLATINUM'
  maxDiscountPct    Int      @map("max_discount_pct")
  maxDurationMonths Int?     @map("max_duration_months") // null = forever permitido
  requiresApproval  Boolean  @default(false) @map("requires_approval")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedById       String?  @map("updated_by_id") // PLATFORM_ADMIN

  @@map("billing_partner_tier_caps")
}

// T&C versionado — owner publica nuevas versions, clientes aceptan
model TermsAndConditionsVersion {
  id              String    @id @default(uuid())
  version         String    @unique // '0.9', '1.0', '1.1', '2.0'
  effectiveFrom   DateTime  @map("effective_from")
  contentMarkdown String    @map("content_markdown") @db.Text
  contentHtml     String?   @map("content_html") @db.Text
  pdfStorageUrl   String?   @map("pdf_storage_url")
  sha256Hash      String    @unique @map("sha256_hash") // determinista
  language        String    @default("es") // 'es' | 'en'
  isCurrent       Boolean   @default(false) @map("is_current")
  createdBy       String    @map("created_by") // PLATFORM_ADMIN
  legalReviewedBy String?   @map("legal_reviewed_by") // abogado externo
  legalReviewedAt DateTime? @map("legal_reviewed_at")
  changelog       String?   @db.Text // qué cambió vs versión previa

  createdAt DateTime @default(now()) @map("created_at")

  acceptances TermsAcceptance[]

  @@index([language, isCurrent])
  @@map("terms_and_conditions_versions")
}

// T&C acceptance — registro auditable de cada acceptance del Cliente
model TermsAcceptance {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  termsVersionId    String   @map("terms_version_id")
  acceptedByUserId  String   @map("accepted_by_user_id") // ORG_OWNER usualmente
  acceptedAt        DateTime @default(now()) @map("accepted_at")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent") @db.Text
  // Para audit: dónde aceptó
  acceptanceContext String   @map("acceptance_context") // 'WIZARD_ACTIVATION' | 'TC_UPDATE' | 'MANUAL_OWNER' | 'PILOT_DOCUSIGN'

  organization Organization              @relation(fields: [organizationId], references: [id])
  termsVersion TermsAndConditionsVersion @relation(fields: [termsVersionId], references: [id])

  @@unique([organizationId, termsVersionId])
  @@index([organizationId])
  @@index([termsVersionId])
  @@map("terms_acceptances")
}

// ─── BILLING-CORE Day 4 — DiscountApprovalRequest ─────────────────────
// Cuando un consultor solicita un descuento que excede su cap (§D-BILL-3),
// se crea una row pending hasta que PARTNER_ADMIN+ apruebe o rechace.
// Si aprobado → resulting_discount_id apunta al SubscriptionDiscount creado.
// Si rechazado → rejection_reason persisted, request termina ahí.
// Si nadie reviewea en expires_at → status='EXPIRED' (cron limpieza futura).

model DiscountApprovalRequest {
  id                  String    @id @default(uuid())
  requestedById       String    @map("requested_by_id")
  requestedByRole     String    @map("requested_by_role")
  organizationId      String    @map("organization_id")
  subscriptionId      String?   @map("subscription_id")
  percentOff          Int       @map("percent_off")
  duration            String
  durationInMonths    Int?      @map("duration_in_months")
  reason              String    @db.Text
  status              String    @default("PENDING")
  reviewedById        String?   @map("reviewed_by_id")
  reviewedAt          DateTime? @map("reviewed_at")
  rejectionReason     String?   @map("rejection_reason") @db.Text
  resultingDiscountId String?   @map("resulting_discount_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  expiresAt           DateTime  @map("expires_at")

  @@index([organizationId])
  @@index([status])
  @@index([requestedById])
  @@index([status, expiresAt])
  @@map("discount_approval_requests")
}

// ═══════════════════════════════════════════════════════════════════════════
// RATES-METRICS-COMPSET-CORE (2026-06-03) — Bloque RATES (Fase 1)
// Pricing flexible: RatePlan + Seasons + DayOfWeek + Restrictions + Promotions
// + Overrides. Resolución de precio con precedencia D-RATES2 (ver RatesService).
// ═══════════════════════════════════════════════════════════════════════════

model RatePlan {
  id                 String   @id @default(uuid())
  propertyId         String   @map("property_id")
  code               String
  name               String
  baseStrategy       String   @default("BAR") // BAR | FIXED | MULTIPLIER
  baseRate           Decimal? @db.Decimal(10, 2)
  baseMultiplier     Decimal? @db.Decimal(4, 3)
  cancellationPolicy String   @default("FLEXIBLE") @map("cancellation_policy")
  inclusions         Json?
  isActive           Boolean  @default(true) @map("is_active")
  visibleToChannels  String[] @default(["ALL"]) @map("visible_to_channels")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  property       Property          @relation(fields: [propertyId], references: [id])
  seasons        RateSeason[]
  dayOfWeekRules DayOfWeekRule[]
  restrictions   RateRestriction[]
  promotions     Promotion[]

  @@unique([propertyId, code])
  @@index([propertyId, isActive])
  @@map("rate_plans")
}

model RateSeason {
  id           String   @id @default(uuid())
  ratePlanId   String   @map("rate_plan_id")
  roomTypeId   String?  @map("room_type_id")
  name         String
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  overrideRate Decimal? @map("override_rate") @db.Decimal(10, 2)
  multiplier   Decimal? @db.Decimal(4, 3)
  createdAt    DateTime @default(now()) @map("created_at")

  ratePlan RatePlan  @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  roomType RoomType? @relation(fields: [roomTypeId], references: [id])

  @@index([ratePlanId, startDate, endDate])
  @@map("rate_seasons")
}

model DayOfWeekRule {
  id         String  @id @default(uuid())
  ratePlanId String  @map("rate_plan_id")
  dayOfWeek  Int     @map("day_of_week") // 0=Sun..6=Sat
  multiplier Decimal @db.Decimal(4, 3)

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, dayOfWeek])
  @@map("day_of_week_rules")
}

model RateRestriction {
  id         String   @id @default(uuid())
  ratePlanId String?  @map("rate_plan_id")
  roomTypeId String?  @map("room_type_id")
  validFrom  DateTime @map("valid_from")
  validTo    DateTime @map("valid_to")
  mlos       Int?
  maxLos     Int?     @map("max_los")
  cta        Boolean  @default(false)
  ctd        Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  ratePlan RatePlan? @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@index([ratePlanId, validFrom, validTo])
  @@index([roomTypeId, validFrom, validTo])
  @@map("rate_restrictions")
}

model Promotion {
  id                  String   @id @default(uuid())
  propertyId          String   @map("property_id")
  ratePlanId          String?  @map("rate_plan_id")
  code                String
  name                String
  discountType        String   @map("discount_type") // PERCENT | FIXED
  discountValue       Decimal  @map("discount_value") @db.Decimal(10, 2)
  minLOS              Int?     @map("min_los")
  advancePurchaseDays Int?     @map("advance_purchase_days")
  validFrom           DateTime @map("valid_from")
  validTo             DateTime @map("valid_to")
  maxRedemptions      Int?     @map("max_redemptions")
  currentRedemptions  Int      @default(0) @map("current_redemptions")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")

  property Property  @relation(fields: [propertyId], references: [id])
  ratePlan RatePlan? @relation(fields: [ratePlanId], references: [id], onDelete: SetNull)

  @@unique([propertyId, code])
  @@index([propertyId, isActive])
  @@map("promotions")
}

model RateOverride {
  id           String   @id @default(uuid())
  propertyId   String   @map("property_id")
  roomTypeId   String   @map("room_type_id")
  ratePlanId   String?  @map("rate_plan_id")
  date         DateTime
  overrideRate Decimal  @map("override_rate") @db.Decimal(10, 2)
  reason       String?
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, roomTypeId, ratePlanId, date])
  @@index([propertyId, date])
  @@map("rate_overrides")
}

// ═══════════════════════════════════════════════════════════════════════════
// RATES-METRICS-COMPSET-CORE (2026-06-03) — Bloque METRICS (Fase 2)
// Snapshot diario inmutable poblado por NightAuditScheduler. Fuente de los KPIs
// del dashboard (ADR/RevPAR/ocupación) + pace/pickup (irreconstruibles sin él).
// ═══════════════════════════════════════════════════════════════════════════

model MetricsDailySnapshot {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  date       DateTime
  computedAt DateTime @default(now()) @map("computed_at")

  totalRoomsAvailable Int     @map("total_rooms_available")
  roomsSold           Int     @map("rooms_sold")
  occupancyPercent    Decimal @map("occupancy_percent") @db.Decimal(5, 2)

  roomRevenue  Decimal @map("room_revenue") @db.Decimal(12, 2)
  baseCurrency String  @map("base_currency")
  adr          Decimal @db.Decimal(10, 2)
  revpar       Decimal @db.Decimal(10, 2)

  cancellationsCount Int @default(0) @map("cancellations_count")
  noShowsCount       Int @default(0) @map("no_shows_count")
  arrivalsCount      Int @default(0) @map("arrivals_count")
  departuresCount    Int @default(0) @map("departures_count")

  avgLengthOfStay Decimal? @map("avg_length_of_stay") @db.Decimal(4, 2)
  avgLeadTime     Decimal? @map("avg_lead_time") @db.Decimal(5, 2)

  channelMix        Json  @map("channel_mix")
  revenueByRoomType Json? @map("revenue_by_room_type")

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId, date(sort: Desc)])
  @@map("metrics_daily_snapshots")
}

/// Snapshot diario de "on-the-books a futuro" para pace/pickup/STLY (D-METRICS3,
/// 2026-06-04). Cada día capturamos, para cada noche futura D (hasta `horizonDays`),
/// cuántas habitaciones están reservadas AS-OF hoy + el revenue proyectado.
///
/// Pace      = onBooks(asOf=hoy, stay=D) vs onBooks(asOf=hace-1-año, stay=D-365)
/// Pickup(N) = onBooks(asOf=hoy, stay=D) − onBooks(asOf=hoy−N, stay=D)
/// STLY      = same metric same-time-last-year
///
/// IMPRESCINDIBLE capturarlo día a día — es irreconstruible retroactivamente
/// (no podemos saber qué reservas existían "en aquel momento" sin un log temporal).
model MetricsForwardSnapshot {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  asOfDate   DateTime @map("as_of_date")
  stayDate   DateTime @map("stay_date")
  computedAt DateTime @default(now()) @map("computed_at")

  totalRoomsAvailable Int     @map("total_rooms_available")
  roomsOnBooks        Int     @map("rooms_on_books")
  occupancyPercent    Decimal @map("occupancy_percent") @db.Decimal(5, 2)

  roomRevenue  Decimal @map("room_revenue") @db.Decimal(12, 2)
  baseCurrency String  @map("base_currency")
  adr          Decimal @db.Decimal(10, 2)
  revpar       Decimal @db.Decimal(10, 2)

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, asOfDate, stayDate])
  @@index([propertyId, stayDate])
  @@index([propertyId, asOfDate])
  @@map("metrics_forward_snapshots")
}

// ======================= COMPSET + LOCAL EVENTS (Fase 3 RATES-METRICS) =======================

/// Competidor seleccionado MANUALMENTE por el supervisor (D-COMPSET2: NO auto-radius
/// en MVP — boutique compite por posicionamiento, no por proximidad). 3-7 hoteles max
/// per property (enforced en service layer).
model Competitor {
  id             String   @id @default(uuid())
  propertyId     String   @map("property_id")
  name           String
  // Resolución externa (Google Places / Booking Affiliate)
  externalId     String?  @map("external_id")
  externalSource String?  @map("external_source") // BOOKING | EXPEDIA | GOOGLE_PLACES
  externalUrl    String?  @map("external_url")
  // Geo
  latitude       Float
  longitude      Float
  address        String?
  // Metadata (snapshot al pin; refresh diario actualiza)
  starRating     Decimal? @map("star_rating") @db.Decimal(2, 1)
  guestRating    Decimal? @map("guest_rating") @db.Decimal(3, 2) // 0-10 Booking style
  reviewCount    Int?     @map("review_count")
  roomCount      Int?     @map("room_count")
  // Lifecycle
  isActive       Boolean  @default(true) @map("is_active")
  addedById      String   @map("added_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  property  Property          @relation(fields: [propertyId], references: [id])
  snapshots CompsetSnapshot[]

  @@index([propertyId, isActive])
  @@map("competitors")
}

/// Snapshot inmutable per competidor per día (D-COMPSET4 append-only). Histórico
/// permite trend analysis. `ratesByDate` = { "2026-07-15": { lowestRate, currency, availability } }.
model CompsetSnapshot {
  id             String   @id @default(uuid())
  competitorId   String   @map("competitor_id")
  propertyId     String   @map("property_id")
  scrapedAt      DateTime @default(now()) @map("scraped_at")
  source         String   @default("SCRAPER_DIY") // SCRAPER_DIY | LIGHTHOUSE | RATEGAIN | STUB
  // Rates por noche futura
  ratesByDate    Json     @map("rates_by_date")
  ratingSnapshot Json?    @map("rating_snapshot") // { starRating, guestRating, reviewCount }
  // Audit
  durationMs     Int?     @map("duration_ms")
  warnings       String[] @default([]) // errores no-fatales (1 hotel falló, etc.)

  competitor Competitor @relation(fields: [competitorId], references: [id])

  @@index([competitorId, scrapedAt(sort: Desc)])
  @@index([propertyId, scrapedAt(sort: Desc)])
  @@map("compset_snapshots")
}

/// Eventos locales con scope 4-niveles (D-COMPSET8). Replicable LATAM, NO hardcoded
/// QR. Resolution: city > regionCode > countryCode > lat/lng radius. Curated por
/// Events Curator (D-COMPSET9, analog Tax Curator §91). Cliente NO edita el catálogo
/// base; usa `LocalEventOverride` con reason + approvedById.
model LocalEvent {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  category           String // FESTIVAL | CONFERENCE | HOLIDAY | SPORTS | CONCERT | RELIGIOUS | NATIONAL_HOLIDAY
  startDate          DateTime  @map("start_date")
  endDate            DateTime  @map("end_date")
  // Geo scoping 4 niveles
  countryCode        String    @map("country_code") // ISO 3166-1 alpha-2 (e.g. MX, CO, CR)
  regionCode         String?   @map("region_code") // ISO 3166-2 (e.g. MX-ROO, CO-DC)
  city               String?
  latitude           Float?
  longitude          Float?
  radiusKm           Decimal?  @map("radius_km") @db.Decimal(6, 2)
  // Demand impact
  demandImpact       String    @default("MEDIUM") @map("demand_impact") // LOW | MEDIUM | HIGH | EXTREME
  expectedAttendance Int?      @map("expected_attendance")
  // Source + curation
  source             String    @default("MANUAL") // MANUAL | EVENTBRITE | SONGKICK | TICKETMASTER
  sourceUrl          String?   @map("source_url")
  sourceExternalId   String?   @map("source_external_id")
  curatedById        String?   @map("curated_by_id")
  verifiedAt         DateTime? @map("verified_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  overrides LocalEventOverride[]

  @@index([countryCode, startDate])
  @@index([regionCode, startDate])
  @@index([city, startDate])
  @@map("local_events")
}

/// Override per-property de un LocalEvent (D-COMPSET9 + analog Tax Override §92).
/// Permite custom name/impact o `disabled=true` para ocultar el evento base. Reason +
/// approvedById obligatorios (audit). Si `baseEventId=null`, es un evento 100% custom.
model LocalEventOverride {
  id                 String   @id @default(uuid())
  propertyId         String   @map("property_id")
  baseEventId        String?  @map("base_event_id")
  customName         String?  @map("custom_name")
  customDemandImpact String?  @map("custom_demand_impact")
  disabled           Boolean  @default(false)
  reason             String
  approvedById       String   @map("approved_by_id")
  createdAt          DateTime @default(now()) @map("created_at")

  baseEvent LocalEvent? @relation(fields: [baseEventId], references: [id])
  property  Property    @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@map("local_event_overrides")
}
