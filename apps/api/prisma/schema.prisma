model GuestStay {
  id                    String              @id @default(uuid())
  // Human-readable booking reference: MX-D-001-2604-0134
  // Segments: [country]-[source]-[propCode]-[YYMM]-[seq]
  bookingRef            String?             @unique @map("booking_ref")
  organizationId        String              @map("organization_id")
  propertyId            String              @map("property_id")
  roomId                String              @map("room_id")
  guestName             String              @map("guest_name")
  guestEmail            String?             @map("guest_email")
  guestPhone            String?             @map("guest_phone")
  documentType          String?             @map("document_type")
  documentNumber        String?             @map("document_number")
  nationality           String?
  paxCount              Int                 @default(1) @map("pax_count")
  checkinAt             DateTime            @map("checkin_at")
  scheduledCheckout     DateTime            @map("scheduled_checkout")
  actualCheckout        DateTime?           @map("actual_checkout")
  actualCheckin         DateTime?           @map("actual_checkin")
  checkinConfirmedById  String?             @map("checkin_confirmed_by_id")
  ratePerNight          Decimal             @map("rate_per_night") @db.Decimal(10, 2)
  currency              String              @default("USD")
  totalAmount           Decimal             @map("total_amount") @db.Decimal(10, 2)
  amountPaid            Decimal             @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentStatus         PaymentStatus       @default(PENDING) @map("payment_status")
  source                String?
  notes                 String?
  checkedInById         String              @map("checked_in_by_id")
  checkedOutById        String?             @map("checked_out_by_id")
  // ── No-show fields ───────────────────────────────────────────────────────
  // noShowAt != null indica que el huésped no se presentó y fue marcado.
  // La disponibilidad de la habitación excluye stays con noShowAt != null
  // (ver checkAvailability). El cargo se registra en noShowFeeAmount y su
  // estado en noShowChargeStatus (PENDING → CHARGED | FAILED | WAIVED).
  noShowAt              DateTime?           @map("no_show_at")
  noShowById            String?             @map("no_show_by_id")
  noShowReason          String?             @map("no_show_reason")
  noShowFeeAmount       Decimal?            @map("no_show_fee_amount") @db.Decimal(10, 2)
  noShowFeeCurrency     String?             @map("no_show_fee_currency")
  noShowChargeStatus    NoShowChargeStatus? @map("no_show_charge_status")
  noShowRevertedAt      DateTime?           @map("no_show_reverted_at")
  noShowRevertedById    String?             @map("no_show_reverted_by_id")
  // ── Late checkout escalation (Sprint 9) ─────────────────────────────────
  // Tracking de cuál tier de notificación ya se disparó para esta stay.
  // Evita duplicar notifs en cada corrida del cron. Reset al hacer
  // confirmDeparture o checkout (la stay sale del flujo de escalación).
  // 0 = ningún tier disparado; 1 = Tier 1 (RECEPTIONIST); 2 = Tier 2 (SUPERVISOR).
  lateCheckoutTier      Int?                @default(0) @map("late_checkout_tier")
  lateCheckoutFlaggedAt DateTime?           @map("late_checkout_flagged_at")
  // ── Check-in extended fields (Sprint 9) ─────────────────────────────────
  arrivalNotes          String?             @map("arrival_notes")
  keyType               KeyDeliveryType?    @map("key_type")
  // ── Reports — pace/lead-time analytics (Sprint 9 research recommendation) ─
  // Días entre creación de la reserva y check-in. Calculado al crear.
  // Habilita pace/lead-time analysis (top wanted report en cross-research)
  // sin recomputar `differenceInDays` en cada query agregada. Trivial cost.
  bookingLeadDays       Int?                @map("booking_lead_days")
  // ── Stripe card-on-file (Sprint 8) ───────────────────────────────────────
  // Guardados al hacer check-in via SetupIntent (usage: 'off_session').
  // stripePaymentIntentId se genera al procesar el cargo de no-show.
  stripeCustomerId      String?             @map("stripe_customer_id")
  stripePaymentMethodId String?             @map("stripe_payment_method_id")
  stripePaymentIntentId String?             @map("stripe_payment_intent_id")
  deletedAt             DateTime?           @map("deleted_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // ── TODO(sprint8-pricing): campos para gestión de tarifas y channel manager ──
  // Descomentar y migrar cuando se implemente Sprint 8. Ver CLAUDE.md §Sprint 8.
  //
  // ratePlanId         String?    @map("rate_plan_id")         // FK → RatePlan
  // rateOverride       Decimal?   @map("rate_override") @db.Decimal(10, 2)
  // rateOverrideReason String?    @map("rate_override_reason")
  // channexRateId      String?    @map("channex_rate_id")      // ID en Channex.io
  // commissionRate     Decimal?   @map("commission_rate") @db.Decimal(5, 4)   // e.g. 0.15 = 15%
  //
  // TODO(sprint8-pricing): Nuevo modelo RatePlan (separado de GuestStay)
  // model RatePlan {
  //   id                String   @id @default(uuid())
  //   propertyId        String
  //   roomTypeId        String?
  //   name              String
  //   baseRate          Decimal  @db.Decimal(10, 2)
  //   currency          String   @default("MXN")
  //   channexRatePlanId String?
  //   isActive          Boolean  @default(true)
  //   markup            Decimal? @db.Decimal(5, 4)  // markup sobre tarifa base OTA
  //   createdAt         DateTime @default(now())
  //   updatedAt         DateTime @updatedAt
  // }

  // ── Cancel-Archive (Sprint CANCEL-ARCHIVE) ────────────────────────────
  // Patrón soft-delete obligatorio. Una stay cancelada permanece en DB con
  // `cancelledAt != null`. AvailabilityService excluye cancelled stays.
  //
  // Diseño "espiral": campos son strings (no enums) y JSON metadata para
  // permitir agregar valores sin migration. FK hooks listos para integrar
  // PAY-CORE (v1.0.1), CFDI-CORE (v1.0.2), Channex outbound sin schema
  // change. Soporta hotel boutique / hostal / STR (Airbnb-style) con el
  // mismo modelo: STR persiste `cancelMetadata.airbnbCancelCode` sin
  // afectar el flujo principal.
  cancelledAt           DateTime?  @map("cancelled_at")
  cancelledById         String?    @map("cancelled_by_id")
  // 'GUEST' | 'HOTEL' | 'OTA' | 'ADMIN_ERROR' | 'SYSTEM' (string, no enum)
  cancelInitiator       String?    @map("cancel_initiator")
  // Texto libre + opcional motivo de dropdown via cancelReasonCode
  cancelReason          String?    @map("cancel_reason")
  cancelReasonCode      String?    @map("cancel_reason_code")
  // OTA cancel codes, refund refs, host fees (STR), email refs, etc.
  cancelMetadata        Json?      @map("cancel_metadata")
  // 'PMS_DIRECT' | 'CHANNEX_WEBHOOK' | 'AUTO_SYSTEM'
  cancelledFromChannel  String?    @map("cancelled_from_channel")
  // FK hook para CancellationPolicy futura (v1.1+ rate plan policies)
  cancellationPolicyId  String?    @map("cancellation_policy_id")
  // Sembrado para v1.0.2 CFDI-CORE — emite CFDI E + FormaPago=15 si folio
  // origen tuvo CFDI I previo y cancelInitiator != 'ADMIN_ERROR'
  requiresFiscalReview  Boolean    @default(false) @map("requires_fiscal_review")
  // Sembrado para anonymization scheduler v1.0.4 NS-UI
  anonymizedAt          DateTime?  @map("anonymized_at")
  // ──────────────────────────────────────────────────────────────────────

  organization Organization      @relation(fields: [organizationId], references: [id])
  room         Room              @relation(fields: [roomId], references: [id])
  stayJourney  StayJourney?
  staySegments StaySegment[]
  contactLogs  GuestContactLog[]
  paymentLogs  PaymentLog[]
  guestStayLogs GuestStayLog[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([roomId])
  @@index([paymentStatus])
  @@index([noShowAt])
  @@index([cancelledAt])
  @@map("guest_stays")
}

// ===================== PRE-CHECKIN QUALITY SYSTEM =====================
//
// Restaurado desde migration 20260402192948_add_pre_checkin_quality_system.
// Workflow: al hacer checkout de un huésped (OnEvent 'checkout.confirmed'),
// se crea automáticamente un RoomReadinessTask con items copiados del
// RoomTypeChecklist activo para la propiedad. Housekeeping los marca (PENDING
// → DONE | ISSUE_FOUND | SKIPPED) antes del siguiente check-in.

enum ReadinessStatus {
  PENDING
  IN_PROGRESS
  NEEDS_MAINTENANCE
  READY
  APPROVED
}

enum ItemStatus {
  PENDING
  DONE
  ISSUE_FOUND
  SKIPPED
}

model RoomTypeChecklist {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  roomTypeId     String?  @map("room_type_id")
  name           String
  triggerOn      String   @default("checkout")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization        @relation(fields: [organizationId], references: [id])
  items          ChecklistItem[]
  readinessTasks RoomReadinessTask[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_type_checklists")
}

model ChecklistItem {
  id            String  @id @default(uuid())
  checklistId   String  @map("checklist_id")
  category      String
  description   String
  isRequired    Boolean @default(true) @map("is_required")
  requiresPhoto Boolean @default(false) @map("requires_photo")
  sortOrder     Int     @default(0) @map("sort_order")

  checklist RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  taskItems RoomReadinessTaskItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model RoomReadinessTask {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  propertyId     String          @map("property_id")
  roomId         String          @map("room_id")
  checklistId    String          @map("checklist_id")
  assignedToId   String?         @map("assigned_to_id")
  triggeredBy    String          @map("triggered_by")
  status         ReadinessStatus @default(PENDING)
  dueBy          DateTime?       @map("due_by")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id])
  room         Room                    @relation(fields: [roomId], references: [id])
  checklist    RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  items        RoomReadinessTaskItem[]

  @@index([organizationId])
  @@index([roomId, status])
  @@map("room_readiness_tasks")
}

model RoomReadinessTaskItem {
  id                  String     @id @default(uuid())
  taskId              String     @map("task_id")
  checklistItemId     String     @map("checklist_item_id")
  status              ItemStatus @default(PENDING)
  completedById       String?    @map("completed_by_id")
  completedAt         DateTime?  @map("completed_at")
  photoUrl            String?    @map("photo_url")
  notes               String?
  // ── Sprint Mx-1 — vínculo con ticket levantado al detectar problema ─────
  // El housekeeper marca un item del checklist como "issue detected" → se crea
  // automáticamente un MaintenanceTicket con sourceTaskId = task.cleaningTaskId
  // (si aplica) y se guarda el id aquí para auditoría inversa.
  maintenanceTicketId String?    @map("maintenance_ticket_id")

  task              RoomReadinessTask  @relation(fields: [taskId], references: [id])
  checklistItem     ChecklistItem      @relation(fields: [checklistItemId], references: [id])
  maintenanceTicket MaintenanceTicket? @relation("ItemMaintenanceTicket", fields: [maintenanceTicketId], references: [id])

  @@index([taskId])
  @@index([maintenanceTicketId])
  @@map("room_readiness_task_items")
}

