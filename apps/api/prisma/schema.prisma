  currency          String        @default("USD")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  source            String?
  notes             String?
  checkedInById     String        @map("checked_in_by_id")
  checkedOutById    String?       @map("checked_out_by_id")
  // ── No-show fields ───────────────────────────────────────────────────────
  // noShowAt != null indica que el huésped no se presentó y fue marcado.
  // La disponibilidad de la habitación excluye stays con noShowAt != null
  // (ver checkAvailability). El cargo se registra en noShowFeeAmount y su
  // estado en noShowChargeStatus (PENDING → CHARGED | FAILED | WAIVED).
  noShowAt           DateTime?           @map("no_show_at")
  noShowById         String?             @map("no_show_by_id")
  noShowReason       String?             @map("no_show_reason")
  noShowFeeAmount    Decimal?            @map("no_show_fee_amount") @db.Decimal(10, 2)
  noShowFeeCurrency  String?             @map("no_show_fee_currency")
  noShowChargeStatus NoShowChargeStatus? @map("no_show_charge_status")
  noShowRevertedAt   DateTime?           @map("no_show_reverted_at")
  noShowRevertedById String?             @map("no_show_reverted_by_id")
  // ── Check-in extended fields (Sprint 9) ─────────────────────────────────
  arrivalNotes  String?          @map("arrival_notes")
  keyType       KeyDeliveryType? @map("key_type")
  // ── Reports — pace/lead-time analytics (Sprint 9 research recommendation) ─
  // Días entre creación de la reserva y check-in. Calculado al crear.
