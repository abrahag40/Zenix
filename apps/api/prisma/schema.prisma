// ── Sprint Mx-1 — Módulo de Mantenimiento (v1.0.0 scope) ──────────────────
//
// Sistema completo de tickets de mantenimiento que reemplaza al modelo legacy
// `MaintenanceIssue` (lightweight, vinculado a CleaningTask). Caso de uso real
// que motivó el módulo (Hotel Monica Tulum, 2026-04-09): el área de mantenimiento
// inició encerado de Bongaloo B2 sin bloquear la habitación → la habitación se
// vendió en Booking.com → el hotel asumió pérdidas reubicando al huésped.
//
// El módulo MaintenanceModule es MONOLÍTICO con el resto del PMS (mismo NestJS,
// misma BD, mismo auth). La separación es a nivel de módulos NestJS, no de
// servicios. Ver CLAUDE.md §10 para el principio arquitectónico.
//
// Bridge crítico con inventario:
//   TicketPriority.CRITICAL → MaintenanceModule.onTicketCreated()
//                          → SmartBlockService.createBlock(OUT_OF_ORDER, MAINTENANCE)
//                          → room.status = BLOCKED
//                          → la habitación desaparece del calendario PMS para venta.
// Resuelto en RoomBlock.maintenanceTicketId (FK del lado del bloque para evitar
// dependencia circular). El ticket conoce su bloque vía la reverse relation.

enum TicketStatus {
  OPEN              // recién creado por housekeeper/recepcionista
  ACKNOWLEDGED      // técnico de mantenimiento lo vio (lectura confirmada)
  IN_PROGRESS       // trabajo activo
  WAITING_PARTS     // pausa por espera de material/proveedor
  RESOLVED          // técnico marcó trabajo completado
  VERIFIED          // supervisor confirmó la resolución (calidad)
  CLOSED            // archivado — readonly, fuente para reportes históricos
}

enum TicketPriority {
  LOW               // cosmético, no afecta disponibilidad (mancha leve, pintura)
  MEDIUM            // funcional pero no bloquea la habitación (foco fundido)
  HIGH              // afecta experiencia del huésped (aire acondicionado débil)
  CRITICAL          // habitación inhabitable → AUTO-BLOQUEA inventario en PMS
}

enum TicketCategory {
  PLUMBING          // fontanería: grifos, baño, desagües
  ELECTRICAL        // eléctrico: instalación, contactos, breakers
  FURNITURE         // mobiliario: cama, escritorio, sillas dañadas
  APPLIANCE         // electrodomésticos: TV, mini-bar, cafetera
  HVAC              // climatización: aire, calefacción, ventilación
  STRUCTURAL        // estructura: paredes, techo, piso, ventanas
  COSMETIC          // estética: pintura, manchas no removibles
  SAFETY            // seguridad: cerraduras, detectores humo, extintores
  PEST              // control de plagas (escala desde housekeeping)
  DEEP_CLEANING     // limpieza profunda especializada (mancha extrema, encerado)
  OTHER
}

enum TicketLogEvent {
  CREATED              // ticket nuevo
  ACKNOWLEDGED         // técnico marcó como visto
  ASSIGNED             // assignedToId cambió
  STARTED              // status → IN_PROGRESS
  WAITING_PARTS        // status → WAITING_PARTS
  RESOLVED             // status → RESOLVED
  VERIFIED             // status → VERIFIED por supervisor
  CLOSED               // status → CLOSED
  REOPENED             // RESOLVED/VERIFIED → IN_PROGRESS (regresión)
  COMMENT_ADDED        // nuevo TicketComment
  PHOTO_ADDED          // nueva TicketPhoto
  BLOCK_AUTO_CREATED   // CRITICAL → RoomBlock auto-creado
  BLOCK_AUTO_RELEASED  // ticket VERIFIED/CLOSED → RoomBlock liberado
}

// ======================= MULTI-TENANT FOUNDATION =======================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(STARTER)
  countryCode String   @default("MX") @map("country_code")
  timezone    String   @default("America/Cancun")
  currency    String   @default("MXN")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Reverse relations (denormalized organizationId in all business tables)
  properties        Property[]
  users             User[]
  rooms             Room[]
  units             Unit[]
  housekeepingStaff HousekeepingStaff[]
  checkouts         Checkout[]
  cleaningTasks     CleaningTask[]
  taskLogs          TaskLog[]
  cleaningNotes     CleaningNote[]
  maintenanceIssues MaintenanceIssue[]
  unitDiscrepancies UnitDiscrepancy[]
  pushTokens        PushToken[]
  pmsConfigs        PmsConfig[]
  propertySettings  PropertySettings[]
  roomTypes         RoomType[]
  guestStays        GuestStay[]
  roomTypeChecklists RoomTypeChecklist[]
  roomReadinessTasks RoomReadinessTask[]
  stayJourneys       StayJourney[]
  roomBlocks         RoomBlock[]
  appNotifications   AppNotification[]
  // ── Sprint 8H ─────────────────────────────────────────────────────────────
  staffShifts        StaffShift[]
  // ── Sprint 9 ──────────────────────────────────────────────────────────────
  channelCommissions ChannelCommission[]
  // ── Sprint Mx-1 — Mantenimiento ──────────────────────────────────────────
  maintenanceTickets MaintenanceTicket[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id])
  propertyRoles UserPropertyRole[]
  staffProfiles HousekeepingStaff[]

  @@index([organizationId])
  @@map("users")
}

model UserPropertyRole {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  propertyId String     @map("property_id")
  role       SystemRole
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId, role])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_roles")
}

// ======================= CORE MODELS =======================

model Property {
  id             String        @id @default(uuid())
  organizationId String?       @map("organization_id")
  name           String
  type           PropertyType  @default(HOTEL)
  taxId          String?       @map("tax_id")
  // Optional geographic grouping for the property switcher.
  // `region` is the coarse grouping key (chains split by "Caribe",
  // "Pacífico", "Brasil", etc. — see Mews/Opera multi-property docs);
  // `city` disambiguates properties with the same name inside the
  // same region (Slack/Google-picker pattern).
  region         String?
  city           String?
  // Globally unique 3-digit code assigned sequentially at property creation.
  // Used as segment in bookingRef: MX-D-001-2604-0134
  propCode       String?       @unique @map("prop_code")
  isActive       Boolean       @default(true) @map("is_active")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  rooms        Room[]
  roomTypes    RoomType[]
  staff        HousekeepingStaff[]
  pmsConfig    PmsConfig?
  settings     PropertySettings?
  userRoles    UserPropertyRole[]
  stayJourneys StayJourney[]
  appNotifications AppNotification[]
  // ── Sprint 8H ─────────────────────────────────────────────────────────────
  shifts          StaffShift[]
  staffCoverages  StaffCoverage[]
  shiftClocks     StaffShiftClock[]
  // ── Sprint 9 — Reports / Channel Manager ──────────────────────────────────
  channelCommissions ChannelCommission[]
  // ── Feature flags / testing toggles ───────────────────────────────────────
  featureFlags    FeatureFlag[]
  // ── Reports — pre-computed aggregations (Sprint 9 research) ──────────────
  dailyMetrics       DailyPropertyMetrics[]
  channelProduction  ChannelProductionDaily[]
  // ── Sprint Mx-1 — Mantenimiento ──────────────────────────────────────────
  maintenanceTickets MaintenanceTicket[]

  @@index([organizationId])
  @@map("properties")
}

model Room {
  id              String      @id @default(uuid())
  organizationId  String?     @map("organization_id")
  propertyId      String
  number          String
  floor           Int?
  category        RoomCategory
  capacity        Int
  status          RoomStatus  @default(AVAILABLE) @map("room_status")
  roomTypeId      String?     @map("room_type_id")
  channexRoomTypeId String?   @map("channex_room_type_id")   // ID del room type en Channex.io (Sprint 8)
  notes             String?
  deletedAt       DateTime?   @map("deleted_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization?  @relation(fields: [organizationId], references: [id])
  property     Property       @relation(fields: [propertyId], references: [id])
  roomType     RoomType?       @relation(fields: [roomTypeId], references: [id])
  units        Unit[]
  checkouts    Checkout[]
  guestStays   GuestStay[]
  readinessTasks RoomReadinessTask[]
  staySegments StaySegment[]
  blocks       RoomBlock[]
  // ── Sprint 8H — quién cubre esta habitación por defecto ───────────────────
  staffCoverages StaffCoverage[]
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  maintenanceTickets MaintenanceTicket[] @relation("TicketRoom")

  @@unique([propertyId, number])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([status])
  @@map("rooms")
}

model Unit {
  id             String     @id @default(uuid())
  organizationId String?    @map("organization_id")
  label          String
  roomId         String
  status         UnitStatus @default(AVAILABLE)
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization  Organization?     @relation(fields: [organizationId], references: [id])
  room          Room              @relation(fields: [roomId], references: [id])
  cleaningTasks CleaningTask[]
  discrepancies UnitDiscrepancy[]
  blocks        RoomBlock[]
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  // Ticket a nivel unidad (e.g. solo cama 2 del dorm tiene problema mecánico)
  maintenanceTickets MaintenanceTicket[] @relation("TicketUnit")

  @@index([organizationId])
  @@map("units")
}

model HousekeepingStaff {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  userId         String?          @map("user_id")
  propertyId     String
  name           String
  email          String           @unique
  passwordHash   String
  role           HousekeepingRole
  department     Department       @default(HOUSEKEEPING) @map("department")
  active         Boolean          @default(true)
  capabilities   Capability[]
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now())

  organization  Organization?   @relation(fields: [organizationId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  tasks         CleaningTask[]  @relation("AssignedTasks")
  verifiedTasks CleaningTask[]  @relation("VerifiedTasks")
  taskLogs      TaskLog[]
  cleaningNotes          CleaningNote[]
  pushTokens             PushToken[]
  checkouts              Checkout[]        @relation("ManualCheckouts")
  issues                 MaintenanceIssue[]
  reportedDiscrepancies  UnitDiscrepancy[] @relation("DiscrepancyReporter")
  resolvedDiscrepancies  UnitDiscrepancy[] @relation("DiscrepancyResolver")
  requestedBlocks       RoomBlock[]      @relation("BlocksRequested")
  approvedBlocks        RoomBlock[]      @relation("BlocksApproved")
  blockLogs             BlockLog[]       @relation("BlockLogs")
  contactLogs           GuestContactLog[] @relation("ContactLogs")
  notificationsTriggered AppNotification[] @relation("NotifTriggeredBy")
  notificationReads      AppNotificationRead[] @relation("NotifReadBy")
  notificationApprovals  AppNotificationApproval[] @relation("NotifApprovedBy")
  collectedPayments      PaymentLog[]     @relation("PaymentCollectedBy")
  approvedPayments       PaymentLog[]     @relation("PaymentApprovedBy")
  voidedPayments         PaymentLog[]     @relation("PaymentVoidedBy")
  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  shifts                 StaffShift[]
  shiftExceptions        StaffShiftException[]            @relation("ShiftExceptionsForStaff")
  approvedShiftExceptions StaffShiftException[]           @relation("ShiftExceptionsApprovedBy")
  coverages              StaffCoverage[]
  shiftClocks            StaffShiftClock[]
  preferences            StaffPreferences?
  preferenceChangesMade  StaffPreferenceLog[]             @relation("PreferenceChangesByStaff")
  // ── Sprint 8I-J — Hub Recamarista gamificación (privacy-respecting) ─────
  streak                 StaffStreak?
  personalRecords        StaffPersonalRecord[]
  dailyActivity          StaffDailyActivity[]
  // ── Feature flags audit trail ────────────────────────────────────────────
  featureFlagsUpdated    FeatureFlag[]
  featureFlagAudits      FeatureFlagAuditLog[]
  // ── Sprint Mx-1 — Módulo de Mantenimiento ─────────────────────────────────
  // Un staff puede aparecer en múltiples roles dentro del ciclo de vida de un
  // ticket (reporta, asignado, resuelve, verifica) — cada relación es independiente.
  // Department.MAINTENANCE identifica al staff que es técnico de mantenimiento.
  ticketsReported        MaintenanceTicket[]        @relation("TicketsReported")
  ticketsAssigned        MaintenanceTicket[]        @relation("TicketsAssigned")
  ticketsResolved        MaintenanceTicket[]        @relation("TicketsResolved")
  ticketsVerified        MaintenanceTicket[]        @relation("TicketsVerified")
  ticketPhotosUploaded   MaintenanceTicketPhoto[]   @relation("TicketPhotoUploader")
  ticketCommentsAuthored MaintenanceTicketComment[] @relation("TicketCommentAuthor")
  ticketLogsBy           MaintenanceTicketLog[]     @relation("TicketLogActor")

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("housekeeping_staff")
}

model Checkout {
  id                     String         @id @default(uuid())
  organizationId         String?        @map("organization_id")
  roomId                 String
  guestName              String?
  actualCheckoutAt       DateTime
  source                 CheckoutSource
  isEarlyCheckout        Boolean        @default(false)
  hasSameDayCheckIn      Boolean        @default(false)
  notes                  String?
  enteredById            String?
  cancelled              Boolean        @default(false)
  cancelledAt            DateTime?
  createdAt              DateTime       @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  room         Room              @relation(fields: [roomId], references: [id])
  enteredBy    HousekeepingStaff? @relation("ManualCheckouts", fields: [enteredById], references: [id])
  tasks        CleaningTask[]

  @@index([organizationId])
  @@map("checkouts")
}

// TODO(hotel-room-granularity): CleaningTask fue diseñado hostel-first — unitId es NOT NULL
// y la tarea siempre se vincula a una unidad, nunca directamente a una habitación.
// Para hoteles con habitaciones dobles/twin (2 unidades, 1 unidad vendible), un bloqueo
// de habitación genera hoy N tareas MAINTENANCE (una por unidad) cuando debería ser 1.
// Refactor requerido:
//   1. Hacer unitId opcional: `unitId String?`
//   2. Añadir `roomId String?` (XOR con unitId — exactamente uno debe estar presente)
//   3. Actualizar TasksService, CleaningTaskDto, KanbanPage y mobile task/[id].tsx
//      para renderizar roomId cuando unitId sea null (tareas de bloqueo room-level)
//   4. Migración Prisma: no hay datos existentes de tipo MAINTENANCE, safe to migrate
model CleaningTask {
  id                 String         @id @default(uuid())
  organizationId     String?        @map("organization_id")
  unitId             String
  checkoutId         String?
  assignedToId       String?
  status             CleaningStatus @default(PENDING)
  taskType           TaskType       @default(CLEANING)
  // TODO(housekeeping-pms-bridge): agregar sourceType para distinguir el origen de la tarea.
  // Descomentar y migrar cuando se implemente el bridge PMS → Housekeeping (Sprint 7A/7B).
  // sourceType         CleaningTaskSource @default(CHECKOUT)
  // enum CleaningTaskSource { CHECKOUT, STAYOVER, ROOM_CHANGE, EXTENSION }
  requiredCapability Capability     @default(CLEANING)
  priority           Priority       @default(MEDIUM)
  hasSameDayCheckIn  Boolean        @default(false)
  startedAt          DateTime?
  finishedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  scheduledFor         DateTime?             @db.Date @map("scheduled_for")  // fecha lógica del roster (idempotencia + queries)
  carryoverFromDate    DateTime?             @db.Date @map("carryover_from_date")
  carryoverFromTaskId  String?               @map("carryover_from_task_id")
  autoAssignmentRule   String?               @map("auto_assignment_rule")    // 'COVERAGE_PRIMARY' | 'COVERAGE_BACKUP' | 'ROUND_ROBIN' | null
  cancelledReason      CleaningCancelReason? @map("cancelled_reason")
  cancelledAt          DateTime?             @map("cancelled_at")
  extensionFlag        ExtensionFlag?        @map("extension_flag")          // D12 — re-etiqueta cuando extension aplica

  // ── Sprint 9 / EC-6 — Skip-and-retry (AHLEI Sec. 4.3) ────────────────────
  deferredAt           DateTime?              @map("deferred_at")
  deferredReason       CleaningDeferReason?   @map("deferred_reason")
  // Hora a la que la tarea debe re-promoverse a READY/UNASSIGNED automáticamente.
  // El cron `*/5 * * * *` la chequea contra `now`. Default 30 min post-defer (AHLEI).
  retryAt              DateTime?              @map("retry_at")
  // Contador acumulado de deferrals. ≥3 → status=BLOCKED + notif tier-2.5 supervisor.
  deferredCount        Int                    @default(0) @map("deferred_count")

  // ── Sprint 9 / EC-3 — Late checkout (huésped sale a hora distinta) ───────
  // Si la recepción aprobó late checkout, este timestamp guarda la nueva
  // hora prevista. Mobile lo usa para re-calcular prioridad: la tarea no
  // es URGENT hasta que `now >= lateCheckoutAt - 1h`.
  lateCheckoutAt       DateTime?              @map("late_checkout_at")

  // ── Sprint 9 / D15 — Override flags (OperationalOverridesPage) ────────────
  // Limpieza profunda — cambia el template de checklist + duración estimada.
  // Operativo: el housekeeper recibe pack diferente (sábanas + manta + cortinas
  // vs solo sábanas) y debe documentar más fotos.
  deepClean            Boolean                @default(false) @map("deep_clean")
  // Hold por extensión sin formalizar (huésped pidió quedarse pero aún no paga).
  // Estado: la tarea se mantiene PENDING (no se inicia limpieza). El housekeeper
  // ve el badge "⏸ En espera de extensión". Al formalizar la extensión: D12
  // resuelve (con/sin limpieza). Al cancelar el hold: vuelve a estado normal.
  holdReason           String?                @map("hold_reason")
  heldAt               DateTime?              @map("held_at")
  heldById             String?                @map("held_by_id")

  organization Organization?      @relation(fields: [organizationId], references: [id])
  unit         Unit               @relation(fields: [unitId], references: [id])
  checkout     Checkout?          @relation(fields: [checkoutId], references: [id])
  assignedTo   HousekeepingStaff? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  verifiedBy   HousekeepingStaff? @relation("VerifiedTasks", fields: [verifiedById], references: [id])
  logs         TaskLog[]
  notes        CleaningNote[]
  issues       MaintenanceIssue[]
  block        RoomBlock?         @relation("BlockTask")
  // Self-relation for carryover audit chain (CleaningTask → original CleaningTask de ayer)
  carryoverFromTask    CleaningTask?  @relation("TaskCarryover", fields: [carryoverFromTaskId], references: [id])
  carryoverChildren    CleaningTask[] @relation("TaskCarryover")
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  // Tickets levantados durante esta tarea de limpieza (housekeeper detecta
  // problemas en cuarto). Vínculo via MaintenanceTicket.sourceTaskId.
  maintenanceTickets   MaintenanceTicket[] @relation("TicketSourceTask")

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId, status])
  @@index([unitId])
  @@index([checkoutId])
  @@index([scheduledFor, status])
  @@index([carryoverFromDate])
  @@index([cancelledReason])
  @@map("cleaning_tasks")
}

