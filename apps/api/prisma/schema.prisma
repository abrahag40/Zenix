enum CleaningStatus {
  PENDING
  READY
  UNASSIGNED
  IN_PROGRESS
  PAUSED
  DONE
  VERIFIED
  CANCELLED
  // ── Sprint 9 / EC-6 — skip-and-retry (AHLEI Sec. 4.3) ────────────────────
  // DEFERRED: housekeeper tocó la puerta y nadie respondió, o el huésped
  // tiene chip DND físico. La tarea se reprograma automáticamente para
  // 30 min después (cron auto-retry). Tras 3 deferrals consecutivos →
  // BLOCKED (acción manual del supervisor).
  DEFERRED
  BLOCKED
}

// EC-6 — razones por las cuales una tarea se difiere temporalmente.
enum CleaningDeferReason {
  DND_PHYSICAL // chip "do not disturb" colgado en la puerta
  NO_ANSWER // tocó, nadie respondió
  GUEST_REQUEST // huésped pidió "vuelve más tarde"
}

/**
 * StaffRole — función operativa del staff dentro del hotel.
 * Decisión de naming (2026-05-08): renombrado desde HousekeepingRole.
 * El enum aplicaba a TODAS las áreas (housekeeping, mantenimiento, recepción,
 * etc.) — el prefijo "Housekeeping" era engañoso e implicaba que el staff
 * pertenecía solo a esa área. Industry standard: AHLEI/USALI usan "Staff"
 * o "Employee" para el modelo abstracto. Mews/Cloudbeds usan "User".
 * Nota deuda técnica: este enum mezcla 2 ejes ortogonales (función +
 * jerarquía: SUPERVISOR es un nivel jerárquico, RECEPTIONIST es función).
 * Sprint 9 introdujo `StaffLevel` (LEAD/COLLABORATOR) para separar la
 * jerarquía. `StaffRole` permanece para retrocompatibilidad durante
 * deprecation period — eliminarse cuando todos los guards consuman level.
 */
enum StaffRole {
  HOUSEKEEPER
  SUPERVISOR
  RECEPTIONIST
}

/**
 * StaffLevel — eje jerárquico ortogonal a StaffRole/Department.
 * Cada Department tiene N COLLABORATORs y 1+ LEADs. El LEAD ejerce autoridad
 * sobre el área (asignar tareas, verificar, aprobar overrides). Combinado
 * con `Staff.reportsToId` habilita árbol jerárquico (SuccessFactors-like)
 * para visualización de plantilla — futuro post-v1.0.
 */
enum StaffLevel {
  LEAD
  COLLABORATOR
}

/**
 * Department — operational area within a hotel property.
 * Sprint 8I "shared chrome + role-aware module" (CLAUDE.md / ARCHITECTURE.md AD-011):
 * the mobile app shows the same chrome (tabs, dashboard, notifications, profile) for
 * all staff, but the "Mi día" tab loads a different feature module based on this enum.
 * Adding a value here = enabling its module slot. Adding a stub for the area follows
 * the pattern at apps/mobile/src/features/<area>/screens/Hub.tsx.
 * NOTE: this is the OPERATIONAL area, distinct from `role` (which is access level —
 * HOUSEKEEPER vs SUPERVISOR vs RECEPTIONIST).
 * Examples:
 * - Ana: role=SUPERVISOR, department=HOUSEKEEPING (supervisora de recamaristas)
 * - Carlos: role=RECEPTIONIST, department=RECEPTION
 * - Pedro: role=HOUSEKEEPER, department=HOUSEKEEPING
 * - (futuro) Ingeniero: role=SUPERVISOR, department=MAINTENANCE
 */
enum Department {
  HOUSEKEEPING
  MAINTENANCE
  LAUNDRY
  PUBLIC_AREAS
  GARDENING
  RECEPTION
  // futuros (cuando demanda lo justifique):
  // FOOD_AND_BEVERAGE
  // SPA
  // SECURITY
  // ACTIVITIES
  // ADMINISTRATION
}

