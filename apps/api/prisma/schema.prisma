// ─── SystemRole — extended for Nova foundation (Sprint NOVA-CHANNEX-COMMAND-CENTER) ───
// 2026-05-23 Late PM: agregados PLATFORM_ADMIN + PARTNER_ADMIN + PARTNER_MEMBER + ORG_OWNER
// para hierarchy 5-tier Nova. Valores legacy (OWNER/MANAGER/RECEPTIONIST/HOUSEKEEPER/
// TECHNICIAN/AUDITOR) se mantienen para backward-compat con código existente.
//
// Ver docs/architecture/NOVA-architecture.md §3 para schema completo y RBAC matrix.
// Decisión §160 D-NOVA-2 — Hierarchy 5-tier no-negociable.
enum SystemRole {
  // ── Tier 1: Platform (root) ──────────────────────
  PLATFORM_ADMIN // ZaharDev staff — único tier cross-Partner. Ver §161 D-NOVA-3.

  // ── Tier 2: Partner (consulting firm) ───────────
  PARTNER_ADMIN // Owner del partner firm. Gestiona PartnerMembers + assignments.
  PARTNER_MEMBER // Consultor individual; granularidad sub-rol via PartnerMember.role.

  // ── Tier 3: Organization (cliente hotelero) ─────
  ORG_OWNER // Dueño del hotel cliente (acceso pleno a su Org).

  // ── Tier 4: legacy roles dentro de Org/Property ─
  // Se mantienen para compatibilidad — son los ORG_STAFF de la hierarchy Nova.
  OWNER // legacy — alias de ORG_OWNER (compat)
  MANAGER
  RECEPTIONIST
  HOUSEKEEPER
  TECHNICIAN
  AUDITOR
}

// ─── PartnerTier — alineado con SAP PartnerEdge (§162 D-NOVA-4) ───
// 4 valores fijos. NUNCA renombrar — comparabilidad con industry partner programs
// (SAP/Cisco/Salesforce/Microsoft) facilita: (a) onboarding partners ex-SAP, (b)
// marketing pitch ("ya eres Gold en SAP — califica a Gold en Zenix").
enum PartnerTier {
  AUTHORIZED // entry tier: $0 annual fee, 10% revenue share
  SILVER // $1,200/año, 15% rev share + training credits
  GOLD // $3,600/año, 20% rev share + co-marketing fund
  PLATINUM // $9,600/año, 25% rev share + sub-partners + dedicated PM
}

// ─── PartnerMemberRole — granularidad interna del firm (§163 D-NOVA-5) ───
// 8 valores fijos alineados con SAP S/4HANA Implementation Roles + IBM BP Program +
// Cisco Partner Program. NUNCA cambiar nombres.
enum PartnerMemberRole {
  PARTNER_ADMIN // owner firma, gestiona team interno
  LEAD_CONSULTANT // senior, owns engagements
  SOLUTION_CONSULTANT // standard implementation
  SUPPORT_L1 // help desk básico
  SUPPORT_L2 // escalation
  SUPPORT_L3 // deep technical
  SALES_REP // demos + closing pre-venta
  TRAINEE // shadow access, no writes
}

// ─── PartnerMemberStatus — controlled vocabulary (Audit H3 fix 2026-05-24) ───
// Estado operativo del PartnerMember dentro de su firm.
// Reemplaza al `status String @default("ACTIVE")` original (text libre).
enum PartnerMemberStatus {
  ACTIVE // operacional, accesos completos
  INACTIVE // pausa temporal — sin login pero history preserved
  OFFBOARDING // proceso de salida en curso (compliance window)
