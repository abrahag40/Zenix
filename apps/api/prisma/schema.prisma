model PropertySettings {
  id                  String    @id @default(uuid())
  organizationId      String?   @map("organization_id")
  propertyId          String    @unique
  defaultCheckoutTime String    @default("11:00")
  timezone            String    @default("America/Cancun")
  pmsMode             String    @default("STANDALONE")
  // Night audit: hora local a partir de la cual se procesan no-shows (0-23).
  // El scheduler corre cada 30 min y verifica hora local por propiedad.
  // Default 2 = 02:00 AM local — permite late arrivals por vuelos retrasados.
  noShowCutoffHour    Int       @default(2) @map("no_show_cutoff_hour")
  // Fecha (solo date, no datetime) del último procesamiento de no-shows.
  // El scheduler la compara con la fecha local actual para evitar doble ejecución.
  noShowProcessedDate DateTime? @db.Date @map("no_show_processed_date")
  // Pre-arrival warning cron: hora local (0-23) a partir de la cual el cron detecta
  // potenciales no-shows (huéspedes que debían llegar pero no lo hicieron aún).
  // Default 20 = 8 PM local. Si enableAutoOutreach es true, se envía WhatsApp/email.
  potentialNoShowWarningHour    Int       @default(20) @map("potential_no_show_warning_hour")
  potentialNoShowProcessedDate  DateTime? @db.Date @map("potential_no_show_processed_date")
  enableAutoOutreach            Boolean   @default(false) @map("enable_auto_outreach")
  // Channex.io channel manager (Sprint 8): ID de la propiedad en Channex para push de inventario.
  // Opcional — sin él, pushInventory() es no-op (fail-soft).
  channexPropertyId             String?   @map("channex_property_id")
  // ── Sprint 8H — Housekeeping scheduling ───────────────────────────────────
  // Hora local (0-23) a la que el MorningRosterScheduler genera el roster del día.
  // Default 7 = 7:00 AM. Configurable per-property porque hostels vacacionales LATAM
  // suelen empezar 6 AM y boutique 8 AM.
  morningRosterHour             Int       @default(7) @map("morning_roster_hour")
  // Hora local (0-23) a la que termina el turno operativo de housekeeping.
  // Default 20 = 8 PM. Si un checkout (regular o early) ocurre a partir de esta
  // hora, la CleaningTask se programa para el grid del día siguiente — los
  // housekeepers ya están fuera de turno y crear tareas hoy genera ruido.
  housekeepingEndHour           Int       @default(20) @map("housekeeping_end_hour")
  // Idempotencia del cron — fecha local del último roster procesado.
  // Mismo patrón que noShowProcessedDate (§15 CLAUDE.md). El scheduler corre cada
  // 15 min y solo procesa si esta fecha != localDate actual.
  morningRosterDate             DateTime? @db.Date @map("morning_roster_date")
  // D-decisión: política de carryover de tareas incompletas del día anterior.
  carryoverPolicy               CarryoverPolicy @default(REASSIGN_TO_TODAY_SHIFT) @map("carryover_policy")
  // Toggle global para auto-asignación. Si false, todas las tareas nacen UNASSIGNED.
  autoAssignmentEnabled         Boolean   @default(true) @map("auto_assignment_enabled")
  // Si true, mobile pide clock-in al abrir y bloquea acciones hasta marcar entrada.
  shiftClockingRequired         Boolean   @default(false) @map("shift_clocking_required")

  // ── Sprint 9 / D14 — Stayover (in-house cleaning) policy ───────────────
  // Frecuencia de limpieza para camas ocupadas sin checkout planificado.
  // Default por PropertyType (en seed/factory): HOTEL→DAILY, HOSTAL→NEVER,
  // VACATION_RENTAL→NEVER. Configurable per-property desde Settings.
  stayoverFrequency  StayoverFrequency @default(NEVER) @map("stayover_frequency")
  // Hora local a la que el StayoverScheduler genera tareas (default 8 = 8 AM,
  // 1h después del MorningRoster para no competir).
  stayoverHour       Int               @default(8)     @map("stayover_hour")
  // Idempotencia per-day del scheduler — mismo patrón que morningRosterDate.
  stayoverProcessedDate DateTime?      @db.Date        @map("stayover_processed_date")
  // ── Sprint 9 — Reports / Revenue ──────────────────────────────────────────
  // Meta semanal de revenue para el frame "FORECAST SEMANA" del Revenue
  // Carousel mobile. Editable por admin desde Settings. Null = sin meta;
  // el frame se computa como porcentaje contra null hasta configurarse.
  weeklyRevenueTarget Decimal?  @db.Decimal(12, 2) @map("weekly_revenue_target")
  // Currency por defecto para revenue reports (no para folios — esos vienen
  // de la reserva). Default MXN. ISO 4217.
  reportCurrency      String    @default("MXN") @map("report_currency")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("property_settings")
}

// Política de carryover (D6 + decisión de usuario REASSIGN_TO_TODAY_SHIFT por default).
enum CarryoverPolicy {
  REASSIGN_TO_TODAY_SHIFT   // reasigna a quien esté en turno hoy (default operativo)
  KEEP_ORIGINAL_ASSIGNEE    // preserva original (si no en turno → UNASSIGNED)
  ALWAYS_UNASSIGNED         // estricto — supervisor reasigna manualmente
}

// D14 (CLAUDE.md §54) — Frecuencia de limpieza de estadía configurable per-property.
// Default por PropertyType en seed/factory (HOTEL=DAILY, HOSTAL/VR=NEVER).
enum StayoverFrequency {
  NEVER             // hostal LATAM default — solo limpieza de checkout
  DAILY             // hotel tradicional (AHLEI Sec. 4.2.1, Marriott/Hilton/IHG)
  EVERY_2_DAYS      // hotel eco-friendly (Marriott Bonvoy "Make a Green Choice")
  EVERY_3_DAYS      // extended-stay / hostel premium
  ON_REQUEST        // huésped opt-in via QR/web (Marriott Bonvoy 2022 standard)
  GUEST_PREFERENCE  // respeta GuestPreference per-stay (futuro — Roadmap P6)
}

