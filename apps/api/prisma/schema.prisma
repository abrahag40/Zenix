generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS =======================

enum AppNotificationType {
  INFORMATIONAL
  ACTION_REQUIRED
  APPROVAL_REQUIRED
}

enum AppNotificationCategory {
  CHECKIN_UNCONFIRMED
  EARLY_CHECKOUT
  NO_SHOW
  NO_SHOW_REVERTED
  ARRIVAL_RISK
  CHECKOUT_COMPLETE
  TASK_COMPLETED
  MAINTENANCE_REPORTED
  PAYMENT_PENDING
  SYSTEM
  // ── Sprint Mx-1 — Módulo de Mantenimiento ─────────────────────────────────
  // MAINTENANCE_TICKET_CRITICAL genera ACTION_REQUIRED automático al manager/supervisor
  // cuando el ticket se crea con priority=CRITICAL (inventario auto-bloqueado).
  MAINTENANCE_TICKET_CREATED   // ticket nuevo (MEDIUM/HIGH) — solo INFORMATIONAL
  MAINTENANCE_TICKET_UPDATED   // cambio de estado relevante (asignado, resuelto)
  MAINTENANCE_TICKET_CRITICAL  // CRITICAL → habitación bloqueada — ACTION_REQUIRED
  // ── Sprint 9 — D17 dual toast+panel persistence ──────────────────────────
  // TASK_VERIFIED_READY: housekeeping ciclo completado, recepción puede entregar
  // la habitación. Toast tier-2 (4s lateral) + entrada persistente en panel.
  // Auto-expira a las 4h para limpieza visual del feed (CLAUDE.md §57).
  TASK_VERIFIED_READY
}

enum AppNotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationRecipient {
  USER
  ROLE
  PROPERTY_ALL
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  ESCALATED
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
  BLOCKED
}

enum CleaningStatus {
  PENDING
  READY
  UNASSIGNED
  IN_PROGRESS
  PAUSED
  DONE
  VERIFIED
  CANCELLED
  // ── Sprint 9 / EC-6 — skip-and-retry (AHLEI Sec. 4.3) ────────────────────
  // DEFERRED: housekeeper tocó la puerta y nadie respondió, o el huésped
  // tiene chip DND físico. La tarea se reprograma automáticamente para
  // 30 min después (cron auto-retry). Tras 3 deferrals consecutivos →
  // BLOCKED (acción manual del supervisor).
  DEFERRED
  BLOCKED
}

// EC-6 — razones por las cuales una tarea se difiere temporalmente.
enum CleaningDeferReason {
  DND_PHYSICAL    // chip "do not disturb" colgado en la puerta
  NO_ANSWER       // tocó, nadie respondió
  GUEST_REQUEST   // huésped pidió "vuelve más tarde"
}

enum HousekeepingRole {
  HOUSEKEEPER
  SUPERVISOR
  RECEPTIONIST
}

/**
 * Department — operational area within a hotel property.
 *
 * Sprint 8I "shared chrome + role-aware module" (CLAUDE.md / ARCHITECTURE.md AD-011):
 * the mobile app shows the same chrome (tabs, dashboard, notifications, profile) for
 * all staff, but the "Mi día" tab loads a different feature module based on this enum.
 *
 * Adding a value here = enabling its module slot. Adding a stub for the area follows
 * the pattern at apps/mobile/src/features/<area>/screens/Hub.tsx.
 *
 * NOTE: this is the OPERATIONAL area, distinct from `role` (which is access level —
 * HOUSEKEEPER vs SUPERVISOR vs RECEPTIONIST).
 *
 * Examples:
 *   - Ana: role=SUPERVISOR, department=HOUSEKEEPING (supervisora de recamaristas)
 *   - Carlos: role=RECEPTIONIST, department=RECEPTION
 *   - Pedro: role=HOUSEKEEPER, department=HOUSEKEEPING
 *   - (futuro) Ingeniero: role=SUPERVISOR, department=MAINTENANCE
 */
enum Department {
  HOUSEKEEPING
  MAINTENANCE
  LAUNDRY
  PUBLIC_AREAS
  GARDENING
  RECEPTION
  // futuros (cuando demanda lo justifique):
  // FOOD_AND_BEVERAGE
  // SPA
  // SECURITY
  // ACTIVITIES
  // ADMINISTRATION
}

enum RoomCategory {
  PRIVATE
  SHARED
}

enum TaskType {
  CLEANING
  SANITIZATION
  MAINTENANCE
  PREPARATION
  // ── Sprint 9 / D14 — limpieza de estadía (in-house cleaning) ──────────────
  // Generada por StayoverScheduler para camas con bed.status=OCCUPIED y
  // sin checkout planificado para hoy. Frecuencia configurable per-property
  // via PropertySettings.stayoverFrequency.
  STAYOVER
}

enum Capability {
  CLEANING
  SANITIZATION
  MAINTENANCE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskLogEvent {
  CREATED
  ASSIGNED
  READY
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  VERIFIED
  CANCELLED
  REOPENED
  NOTE_ADDED
  // ── Sprint 8H — housekeeping scheduling ───────────────────────────────────
  AUTO_ASSIGNED      // auto-asignación por AssignmentService
  CARRYOVER          // tarea movida del día anterior por MorningRosterScheduler
  REASSIGNED         // cambio de assignedToId post-creación (ausencia/manual)
  CLOCKED_BY_STAFF   // clock-in del staff vinculado a esta tarea
  // ── Sprint 9 — flow refactor ──────────────────────────────────────────────
  STAYOVER_CREATED          // tarea STAYOVER generada por StayoverScheduler
  DEFERRED                  // EC-6 — housekeeper difirió la tarea (DND/no-answer/guest-request)
  RETRY_SCHEDULED           // cron auto-retry promovió DEFERRED → READY/UNASSIGNED
  BLOCKED                   // 3 deferrals consecutivos → acción manual del supervisor
  LATE_CHECKOUT_RESCHEDULED // EC-3 — recepción aprobó late-checkout, scheduledCheckout movido
  // ── Sprint 9 / D15 — Operational overrides (recepción) ──────────────────
  PRIORITY_OVERRIDDEN       // recepción forzó URGENT desde Ajustes del día
  DEEP_CLEAN_FLAGGED        // tarea marcada para limpieza profunda
  WALK_IN_CREATED           // walk-in checkout creado ad-hoc
  HOLD_PLACED               // recepción puso hold por extensión sin formalizar
  HOLD_RELEASED             // recepción liberó el hold
}

// ── Sprint 8H — Cleaning task cancellation reason / extension flag (D12) ────
enum CleaningCancelReason {
  EXTENSION_NO_CLEANING     // huésped extendió y no pidió limpieza (queda visible en mobile como badge)
  EXTENSION_WITH_CLEANING   // huésped extendió pero pidió limpieza (no debería aparecer cancelada — sólo si flow lo requiere)
  GUEST_NEVER_CHECKED_IN    // no-show o cancelación
  RECEPTIONIST_MANUAL       // cancelación operativa estándar
  STAFF_ABSENCE_CLEANUP     // sin personal disponible al final del día
  DUPLICATE                 // tarea duplicada por error/race condition
}

enum ExtensionFlag {
  WITH_CLEANING             // mantener tarea activa, push al housekeeper
  WITHOUT_CLEANING          // cancelar pero mantener visible en mobile como badge
}

enum CheckoutSource {
  MANUAL
  SYSTEM
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  FURNITURE
  PEST
  OTHER
}

enum DiscrepancyType {
  BED_STATUS_MISMATCH
  GUEST_EXTENSION
  UNEXPECTED_OCCUPANCY
  OTHER
}

