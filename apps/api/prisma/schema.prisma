generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS =======================

enum AppNotificationType {
  INFORMATIONAL
  ACTION_REQUIRED
  APPROVAL_REQUIRED
}

enum AppNotificationCategory {
  CHECKIN_UNCONFIRMED
  EARLY_CHECKOUT
  NO_SHOW
  NO_SHOW_REVERTED
  ARRIVAL_RISK
  CHECKOUT_COMPLETE
  TASK_COMPLETED
  MAINTENANCE_REPORTED
  PAYMENT_PENDING
  SYSTEM
  // ── Sprint Mx-1 — Módulo de Mantenimiento ─────────────────────────────────
  // MAINTENANCE_TICKET_CRITICAL genera ACTION_REQUIRED automático al manager/supervisor
  // cuando el ticket se crea con priority=CRITICAL (inventario auto-bloqueado).
  MAINTENANCE_TICKET_CREATED // ticket nuevo (MEDIUM/HIGH) — solo INFORMATIONAL
  MAINTENANCE_TICKET_UPDATED // cambio de estado relevante (asignado, resuelto)
  MAINTENANCE_TICKET_CRITICAL // CRITICAL → habitación bloqueada — ACTION_REQUIRED
  MAINTENANCE_TICKET_NEEDS_APPROVAL // Flujo B — supervisor debe aprobar/rechazar
  MAINTENANCE_TICKET_ASSIGNED // técnico recibe asignación (manual o auto)
  MAINTENANCE_TICKET_RESOLVED // supervisor recibe RESOLVED para verificación
  MAINTENANCE_TICKET_VERIFIED // técnico recibe que su trabajo fue verificado
  MAINTENANCE_TICKET_QUEUED // ticket entró a la cola sin asignar (pool)
  MAINTENANCE_SLA_BREACH // scheduler — supervisor recibe SLA vencido
  // ── Sprint 9 — D17 dual toast+panel persistence ──────────────────────────
  // TASK_VERIFIED_READY: housekeeping ciclo completado, recepción puede entregar
  // la habitación. Toast tier-2 (4s lateral) + entrada persistente en panel.
  // Auto-expira a las 4h para limpieza visual del feed (CLAUDE.md §57).
  TASK_VERIFIED_READY
  // ── Sprint 9 — Late checkout escalation (cron LateCheckoutScheduler) ─
  // T1: notif al RECEPTIONIST cuando una stay pasa scheduledCheckout +
  //     lateCheckoutGraceMinutes sin actualCheckout.
  // T2: notif URGENT al SUPERVISOR cuando pasa lateCheckoutEscalationMinutes.
  LATE_CHECKOUT_PENDING
  LATE_CHECKOUT_ESCALATED
  // ── Sprint CANCEL-ARCHIVE 2026-05-16 ────────────────────────────────────
  // Notif al SUPERVISOR cuando una reserva se cancela. Self-suppress aplica
  // — el actor que canceló NO recibe la notif. Priority varía por initiator:
  // ADMIN_ERROR / HOTEL = HIGH (anómalos), OTA = MEDIUM, GUEST = LOW.
  STAY_CANCELLED
  STAY_RESTORED
}

