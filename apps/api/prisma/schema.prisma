// ===================== PRE-CHECKIN QUALITY SYSTEM =====================
//
// Restaurado desde migration 20260402192948_add_pre_checkin_quality_system.
// Workflow: al hacer checkout de un huésped (OnEvent 'checkout.confirmed'),
// se crea automáticamente un RoomReadinessTask con items copiados del
// RoomTypeChecklist activo para la propiedad. Housekeeping los marca (PENDING
// → DONE | ISSUE_FOUND | SKIPPED) antes del siguiente check-in.

enum ReadinessStatus {
  PENDING
  IN_PROGRESS
  NEEDS_MAINTENANCE
  READY
  APPROVED
}

enum ItemStatus {
  PENDING
  DONE
  ISSUE_FOUND
  SKIPPED
}

model RoomTypeChecklist {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  roomTypeId     String?  @map("room_type_id")
  name           String
  triggerOn      String   @default("checkout")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization       @relation(fields: [organizationId], references: [id])
  items          ChecklistItem[]
  readinessTasks RoomReadinessTask[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_type_checklists")
}

model ChecklistItem {
  id            String   @id @default(uuid())
  checklistId   String   @map("checklist_id")
  category      String
  description   String
  isRequired    Boolean  @default(true) @map("is_required")
  requiresPhoto Boolean  @default(false) @map("requires_photo")
  sortOrder     Int      @default(0) @map("sort_order")

  checklist  RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  taskItems  RoomReadinessTaskItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model RoomReadinessTask {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  propertyId     String          @map("property_id")
  roomId         String          @map("room_id")
  checklistId    String          @map("checklist_id")
  assignedToId   String?         @map("assigned_to_id")
  triggeredBy    String          @map("triggered_by")
  status         ReadinessStatus @default(PENDING)
  dueBy          DateTime?       @map("due_by")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id])
  room         Room                    @relation(fields: [roomId], references: [id])
  checklist    RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  items        RoomReadinessTaskItem[]

  @@index([organizationId])
  @@index([roomId, status])
  @@map("room_readiness_tasks")
}

model RoomReadinessTaskItem {
  id                   String     @id @default(uuid())
  taskId               String     @map("task_id")
  checklistItemId      String     @map("checklist_item_id")
  status               ItemStatus @default(PENDING)
  completedById        String?    @map("completed_by_id")
  completedAt          DateTime?  @map("completed_at")
  photoUrl             String?    @map("photo_url")
  notes                String?
  // ── Sprint Mx-1 — vínculo con ticket levantado al detectar problema ─────
  // El housekeeper marca un item del checklist como "issue detected" → se crea
  // automáticamente un MaintenanceTicket con sourceTaskId = task.cleaningTaskId
  // (si aplica) y se guarda el id aquí para auditoría inversa.
  maintenanceTicketId  String?    @map("maintenance_ticket_id")

  task              RoomReadinessTask  @relation(fields: [taskId], references: [id])
  checklistItem     ChecklistItem      @relation(fields: [checklistItemId], references: [id])
  maintenanceTicket MaintenanceTicket? @relation("ItemMaintenanceTicket", fields: [maintenanceTicketId], references: [id])

  @@index([taskId])
  @@index([maintenanceTicketId])
  @@map("room_readiness_task_items")
}

// ======================== STAY JOURNEY MODEL =========================
//
// Restaurado desde migration 20260410000000_add_stay_journey_model.
// Modela una estadía completa como journey + segmentos (permite extensiones
// y mudanzas de habitación) + nights (ingresos diarios para reporting).

enum StayJourneyStatus {
  ACTIVE
  CHECKED_OUT
  CANCELLED
  NO_SHOW

  @@map("stay_journey_status")
}

enum SegmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("segment_status")
}

enum SegmentReason {
  ORIGINAL
  EXTENSION_SAME_ROOM
  EXTENSION_NEW_ROOM
  ROOM_MOVE
  SPLIT

  @@map("segment_reason")
}

enum NightStatus {
  PENDING
  POSTED
  LOCKED

  @@map("night_status")
}

enum JourneyEventType {
  JOURNEY_CREATED
  SEGMENT_ADDED
  SEGMENT_LOCKED
  ROOM_MOVE_EXECUTED
  EXTENSION_APPROVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW_MARKED
  NO_SHOW_REVERTED
  JOURNEY_SPLIT

  @@map("journey_event_type")
}

// ── Payment method for front-desk transactions ────────────────────────────────
// CARD_TERMINAL: POS físico externo — Zenix guarda solo el número de referencia
// del comprobante, nunca datos de tarjeta (PCI DSS fuera de alcance para TERMINAL).
enum PaymentMethod {
  CASH
  CARD_TERMINAL
  BANK_TRANSFER
  OTA_PREPAID
  COMP

  @@map("payment_method")
}

// ── Tipo de acceso físico entregado al huésped en check-in ────────────────────
enum KeyDeliveryType {
  PHYSICAL  // llave física tradicional
  CARD      // tarjeta magnética / RFID
  CODE      // PIN / código numérico
  MOBILE    // link o app móvil

  @@map("key_delivery_type")
}

// ── No-Show charge lifecycle ──────────────────────────────────────────────────
// NOT_APPLICABLE → policy = NONE (tarifa gratuita)
// PENDING        → registrado, esperando procesamiento de pago
// CHARGED        → cobro procesado exitosamente
// FAILED         → tarjeta rechazada (requiere acción manual)
// WAIVED         → exonerado por supervisor (fee perdonado)
enum NoShowChargeStatus {
  NOT_APPLICABLE
  PENDING
  CHARGED
  FAILED
  WAIVED
}

model StayJourney {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  propertyId      String            @map("property_id")
  guestStayId     String?           @unique @map("guest_stay_id")
  guestName       String            @map("guest_name")
  guestEmail      String?           @map("guest_email")
  status          StayJourneyStatus @default(ACTIVE)
  journeyCheckIn  DateTime          @map("journey_check_in")
  journeyCheckOut DateTime          @map("journey_check_out")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  property     Property           @relation(fields: [propertyId], references: [id])
  guestStay    GuestStay?         @relation(fields: [guestStayId], references: [id])
  segments     StaySegment[]
  events       StayJourneyEvent[]

  @@index([organizationId, status])
  @@index([propertyId, journeyCheckIn, journeyCheckOut])
  @@map("stay_journeys")
}

model StaySegment {
  id           String        @id @default(uuid())
  journeyId    String        @map("journey_id")
  roomId       String        @map("room_id")
  guestStayId  String?       @map("guest_stay_id")
  checkIn      DateTime      @map("check_in")
  checkOut     DateTime      @map("check_out")
  status       SegmentStatus @default(PENDING)
  locked       Boolean       @default(false)
  reason       SegmentReason @default(ORIGINAL)
  rateSnapshot Decimal?      @map("rate_snapshot") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  journey   StayJourney    @relation(fields: [journeyId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  guestStay GuestStay?     @relation(fields: [guestStayId], references: [id])
  nights    SegmentNight[]

  @@index([journeyId])
  @@index([roomId, checkIn, checkOut])
  @@index([status, locked])
  @@map("stay_segments")
}

model SegmentNight {
  id        String      @id @default(uuid())
  segmentId String      @map("segment_id")
  date      DateTime    @db.Date
  rate      Decimal     @db.Decimal(10, 2)
  status    NightStatus @default(PENDING)
  locked    Boolean     @default(false)

  segment StaySegment @relation(fields: [segmentId], references: [id])

  @@unique([segmentId, date])
  @@index([date])
  @@index([segmentId, locked])
  @@map("segment_nights")
}

model StayJourneyEvent {
  id         String           @id @default(uuid())
  journeyId  String           @map("journey_id")
  eventType  JourneyEventType @map("event_type")
  actorId    String?          @map("actor_id")
  payload    Json
  occurredAt DateTime         @default(now()) @map("occurred_at")

  journey StayJourney @relation(fields: [journeyId], references: [id])

  @@index([journeyId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("stay_journey_events")
}

// ======================= SMARTBLOCK =======================

enum BlockSemantic {
  OUT_OF_SERVICE
  OUT_OF_ORDER
  OUT_OF_INVENTORY
  HOUSE_USE
}

enum BlockReason {
  MAINTENANCE
  DEEP_CLEANING
  INSPECTION
  PHOTOGRAPHY
  VIP_SETUP
  PEST_CONTROL
  WATER_DAMAGE
  ELECTRICAL
  PLUMBING
  STRUCTURAL
  RENOVATION
  OWNER_STAY
  STAFF_USE
  OTHER
}

enum BlockStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EXPIRED
  CANCELLED
  REJECTED
}

enum BlockLogEvent {
  CREATED
  APPROVED
  REJECTED
  ACTIVATED
  EXTENDED
  EARLY_RELEASE
  CANCELLED
  EXPIRED
  NOTE_ADDED
}

/**
 * RoomBlock — bloqueo de unidad o habitación con workflow de aprobación.
 *
 * Granularidad:
 *   unitId != null → bloqueo de unidad individual (dormitorios compartidos)
 *   unitId == null → bloqueo de habitación completa
 *
 * Semánticas:
 *   OUT_OF_SERVICE   → problema menor, no impacta RevPAR
 *   OUT_OF_ORDER     → inhabilitada, impacta RevPAR, requiere aprobación
 *   OUT_OF_INVENTORY → largo plazo, excluida del inventario operativo
 *   HOUSE_USE        → uso interno (fotos, staff)
 *
 * Al activarse (APPROVED → ACTIVE):
 *   1. Se crea CleaningTask(MAINTENANCE, UNASSIGNED)
 *   2. unit.status = BLOCKED
 *   3. SSE: block:activated
 *
 * Auto-aprobación:
 *   OOS + actor = SUPERVISOR → APPROVED inmediato (sin pasar por PENDING)
 *   HOUSE_USE + actor = SUPERVISOR → APPROVED inmediato
 *   Cualquier otro caso → PENDING_APPROVAL
 */
model RoomBlock {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  propertyId     String        @map("property_id")
  roomId         String?       @map("room_id")   // null = solo unidad
  unitId         String?       @map("unit_id")   // null = habitación completa

  semantic       BlockSemantic
  reason         BlockReason
  status         BlockStatus   @default(PENDING_APPROVAL)

  notes          String?                        // visible para housekeeping
  internalNotes  String?       @map("internal_notes") // solo supervisores

  startDate      DateTime      @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date")   @db.Date // null = indefinido

  requestedById  String        @map("requested_by_id")
  approvedById   String?       @map("approved_by_id")
  approvalNotes  String?       @map("approval_notes")
  approvedAt     DateTime?     @map("approved_at")

  // Tarea de mantenimiento creada automáticamente al activar el bloqueo
  cleaningTaskId String?       @unique @map("cleaning_task_id")

  // ── Sprint Mx-1 — Mantenimiento (Bridge crítico inventario ↔ tickets) ───
  // FK al ticket que disparó este bloqueo automático (TicketPriority.CRITICAL).
  // Se coloca del lado del bloque para evitar dependencia FK circular con
  // MaintenanceTicket. La reverse relation `MaintenanceTicket.autoBlock` no
  // tiene FK propia. @unique garantiza 1 bloque automático por ticket.
  maintenanceTicketId String? @unique @map("maintenance_ticket_id")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization      @relation(fields: [organizationId], references: [id])
  room           Room?             @relation(fields: [roomId], references: [id])
  unit           Unit?             @relation(fields: [unitId], references: [id])
  requestedBy    HousekeepingStaff @relation("BlocksRequested", fields: [requestedById], references: [id])
  approvedBy     HousekeepingStaff? @relation("BlocksApproved", fields: [approvedById], references: [id])
  cleaningTask   CleaningTask?     @relation("BlockTask", fields: [cleaningTaskId], references: [id])
  maintenanceTicket MaintenanceTicket? @relation("BlockMaintenanceTicket", fields: [maintenanceTicketId], references: [id])
  logs           BlockLog[]

  @@index([organizationId, propertyId, status])
  @@index([unitId, status])
  @@index([roomId, status])
  @@index([startDate, endDate])
  @@map("room_blocks")
}

/**
 * BlockLog — bitácora inmutable de cambios de estado.
 * staffId es null para eventos del sistema (cron, auto-activación).
 */
model BlockLog {
  id        String        @id @default(uuid())
  blockId   String        @map("block_id")
  staffId   String?       @map("staff_id")
  event     BlockLogEvent
  note      String?
  metadata  Json?         // contexto adicional: { previousStatus, reason, etc }
  createdAt DateTime      @default(now()) @map("created_at")

  block   RoomBlock          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  staff   HousekeepingStaff? @relation("BlockLogs", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([blockId])
  @@index([createdAt])
  @@map("block_logs")
}

// ── Guest contact channel ─────────────────────────────────────────────────────
enum ContactChannel {
  WHATSAPP
  EMAIL
  PHONE
}

// ── Guest contact log (append-only, for dispute documentation) ───────────────
// Cada intento de contacto queda registrado: quién lo hizo, cuándo, por qué canal.
// Usar como evidencia ante chargebacks u otras disputas con OTAs.
model GuestContactLog {
  id             String         @id @default(uuid())
  stayId         String         @map("stay_id")
  channel        ContactChannel
  // sentById es null para envíos automáticos del sistema (cron de potencial no-show).
  // Non-null para envíos manuales desde BookingDetailSheet (recepcionista identificado).
  sentById       String?        @map("sent_by_id")
  sentAt         DateTime       @default(now()) @map("sent_at")
  messagePreview String?        @map("message_preview")

  stay   GuestStay          @relation(fields: [stayId], references: [id])
  sentBy HousekeepingStaff? @relation("ContactLogs", fields: [sentById], references: [id])

  @@index([stayId])
  @@index([sentAt])
  @@map("guest_contact_logs")
}

// ======================= NOTIFICATION CENTER =======================
//
// Persistent, stored notifications with full audit trail (Facebook-style).
// Separate from NotificationsModule which provides ephemeral SSE streaming.
//
// Recipient targeting:
//   USER         → recipientId = staffId (personal notification)
//   ROLE         → recipientRole = HousekeepingRole (fan-out to role)
//   PROPERTY_ALL → all staff in the property
//
// Type lifecycle:
//   INFORMATIONAL    → read-only, no action needed
//   ACTION_REQUIRED  → surfaced prominently until read
//   APPROVAL_REQUIRED → records decision in AppNotificationApproval

model AppNotification {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  propertyId     String?                   @map("property_id")
  type           AppNotificationType
  category       AppNotificationCategory
  priority       AppNotificationPriority   @default(MEDIUM)
  title          String
  body           String
  metadata       Json?
  actionUrl      String?                   @map("action_url")
  recipientType  NotificationRecipient     @map("recipient_type")
  recipientId    String?                   @map("recipient_id")
  recipientRole  HousekeepingRole?         @map("recipient_role")
  triggeredById  String?                   @map("triggered_by_id")
  expiresAt      DateTime?                 @map("expires_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  organization   Organization              @relation(fields: [organizationId], references: [id])
  property       Property?                 @relation(fields: [propertyId], references: [id])
  triggeredBy    HousekeepingStaff?        @relation("NotifTriggeredBy", fields: [triggeredById], references: [id])
  reads          AppNotificationRead[]
  approvals      AppNotificationApproval[]

  @@index([organizationId, propertyId, createdAt(sort: Desc)])
  @@index([recipientId])
  @@index([recipientRole])
  @@map("app_notifications")
}

model AppNotificationRead {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  readById       String              @map("read_by_id")
  readAt         DateTime            @default(now()) @map("read_at")

  notification   AppNotification     @relation(fields: [notificationId], references: [id])
  readBy         HousekeepingStaff   @relation("NotifReadBy", fields: [readById], references: [id])

  @@unique([notificationId, readById])
  @@map("app_notification_reads")
}

model AppNotificationApproval {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  action         ApprovalDecision
  actionById     String              @map("action_by_id")
  actionAt       DateTime            @default(now()) @map("action_at")
  reason         String?

  notification   AppNotification     @relation(fields: [notificationId], references: [id])
  actionBy       HousekeepingStaff   @relation("NotifApprovedBy", fields: [actionById], references: [id])

  @@map("app_notification_approvals")
}

// ======================= PAYMENT LOG =======================
//
// Registro inmutable de pagos recibidos en recepción (USALI-compliant).
// Reglas de inmutabilidad:
//   - No hay campo updatedAt — Prisma no genera rutas UPDATE para este modelo.
//   - La capa de servicio solo permite create(). Nunca update().
//   - Las anulaciones crean un nuevo registro con isVoid=true y amount negativo.
//   - El registro original permanece intacto (trail auditnable).
//
// Anti-fraude:
//   - collectedById identifica al recepcionista que cobró.
//   - COMP / amount=0 requieren approvedById + approvalReason obligatorios.
//   - shiftDate permite reconciliar por turno: sum(CASH, isVoid=false) vs. efectivo físico.
//   - reference = número de autorización del terminal (6-8 dígitos del comprobante),
//     nunca PAN / CVV / track data. Zenix está fuera del flujo de datos de tarjeta.

model PaymentLog {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  propertyId     String        @map("property_id")
  stayId         String        @map("stay_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("MXN")
  reference      String?                           // autorización terminal / referencia bancaria
  approvedById   String?       @map("approved_by_id")
  approvalReason String?       @map("approval_reason")
  isVoid         Boolean       @default(false) @map("is_void")
  voidedAt       DateTime?     @map("voided_at")
  voidedById     String?       @map("voided_by_id")
  voidReason     String?       @map("void_reason")
  voidsLogId     String?       @unique @map("voids_log_id")
  shiftDate      DateTime      @db.Date @map("shift_date")
  collectedById  String        @map("collected_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")

  stay         GuestStay            @relation(fields: [stayId], references: [id])
  collectedBy  HousekeepingStaff    @relation("PaymentCollectedBy", fields: [collectedById], references: [id])
  approvedBy   HousekeepingStaff?   @relation("PaymentApprovedBy", fields: [approvedById], references: [id])
  voidedBy     HousekeepingStaff?   @relation("PaymentVoidedBy", fields: [voidedById], references: [id])
  voidsEntry   PaymentLog?          @relation("VoidOf", fields: [voidsLogId], references: [id])
  voidedByLog  PaymentLog?          @relation("VoidOf")

  @@index([stayId])
  @@index([organizationId, propertyId, shiftDate])
  @@index([collectedById, shiftDate])
  @@map("payment_logs")
}

// ======================= HOUSEKEEPING SCHEDULING (Sprint 8H) =======================
//
// Modelos que sustentan el módulo de recamaristas como diferenciador competitivo:
//   StaffShift            — turno semanal recurrente
//   StaffShiftException   — excepción puntual (vacación, día libre, turno extra)
//   StaffCoverage         — cobertura habitación↔staff (primary/backup)
//   StaffShiftClock       — clock-in/out real (USALI compliance)
//   StaffPreferences      — preferencias del staff (gamificación gestionada por supervisor)
//   StaffPreferenceLog    — audit append-only de cambios a preferences
//
// Decisiones documentadas en CLAUDE.md §35-§46 (D1-D12) y plan vamos-a-comenzar-a-federated-kitten.md.

/**
 * StaffShift — turno semanal recurrente del staff. Fuente de verdad de "quién está en turno".
 * Las excepciones puntuales viven en StaffShiftException (D5: ausencia explícita, etc.)
 *
 * Ejemplo: María trabaja Lun-Vie 7-15.
 *   { staffId: 'maria', dayOfWeek: 1, startTime: '07:00', endTime: '15:00', active: true }
 *   { staffId: 'maria', dayOfWeek: 2, ... }
 *   ...
 */
model StaffShift {
  id              String    @id @default(uuid())
  organizationId  String?   @map("organization_id")
  propertyId      String    @map("property_id")
  staffId         String    @map("staff_id")
  dayOfWeek       Int       @map("day_of_week")        // 0 (Sun) - 6 (Sat)
  startTime       String    @map("start_time")          // "HH:mm" — local de la propiedad
  endTime         String    @map("end_time")            // "HH:mm" — local de la propiedad
  effectiveFrom   DateTime  @db.Date @map("effective_from")
  effectiveUntil  DateTime? @db.Date @map("effective_until")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization?     @relation(fields: [organizationId], references: [id])
  property     Property          @relation(fields: [propertyId], references: [id])
  staff        HousekeepingStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([propertyId, dayOfWeek, active])
  @@index([staffId, active])
  @@map("staff_shifts")
}

enum ShiftExceptionType {
  OFF        // día libre solicitado / ausencia
  EXTRA      // turno adicional cubriendo a alguien
  MODIFIED   // misma fecha pero distintas horas
}

/**
 * StaffShiftException — excepción puntual al horario semanal (D5).
 * Tipo OFF se usa también para registrar AUSENCIAS marcadas por el receptionist
 * a través del endpoint POST /v1/scheduling/absences.
 */
model StaffShiftException {
  id           String             @id @default(uuid())
  staffId      String             @map("staff_id")
  date         DateTime           @db.Date
  type         ShiftExceptionType
  startTime    String?            @map("start_time")    // null si OFF
  endTime      String?            @map("end_time")
  reason       String?
  approvedById String?            @map("approved_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  staff      HousekeepingStaff  @relation("ShiftExceptionsForStaff", fields: [staffId], references: [id], onDelete: Cascade)
  approvedBy HousekeepingStaff? @relation("ShiftExceptionsApprovedBy", fields: [approvedById], references: [id])

  @@unique([staffId, date])
  @@index([date])
  @@map("staff_shift_exceptions")
}

/**
 * StaffCoverage — qué habitaciones limpia esta recamarista por defecto (D5: soft, no hard).
 * Una habitación puede tener múltiples staff cubriéndola: 1 primary + N backups.
 *
 * El AssignmentService prefiere primary; si no en turno, baja a backup; si nadie cubre, round-robin.
 */
model StaffCoverage {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  staffId     String   @map("staff_id")
  roomId      String   @map("room_id")
  isPrimary   Boolean  @default(true) @map("is_primary")
  weight      Int      @default(1)                       // tiebreaker para round-robin secundario
  createdAt   DateTime @default(now()) @map("created_at")

  property Property          @relation(fields: [propertyId], references: [id])
  staff    HousekeepingStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  room     Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // Un staff no puede tener dos coverages para la misma room en el mismo nivel (primary vs backup).
  @@unique([staffId, roomId, isPrimary])
  @@index([propertyId, roomId])
  @@index([roomId, isPrimary])
  @@map("staff_coverages")
}

enum ClockSource {
  MOBILE
  WEB
  MANUAL_SUPERVISOR
}

/**
 * StaffShiftClock — registro real de clock-in/out (USALI auditability).
 * Append-only: nunca se actualiza un clock-in pasado.
 * Para correcciones, el supervisor crea un nuevo registro con source=MANUAL_SUPERVISOR.
 */
model StaffShiftClock {
  id         String      @id @default(uuid())
  staffId    String      @map("staff_id")
  propertyId String      @map("property_id")
  clockInAt  DateTime    @map("clock_in_at")
  clockOutAt DateTime?   @map("clock_out_at")
  source     ClockSource
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")

  staff    HousekeepingStaff @relation(fields: [staffId], references: [id])
  property Property          @relation(fields: [propertyId], references: [id])

  @@index([staffId, clockInAt])
  @@index([propertyId, clockInAt])
  @@map("staff_shift_clocks")
}

enum GamificationLevel {
  OFF
  SUBTLE
  STANDARD
}

/**
 * StaffPreferences — preferencias del staff. NOTA: gamificationLevel solo es
 * editable por SUPERVISOR (D9). El staff puede leer su propio registro pero no
 * escribirlo. hapticEnabled / soundEnabled SÍ son self-managed.
 */
model StaffPreferences {
  id                String            @id @default(uuid())
  staffId           String            @unique @map("staff_id")
  gamificationLevel GamificationLevel @default(STANDARD) @map("gamification_level")
  language          String            @default("es-MX")
  hapticEnabled     Boolean           @default(true) @map("haptic_enabled")
  soundEnabled      Boolean           @default(true) @map("sound_enabled")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  staff HousekeepingStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  logs  StaffPreferenceLog[]

  @@map("staff_preferences")
}

/**
 * StaffPreferenceLog — append-only log de cambios a StaffPreferences.
 * Cumple USALI auditability + traza decisiones laborales (quién cambió qué, cuándo, por qué).
 * Útil para cumplir LFPDPPP MX / GDPR / LGPD si un staff cuestiona la configuración.
 */
model StaffPreferenceLog {
  id            String   @id @default(uuid())
  preferencesId String   @map("preferences_id")
  staffId       String   @map("staff_id")          // denormalizado para queries directas
  field         String                              // 'gamificationLevel' | 'language' | etc.
  oldValue      String?  @map("old_value")
  newValue      String   @map("new_value")
  changedById   String   @map("changed_by_id")     // siempre presente — sin cambios automáticos
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")

  preferences StaffPreferences  @relation(fields: [preferencesId], references: [id], onDelete: Cascade)
  changedBy   HousekeepingStaff @relation("PreferenceChangesByStaff", fields: [changedById], references: [id])

  @@index([staffId, createdAt])
  @@map("staff_preference_logs")
}

// ============================================================================
// SPRINT 9 — REPORTS / CHANNEL COMMISSIONS
// ============================================================================

/**
 * ChannelCommission — comisión que cada OTA cobra por reserva.
 *
 * Justificación (CLAUDE.md §29 + revenue-data-mapping.md):
 *   - Booking típicamente 15%, Airbnb 14-16%, Expedia 18-22%
 *   - El % varía por contrato y temporada — no es constante
 *   - Necesario para el frame "COMISIONES OTA HOY" del Revenue Carousel
 *   - Histórico relevante (effectiveFrom/effectiveUntil) para reportes
 *     fiscales correctos cuando un cliente revisa períodos pasados
 *
 * Source uses the same string values as GuestStay.source.
 * Sprint 9+ podríamos migrar a un enum BookingSource compartido.
 *
 * Lookup pattern:
 *   const rate = await prisma.channelCommission.findFirst({
 *     where: {
 *       propertyId,
 *       source: 'BOOKING',
 *       effectiveFrom: { lte: targetDate },
 *       OR: [{ effectiveUntil: null }, { effectiveUntil: { gt: targetDate } }],
 *     },
 *     orderBy: { effectiveFrom: 'desc' },
 *   })
 */
model ChannelCommission {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  propertyId     String    @map("property_id")
  /** Channel source (matches GuestStay.source string values). */
  source         String    // 'BOOKING' | 'AIRBNB' | 'EXPEDIA' | 'HOSTELWORLD' | etc.
  /** Commission rate as percent (e.g., 15.00 for 15%). Stored as Decimal
   *  for exact arithmetic (CLAUDE.md §17 — no float for money). */
  ratePercent    Decimal   @db.Decimal(5, 2) @map("rate_percent")
  /** Effective period — supports historical lookups for past reports. */
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveUntil DateTime? @map("effective_until") @db.Date
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([propertyId, source, effectiveFrom])
  @@map("channel_commissions")
}

// ============================================================================
// SPRINT 8I-J — HUB RECAMARISTA · GAMIFICACIÓN (privacy-respecting)
// ============================================================================
//
// Anclado a docs/research-housekeeping-hub.md.
// Principios SDT (Deci & Ryan 1985) + privacy peer-to-peer estricta (D9).
//
// NUNCA expuestos a pares ni listados públicamente. Solo:
//   - El propio staff (en su Hub)
//   - Su supervisor (audit trail / coaching)

/**
 * StaffStreak — racha diaria estilo Duolingo, sin shame al romperse.
 *
 * Loss aversion suave (Tversky-Kahneman 1979): el usuario no quiere
 * romper su racha. Pero usamos `freezesTotal` (2/mes) para vacaciones
 * o ausencias justificadas — autonomía SDT preservada.
 */
model StaffStreak {
  id              String    @id @default(uuid())
  staffId         String    @unique @map("staff_id")
  /** Días consecutivos con al menos 1 tarea completada (o freeze activo). */
  currentDays     Int       @default(0) @map("current_days")
  /** Récord histórico — para celebrar al superarlo (Strava-style). */
  longestDays     Int       @default(0) @map("longest_days")
  /** Última fecha (DATE local) en que el staff trabajó tareas. */
  lastWorkDate    DateTime? @db.Date @map("last_work_date")
  /** Freezes usados este mes — ausencias que no rompen la racha. */
  freezesUsed     Int       @default(0) @map("freezes_used")
  /** Budget mensual de freezes. Default 2 — generoso pero acotado. */
  freezesTotal    Int       @default(2) @map("freezes_total")
  /** Reset mensual del contador de freezes (1° del mes). */
  freezesResetAt  DateTime? @db.Date @map("freezes_reset_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  staff           HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@map("staff_streaks")
}

/**
 * StaffPersonalRecord — récord personal por categoría de habitación.
 *
 * Strava PR pattern. Self-vs-self. No es ranking ni comparación peer.
 * Una row por staff por categoría — siempre el mejor tiempo histórico.
 *
 * `roomCategory` usa los valores de `RoomCategory` (PRIVATE | SHARED) o
 * un id de RoomType cuando exista (Sprint 9+).
 */
model StaffPersonalRecord {
  id            String   @id @default(uuid())
  staffId       String   @map("staff_id")
  /** Bucketing key. */
  roomCategory  String   @map("room_category")
  /** Best cleaning duration in minutes. */
  bestMinutes   Int      @map("best_minutes")
  /** When the PR was set. */
  achievedAt    DateTime @map("achieved_at")
  /** Reference to the task that set the record (audit trail). */
  taskId        String   @map("task_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  staff         HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@unique([staffId, roomCategory])
  @@map("staff_personal_records")
}

/**
 * StaffDailyActivity — granular día-a-día por staff para Activity Rings.
 *
 * Apple Fitness pattern: 3 rings = (tareas, tiempo eficiente,
 * verificaciones positivas). Una row por staff por día. Permite
 * GitHub-style contribution graph en /me sin re-computar.
 */
model StaffDailyActivity {
  id                    String   @id @default(uuid())
  staffId               String   @map("staff_id")
  date                  DateTime @db.Date
  tasksCompleted        Int      @default(0) @map("tasks_completed")
  tasksVerified         Int      @default(0) @map("tasks_verified")
  totalCleaningMinutes  Int      @default(0) @map("total_cleaning_minutes")
  /** Whether the user closed all 3 rings this day (Day Completion Ritual). */
  ringsCompleted        Boolean  @default(false) @map("rings_completed")
  /** Cached daily target for ring 1 (tasks). Derived at roster time. */
  tasksTarget           Int      @default(0) @map("tasks_target")
  /** Cached daily target for ring 2 (efficient minutes). */
  minutesTarget         Int      @default(0) @map("minutes_target")
  /** Cached daily target for ring 3 (verified count). */
  verifiedTarget        Int      @default(0) @map("verified_target")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  staff                 HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId, date])
  @@map("staff_daily_activity")
}

/**
 * FeatureFlag — toggles persistentes server-side para testing y rollouts.
 *
 * Por qué server-side y no localStorage:
 *   - Multi-device coherence: un admin que activa "test.alarm" desde web
 *     debe afectar al backend (cron) y a todos los clientes mobile/web
 *     simultáneamente. localStorage solo afecta al navegador del actor.
 *   - Audit fiscal-grade: registro de quién encendió qué cuándo (ver
 *     FeatureFlagAuditLog). Esto es trazabilidad de operación, no de UI.
 *
 * Naming convention:
 *   - test.*    → entornos/flujos de prueba (test.alarm, test.no_show, ...)
 *   - feature.* → feature flags futuros con rollout gradual
 *   - debug.*   → logs/diagnostics que en prod están off por defecto
 *
 * Kill-switch de seguridad:
 *   - Las variables de entorno SIEMPRE ganan sobre el DB flag.
 *     Si `TEST_ALARM_ENABLED=false` por env, el cron NO se activa
 *     aunque el flag esté ON en BD. Esto permite a ops apagar
 *     un flag inmediatamente sin acceso a la base.
 *
 * Scope:
 *   - propertyId nullable: flag global a toda la organización si null,
 *     o restringido a una propiedad si está seteado.
 *
 * Solo SUPERVISOR puede crear/editar (Roles guard en el controller).
 *
 * Referencia: Martin Fowler — *Feature Toggles* (2017),
 * https://martinfowler.com/articles/feature-toggles.html
 */
model FeatureFlag {
  id          String   @id @default(uuid())
  /** Identificador único del flag (e.g. "test.alarm", "feature.x"). */
  key         String   @unique
  enabled     Boolean  @default(false)
  /** Restringir el flag a una propiedad específica. null = global. */
  propertyId  String?  @map("property_id")
  /** Configuración libre por flag (e.g. { intervalMin: 5, staffEmail: "m@z.co" }). */
  config      Json?
  /** Texto humano para que admin recuerde qué hace este flag. */
  description String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  property    Property?          @relation(fields: [propertyId], references: [id])
  updatedBy   HousekeepingStaff? @relation(fields: [updatedById], references: [id])
  auditLogs   FeatureFlagAuditLog[]

  @@index([key])
  @@index([propertyId])
  @@map("feature_flags")
}

/**
 * FeatureFlagAuditLog — append-only audit trail de cambios.
 * Append-only: nunca se borra ni edita. Cumple con §11 (registros
 * inmutables). Permite responder "¿quién dejó test.alarm encendido en
 * producción 3 horas?" en cualquier postmortem.
 */
model FeatureFlagAuditLog {
  id          String   @id @default(uuid())
  flagId      String   @map("flag_id")
  flagKey     String   @map("flag_key")  // duplicado para queries sin join
  action      String   // 'CREATED' | 'ENABLED' | 'DISABLED' | 'CONFIG_UPDATED'
  previousValue Json?  @map("previous_value")
  newValue    Json?    @map("new_value")
  actorId     String?  @map("actor_id")
  actorRole   String?  @map("actor_role")
  createdAt   DateTime @default(now()) @map("created_at")

  flag        FeatureFlag        @relation(fields: [flagId], references: [id])
  actor       HousekeepingStaff? @relation(fields: [actorId], references: [id])

  @@index([flagKey, createdAt])
  @@index([actorId])
  @@map("feature_flag_audit_logs")
}

/**
 * DailyPropertyMetrics — snapshot diario inmutable de KPIs operativos.
 *
 * Recomendación basada en investigación cross-referencia (Sprint 9):
 * Mews/Cloudbeds engineering blogs + STR + USALI 12th + reviews G2/Capterra.
 * El "Manager Report" (Occ + ADR + RevPAR) es el report #4 más usado en la
 * industria. Recomputarlo desde GuestStay + StaySegment + PaymentLog no
 * escala más allá de ~30 días. Snapshot append-only por propiedad por
 * fecha local.
 *
 * Refresh trigger: `NightAuditScheduler` corre per-property en local TZ
 * (CLAUDE.md §14). Añadir paso `computeDailyMetrics(propertyId, localDate)`
 * tras procesar no-shows.
 *
 * Tamaño: 1 row/property/day = ~365 rows/año/propiedad. 50 propiedades
 * × 5 años = 91k rows. Trivial para Postgres con índice (propertyId, date).
 *
 * NO denormaliza datos derivables on-the-fly (ARRIVAL_LIST, IN_HOUSE) —
 * eso es projection sobre GuestStay con índices, no aggregation table.
 */
model DailyPropertyMetrics {
  id                String   @id @default(uuid())
  propertyId        String   @map("property_id")
  /** Fecha local de la propiedad (timezone IANA aplicado). NO UTC. */
  date              DateTime @db.Date
  /** Inventario base — habitaciones disponibles para vender ese día. */
  roomsAvailable    Int      @map("rooms_available")
  /** Habitaciones vendidas (con stay activo cubriendo la noche). */
  roomsSold         Int      @map("rooms_sold")
  /** Habitaciones bloqueadas (mantenimiento, OOS). */
  roomsOOO          Int      @map("rooms_ooo")
  /** Revenue de habitaciones (sin F&B, sin extras). */
  roomRevenue       Decimal  @map("room_revenue") @db.Decimal(12, 2)
  /** Revenue total (incluye otros departamentos cuando los haya). */
  totalRevenue      Decimal  @map("total_revenue") @db.Decimal(12, 2)
  /** ADR = roomRevenue / roomsSold. Snapshot — no se recalcula. */
  adr               Decimal  @map("adr") @db.Decimal(10, 2)
  /** Occupancy = roomsSold / roomsAvailable. */
  occupancy         Decimal  @db.Decimal(5, 4)
  /** RevPAR = roomRevenue / roomsAvailable. */
  revpar            Decimal  @db.Decimal(10, 2)
  /** Eventos del día — counters para reportes diarios. */
  arrivalCount      Int      @default(0) @map("arrival_count")
  departureCount    Int      @default(0) @map("departure_count")
  noShowCount       Int      @default(0) @map("no_show_count")
  cancellationCount Int      @default(0) @map("cancellation_count")
  walkInCount       Int      @default(0) @map("walk_in_count")
  /** Currency snapshot (importante en LATAM con multi-property multi-divisa). */
  currency          String   @default("MXN")
  computedAt        DateTime @default(now()) @map("computed_at")

  property          Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId, date])
  @@map("daily_property_metrics")
}

/**
 * ChannelProductionDaily — agregación diaria por canal de venta.
 *
 * El "Channel Production Report" es report #9 en uso real (cross-research)
 * y crítico para evaluar comisiones OTA vs revenue directo. Recomputarlo
 * por fecha exige scan completo de GuestStay para rangos largos.
 *
 * Granularidad: 1 row/property/date/source. 5 sources típicos
 * (Booking, Expedia, Direct, Airbnb, Walk-in) × 365 días × 50 propiedades
 * = 91k rows/año.
 *
 * Top wanted report cross-research: "cancellation rate by channel +
 * lead-time-to-cancel" — los counters aquí agregados habilitan ese
 * análisis sin scan adicional.
 */
model ChannelProductionDaily {
  id            String   @id @default(uuid())
  propertyId    String   @map("property_id")
  date          DateTime @db.Date
  /** Identificador de canal: 'BOOKING' | 'EXPEDIA' | 'DIRECT' | 'WALK_IN' | 'AIRBNB' | etc. */
  source        String
  /** Reservas creadas en ese día/canal (no necesariamente con check-in ese día). */
  bookings      Int      @default(0)
  /** Reservas canceladas con fecha de cancelación en ese día. */
  cancellations Int      @default(0)
  /** No-shows: GuestStay con noShowAt cayendo en este día/canal. */
  noShows       Int      @default(0) @map("no_shows")
  /** Revenue neto del canal en ese día (post-comisión cuando aplique). */
  netRevenue    Decimal  @default(0) @map("net_revenue") @db.Decimal(12, 2)
  /** Comisión cobrada por el canal (0 para DIRECT/WALK_IN). */
  commission    Decimal  @default(0) @db.Decimal(12, 2)
  /** Lead time promedio en días — habilita análisis de patrones de booking. */
  avgLeadDays   Int?     @map("avg_lead_days")
  currency      String   @default("MXN")
  computedAt    DateTime @default(now()) @map("computed_at")

  property      Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date, source])
  @@index([propertyId, date])
  @@index([source, date])
  @@map("channel_production_daily")
}

// ============================================================================
// SPRINT Mx-1 — MÓDULO DE MANTENIMIENTO (v1.0.0)
// ============================================================================
//
// Sistema completo de tickets de mantenimiento con control, administración y
// seguimiento en tiempo real. Reemplaza al modelo legacy `MaintenanceIssue`
// (lightweight, vinculado a CleaningTask) que se preserva por compatibilidad
// pero NO debe usarse para nuevas integraciones.
//
// Flujo operativo del ticket:
//
//   [Housekeeper detecta problema durante limpieza]
//                  ↓
//   POST /v1/maintenance/tickets { roomId, category, priority, title, photos[] }
//                  ↓
//   MaintenanceTicket(status: OPEN, sourceTaskId: <CleaningTask>)
//                  ↓
//   ─── ¿priority === CRITICAL? ────────────────┐
//   │ NO                                       │ SÍ
//   ↓                                          ↓
//   AppNotification(MAINTENANCE_TICKET_CREATED) │
//   → técnico mantenimiento                     │
//                                               ↓
//                                        SmartBlockService.createBlock(
//                                          OUT_OF_ORDER, MAINTENANCE,
//                                          maintenanceTicketId: ticket.id
//                                        )
//                                        → room.status = BLOCKED
//                                        → desaparece del calendario PMS
//                                        → SSE: block:activated
//                                        → AppNotification(
//                                            MAINTENANCE_TICKET_CRITICAL,
//                                            ACTION_REQUIRED) → manager
//                                        → TicketLog(BLOCK_AUTO_CREATED)
//
//   [Técnico acknowledge → IN_PROGRESS → RESOLVED]
//                  ↓
//   [Supervisor verifica calidad → VERIFIED]
//                  ↓
//   ─── ¿hubo bloque automático? ───────────────┐
//                                                ↓
//                                        SmartBlockService.releaseBlock()
//                                        → room.status restored
//                                        → TicketLog(BLOCK_AUTO_RELEASED)
//                  ↓
//   [CLOSED — readonly, archivo histórico]
//
// Caso de uso real (Hotel Monica Tulum, 2026-04-09):
//   Mantenimiento inició encerado de Bongaloo B2 sin bloquear la habitación.
//   La habitación se vendió en Booking.com → pérdida + reubicación de huésped.
//   Con este módulo: encerado se levanta como TicketCategory.DEEP_CLEANING +
//   priority=CRITICAL → auto-bloqueo → Channex.io recibe pushInventory →
//   Booking.com cierra disponibilidad → no hay reserva conflictiva.
//
// Multi-tenancy: organizationId presente y obligatorio. Toda query debe
// filtrar por organizationId via TenantContextService.
//
// Integraciones:
//   - NotificationCenterService (notif.send) en cada cambio de estado.
//   - SmartBlockService (createBlock/releaseBlock) en CRITICAL/VERIFIED.
//   - PushService (Expo) al técnico asignado.
//   - SSE: maintenance:ticket:created | :updated | :resolved | :verified.
//   - Channex.io: el bloque automático dispara pushInventory (Sprint 9).
// ============================================================================

model MaintenanceTicket {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  propertyId     String         @map("property_id")
  roomId         String         @map("room_id")              // ticket SIEMPRE vincula a habitación
  unitId         String?        @map("unit_id")              // opcional — solo cuando aplica a unidad específica

  category       TicketCategory
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)

  title          String                                       // resumen corto: "Grifo gotea en baño"
  description    String?        @db.Text                      // detalle libre
  guestImpact    String?        @map("guest_impact")          // "huésped reportó al recepcionista" — contexto

  // ── Actores del ciclo de vida ────────────────────────────────────────────
  reportedById   String         @map("reported_by_id")        // housekeeper / recepcionista que detectó
  assignedToId   String?        @map("assigned_to_id")        // técnico (HousekeepingStaff con department=MAINTENANCE)
  resolvedById   String?        @map("resolved_by_id")        // quien marcó RESOLVED
  verifiedById   String?        @map("verified_by_id")        // supervisor que confirmó VERIFIED

  // ── Estimación y tiempo real ─────────────────────────────────────────────
  estimatedMinutes Int?         @map("estimated_minutes")     // estimación al crear/asignar
  actualMinutes    Int?         @map("actual_minutes")        // calculado al RESOLVED desde logs

  // ── Costos / refacciones (Sprint Mx-2: integración con inventario) ──────
  // estimatedCost   Decimal?    @db.Decimal(10, 2)
  // actualCost      Decimal?    @db.Decimal(10, 2)
  // partsRequired   Json?                                    // [{ name, qty, supplier?, eta? }]

  // ── Timestamps del ciclo de vida (cada cambio de status escribe aquí) ──
  acknowledgedAt DateTime?      @map("acknowledged_at")
  startedAt      DateTime?      @map("started_at")
  waitingPartsAt DateTime?      @map("waiting_parts_at")
  resolvedAt     DateTime?      @map("resolved_at")
  verifiedAt     DateTime?      @map("verified_at")
  closedAt       DateTime?      @map("closed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // ── Vínculo con tarea de limpieza origen (cuando housekeeper lo detectó) ─
  sourceTaskId   String?        @map("source_task_id")

  // ── Relations ────────────────────────────────────────────────────────────
  organization Organization        @relation(fields: [organizationId], references: [id])
  property     Property            @relation(fields: [propertyId], references: [id])
  room         Room                @relation("TicketRoom", fields: [roomId], references: [id])
  unit         Unit?               @relation("TicketUnit", fields: [unitId], references: [id])
  reportedBy   HousekeepingStaff   @relation("TicketsReported", fields: [reportedById], references: [id])
  assignedTo   HousekeepingStaff?  @relation("TicketsAssigned", fields: [assignedToId], references: [id])
  resolvedBy   HousekeepingStaff?  @relation("TicketsResolved", fields: [resolvedById], references: [id])
  verifiedBy   HousekeepingStaff?  @relation("TicketsVerified", fields: [verifiedById], references: [id])
  sourceTask   CleaningTask?       @relation("TicketSourceTask", fields: [sourceTaskId], references: [id])

  // Reverse relations — hijos del ticket
  photos       MaintenanceTicketPhoto[]
  comments     MaintenanceTicketComment[]
  logs         MaintenanceTicketLog[]
  // Reverse: bloque automático creado por este ticket cuando priority=CRITICAL.
  // FK vive en RoomBlock.maintenanceTicketId para evitar dependencia circular.
  // 1 ticket → 0..1 bloque (garantizado por @unique en RoomBlock).
  autoBlock    RoomBlock?          @relation("BlockMaintenanceTicket")
  // Reverse: items del checklist de readiness que originaron este ticket
  readinessItems RoomReadinessTaskItem[] @relation("ItemMaintenanceTicket")

  @@index([organizationId, propertyId, status])
  @@index([organizationId, propertyId, priority, status])
  @@index([assignedToId, status])
  @@index([roomId, status])
  @@index([category, status])
  @@index([createdAt])
  @@map("maintenance_tickets")
}

// ── Fotos antes/después de la reparación ─────────────────────────────────
// Se almacenan como URLs (S3 / Cloudinary). El upload pasa por endpoint
// dedicado /v1/uploads que retorna la URL pública firmada.
model MaintenanceTicketPhoto {
  id            String   @id @default(uuid())
  ticketId      String   @map("ticket_id")
  url           String                                          // URL pública del archivo
  caption       String?                                         // "antes" | "después" | descripción libre
  isAfterPhoto  Boolean  @default(false) @map("is_after_photo") // true = foto post-reparación
  uploadedById  String   @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  ticket     MaintenanceTicket @relation(fields: [ticketId], references: [id])
  uploadedBy HousekeepingStaff @relation("TicketPhotoUploader", fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@map("maintenance_ticket_photos")
}

// ── Comentarios del ticket (chat interno técnico ↔ supervisor) ──────────
model MaintenanceTicketComment {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id])
  author HousekeepingStaff @relation("TicketCommentAuthor", fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
  @@map("maintenance_ticket_comments")
}

// ── Audit trail inmutable del ciclo de vida del ticket ──────────────────
// Append-only. Cada cambio de status, asignación, foto o comentario genera
// una entrada. Fuente de verdad para reportes de tiempo de respuesta y
// disputas operativas.
model MaintenanceTicketLog {
  id        String         @id @default(uuid())
  ticketId  String         @map("ticket_id")
  event     TicketLogEvent
  staffId   String?        @map("staff_id")               // null = evento del sistema (auto-block)
  // metadata: snapshot del cambio. Ejemplos:
  //   ASSIGNED            { fromStaffId, toStaffId }
  //   STARTED             { estimatedMinutes }
  //   WAITING_PARTS       { reason, expectedEta }
  //   RESOLVED            { resolutionSummary, actualMinutes }
  //   BLOCK_AUTO_CREATED  { roomBlockId, semantic, reason }
  //   BLOCK_AUTO_RELEASED { roomBlockId }
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  ticket MaintenanceTicket  @relation(fields: [ticketId], references: [id])
  staff  HousekeepingStaff? @relation("TicketLogActor", fields: [staffId], references: [id])

  @@index([ticketId, createdAt])
  @@index([event])
  @@map("maintenance_ticket_logs")
}
