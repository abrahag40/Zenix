// ── Sprint Mx-1 — Módulo de Mantenimiento (v1.0.0 scope) ──────────────────
//
// Sistema completo de tickets de mantenimiento que reemplaza al modelo legacy
// `MaintenanceIssue` (lightweight, vinculado a CleaningTask). Caso de uso real
// que motivó el módulo (Hotel Monica Tulum, 2026-04-09): el área de mantenimiento
// inició encerado de Bongaloo B2 sin bloquear la habitación → la habitación se
// vendió en Booking.com → el hotel asumió pérdidas reubicando al huésped.
//
// El módulo MaintenanceModule es MONOLÍTICO con el resto del PMS (mismo NestJS,
// misma BD, mismo auth). La separación es a nivel de módulos NestJS, no de
// servicios. Ver CLAUDE.md §10 para el principio arquitectónico.
//
// Bridge crítico con inventario:
//   TicketPriority.CRITICAL → MaintenanceModule.onTicketCreated()
//                          → SmartBlockService.createBlock(OUT_OF_ORDER, MAINTENANCE)
//                          → room.status = BLOCKED
//                          → la habitación desaparece del calendario PMS para venta.
// Resuelto en RoomBlock.maintenanceTicketId (FK del lado del bloque para evitar
// dependencia circular). El ticket conoce su bloque vía la reverse relation.

enum TicketStatus {
  OPEN // recién creado por housekeeper/recepcionista
  ACKNOWLEDGED // técnico de mantenimiento lo vio (lectura confirmada)
  IN_PROGRESS // trabajo activo
  WAITING_PARTS // pausa por espera de material/proveedor
  RESOLVED // técnico marcó trabajo completado
  VERIFIED // supervisor confirmó la resolución (calidad)
  CLOSED // archivado — readonly, fuente para reportes históricos
}

enum TicketPriority {
  LOW // cosmético, no afecta disponibilidad (mancha leve, pintura)
  MEDIUM // funcional pero no bloquea la habitación (foco fundido)
  HIGH // afecta experiencia del huésped (aire acondicionado débil)
  CRITICAL // habitación inhabitable → AUTO-BLOQUEA inventario en PMS
}

enum TicketCategory {
  PLUMBING // fontanería: grifos, baño, desagües
  ELECTRICAL // eléctrico: instalación, contactos, breakers
  FURNITURE // mobiliario: cama, escritorio, sillas dañadas
  APPLIANCE // electrodomésticos: TV, mini-bar, cafetera
  HVAC // climatización: aire, calefacción, ventilación
  STRUCTURAL // estructura: paredes, techo, piso, ventanas
  COSMETIC // estética: pintura, manchas no removibles
  SAFETY // seguridad: cerraduras, detectores humo, extintores
  PEST // control de plagas (escala desde housekeeping)
  DEEP_CLEANING // limpieza profunda especializada (mancha extrema, encerado)
  OTHER
}

enum TicketLogEvent {
  CREATED // ticket nuevo
  ACKNOWLEDGED // técnico marcó como visto
  ASSIGNED // assignedToId cambió
  AUTO_ASSIGNED // sistema asignó por load-balancing (Mx-1 D4 + D44)
  CLAIMED // técnico tomó voluntariamente de la cola (voluntary pickup)
  QUEUED // ticket entró a la cola (sin asignar inicialmente)
  APPROVED // supervisor aprobó ticket bottom-up (Flujo B)
  REJECTED // supervisor rechazó ticket bottom-up (cierra con razón)
  STARTED // status → IN_PROGRESS
  WAITING_PARTS // status → WAITING_PARTS
  RESOLVED // status → RESOLVED
  VERIFIED // status → VERIFIED por supervisor
  CLOSED // status → CLOSED
  REOPENED // RESOLVED/VERIFIED → IN_PROGRESS (regresión)
  COMMENT_ADDED // nuevo TicketComment
  PHOTO_ADDED // nueva TicketPhoto
  PHOTO_DELETED // foto soft-deleted (Mx-1B-W2 — W2-04 fix)
  BLOCK_AUTO_CREATED // CRITICAL → RoomBlock auto-creado
  BLOCK_AUTO_RELEASED // ticket VERIFIED/CLOSED → RoomBlock liberado
  SLA_BREACH // scheduler detectó que pasó el umbral sin acknowledgment
}

// Alcance de un template de mantenimiento preventivo recurrente.
// PER_ROOM: una instancia por habitación de la propiedad (ej. limpieza filtros A/C).
// PER_ASSET: una instancia por asset identificado por defaultAssetTag (ej. lavadora-1).
// PER_PROPERTY: una sola instancia para toda la propiedad (ej. fumigación general).
// COMMON_AREAS: una instancia para áreas comunes — sin roomId, sin assetTag.
enum RecurrenceScope {
  PER_ROOM
  PER_ASSET
  PER_PROPERTY
  COMMON_AREAS
}

// ======================= MULTI-TENANT FOUNDATION =======================

model Organization {
  id          String   @id @default(uuid())
  // v1.0.5 ORG-HIERARCHY-SEED — brand opcional. Null = hotel independiente.
  // Puede agregarse después sin migration: el cliente "se vuelve marca"
  // simplemente con UPDATE organizations SET brand_id = X.
  brandId     String?  @map("brand_id")
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(STARTER)
  // ── Campos legacy (preservados pre-v1.0.5, deprecated post-v1.1) ─────
  // countryCode/timezone/currency: la autoridad fiscal/operativa ahora
  // vive en LegalEntity (currency, regime) y Property (timezone). Estos
  // campos persisten por backwards-compat hasta v1.1 backfill complete.
  countryCode String   @default("MX") @map("country_code")
  timezone    String   @default("America/Cancun")
  currency    String   @default("MXN")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  brand         Brand?        @relation(fields: [brandId], references: [id])
  legalEntities LegalEntity[]

  // Reverse relations (denormalized organizationId in all business tables)
  properties          Property[]
  users               User[]
  rooms               Room[]
  units               Unit[]
  housekeepingStaff   Staff[]
  checkouts           Checkout[]
  cleaningTasks       CleaningTask[]
  taskLogs            TaskLog[]
  cleaningNotes       CleaningNote[]
  maintenanceIssues   MaintenanceIssue[]
  unitDiscrepancies   UnitDiscrepancy[]
  pushTokens          PushToken[]
  pmsConfigs          PmsConfig[]
  propertySettings    PropertySettings[]
  roomTypes           RoomType[]
  guestStays          GuestStay[]
  roomTypeChecklists  RoomTypeChecklist[]
  roomReadinessTasks  RoomReadinessTask[]
  stayJourneys        StayJourney[]
  roomBlocks          RoomBlock[]
  appNotifications    AppNotification[]
  // ── Sprint 8H ─────────────────────────────────────────────────────────────
  staffShifts         StaffShift[]
  // ── Sprint 9 ──────────────────────────────────────────────────────────────
  channelCommissions  ChannelCommission[]
  // ── Sprint Mx-1 — Mantenimiento ──────────────────────────────────────────
  maintenanceTickets  MaintenanceTicket[]
  recurrenceTemplates MaintenanceRecurrenceTemplate[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization     Organization          @relation(fields: [organizationId], references: [id])
  propertyRoles    UserPropertyRole[]
  // v1.0.5 — nuevos scope levels para multi-property cross-* access
  brandRoles       BrandUserRole[]
  legalEntityRoles LegalEntityUserRole[]
  staffProfiles    Staff[]

  @@index([organizationId])
  @@map("users")
}

model UserPropertyRole {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  propertyId String     @map("property_id")
  role       SystemRole
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId, role])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_roles")
}

// ======================= 4-LEVEL HIERARCHY (v1.0.5 ORG-HIERARCHY-SEED) =======================
// Brand → Organization → LegalEntity → Property
//
// Modelo aprobado 2026-05-15. Ver docs/vision/11-multi-tenant-architecture.md
// para análisis arquitectónico completo y casos de uso (Selina-like
// multi-country, Hotel Monica Tulum independiente, "growing into a brand").
//
// Decisiones no-negociables §63-§72 CLAUDE.md:
//  · Brand opcional (independent hotels = NULL)
//  · LegalEntity required para invoicing (RFC MX / NIT CO / RUC PE / etc.)
//  · Property con timezone propio (operativo) — la moneda fiscal vive en LegalEntity
//  · organizationId denormalizado en Property + trigger consistency (más adelante)
//  · User access 3-level: BrandUserRole / LegalEntityUserRole / UserPropertyRole
//  · FiscalRegime sembrada con 10 países LATAM
//  · PAC credentials per LegalEntity (no per Property)
//  · legalAddress JSONB (formato varía per país)
//  · App-layer enforcement (no Postgres RLS hasta v1.2+)
//
// Migration v1.0.5 backwards-compatible: backfill automático creará 1
// LegalEntity por Organization existente, todas las Properties existentes
// vinculadas. Sin breaking changes para código existente — los nuevos
// endpoints brand/legal-entity son additive.

model Brand {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  logoUrl       String?  @map("logo_url")
  brandColors   Json?    @map("brand_colors") // { primary, secondary, accent }
  brandBookUrl  String?  @map("brand_book_url") // PDF público
  websiteUrl    String?  @map("website_url")
  // Loyalty cross-property — config sembrada en v1.0.5, UI en v1.5+
  loyaltyConfig Json?    @map("loyalty_config")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organizations Organization[]
  userRoles     BrandUserRole[]

  @@map("brands")
}

// Régimen fiscal por país. Tabla semilla con 10 países LATAM identificados
// (MX/CO/CR/PE/PA/GT/SV/HN/BR/AR). `active` controla si el adapter está
// implementado y certificado. Activación per-país sigue el roadmap v1.0.x→v1.3.x.
model FiscalRegime {
  id              String   @id // 'MX_CFDI4', 'CO_DIAN', 'CR_TRIBU', 'PE_SUNAT'...
  countryCode     String   @map("country_code") // ISO 3166-1 alpha-2
  displayName     String   @map("display_name")
  taxAuthority    String   @map("tax_authority") // 'SAT', 'DIAN', 'Hacienda', 'SUNAT'...
  active          Boolean  @default(false) // gate hasta adapter certificado
  // JSON schemas para validación y mapping per país:
  docTypeEnums    Json     @map("doc_type_enums") // { invoice: 'I', creditNote: 'E', paymentComplement: 'P' }
  taxCodes        Json     @map("tax_codes") // mapping IVA / ISH / Saneamiento / Withholding
  pacAdapterClass String?  @map("pac_adapter_class") // 'MX_FacturamaAdapter', 'CO_OlimpiaAdapter'
  pacConfigSchema Json?    @map("pac_config_schema") // JSON schema valida pacCredentials shape
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  legalEntities LegalEntity[]

  @@index([countryCode])
  @@map("fiscal_regimes")
}

model LegalEntity {
  id                    String    @id @default(uuid())
  organizationId        String    @map("organization_id")
  fiscalRegimeId        String?   @map("fiscal_regime_id") // nullable hasta cargar PAC
  countryCode           String    @map("country_code") // ISO 3166-1 — debe coincidir con fiscalRegime.countryCode
  name                  String // razón social completa
  taxId                 String    @map("tax_id") // RFC / NIT / RUC / Cédula Jurídica
  legalAddress          Json      @map("legal_address") // jsonb — formato per país
  baseCurrency          String    @map("base_currency") // ISO 4217: MXN, COP, CRC, USD, BRL...
  pacCredentials        Json?     @map("pac_credentials") // encrypted at-rest in v1.1+ (placeholder hoy)
  // Mes de inicio del fiscal year (1-12, default enero):
  accountingPeriodStart Int       @default(1) @map("accounting_period_start")
  active                Boolean   @default(true)
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id])
  fiscalRegime FiscalRegime?         @relation(fields: [fiscalRegimeId], references: [id])
  properties   Property[]
  userRoles    LegalEntityUserRole[]

  @@unique([organizationId, taxId])
  @@index([organizationId])
  @@index([countryCode])
  @@map("legal_entities")
}

model BrandUserRole {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  brandId   String     @map("brand_id")
  role      SystemRole
  createdAt DateTime   @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  brand Brand @relation(fields: [brandId], references: [id])

  @@unique([userId, brandId, role])
  @@index([userId])
  @@index([brandId])
  @@map("brand_user_roles")
}

model LegalEntityUserRole {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  legalEntityId String     @map("legal_entity_id")
  role          SystemRole
  createdAt     DateTime   @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@unique([userId, legalEntityId, role])
  @@index([userId])
  @@index([legalEntityId])
  @@map("legal_entity_user_roles")
}

// ======================= CORE MODELS =======================

model Property {
  id             String       @id @default(uuid())
  // v1.0.5 — organizationId ahora NOT NULL (audit MT-4 cierre).
  // Backfill verifica que todas las Properties tengan org antes del switch.
  organizationId String       @map("organization_id")
  // v1.0.5 — legalEntityId NULLABLE durante transición. Backfill auto-asigna
  // una LegalEntity por Organization. v1.1+ migración separada lo hace NOT NULL.
  legalEntityId  String?      @map("legal_entity_id")
  name           String
  type           PropertyType @default(HOTEL)
  // Campo legacy — la authority fiscal está ahora en LegalEntity.taxId.
  // Preservado por backwards-compat; deprecated v1.1.
  taxId          String?      @map("tax_id")
  // Optional geographic grouping for the property switcher.
  // `region` is the coarse grouping key (chains split by "Caribe",
  // "Pacífico", "Brasil", etc. — see Mews/Opera multi-property docs);
  // `city` disambiguates properties with the same name inside the
  // same region (Slack/Google-picker pattern).
  region         String?
  city           String?
  // Globally unique 3-digit code assigned sequentially at property creation.
  // Used as segment in bookingRef: MX-D-001-2604-0134
  propCode       String?      @unique @map("prop_code")
  isActive       Boolean      @default(true) @map("is_active")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // v1.0.5 — relación a Organization ahora NOT NULL.
  organization       Organization             @relation(fields: [organizationId], references: [id])
  // v1.0.5 — nuevo FK opcional. Required v1.1+ tras backfill verificado.
  legalEntity        LegalEntity?             @relation(fields: [legalEntityId], references: [id])
  rooms              Room[]
  roomTypes          RoomType[]
  staff              Staff[]
  pmsConfig          PmsConfig?
  settings           PropertySettings?
  userRoles          UserPropertyRole[]
  stayJourneys       StayJourney[]
  appNotifications   AppNotification[]
  // ── Sprint 8H ─────────────────────────────────────────────────────────────
  shifts             StaffShift[]
  staffCoverages     StaffCoverage[]
  shiftClocks        StaffShiftClock[]
  // ── Sprint 9 — Reports / Channel Manager ──────────────────────────────────
  channelCommissions ChannelCommission[]
  // ── Feature flags / testing toggles ───────────────────────────────────────
  featureFlags       FeatureFlag[]
  // ── Reports — pre-computed aggregations (Sprint 9 research) ──────────────
  dailyMetrics       DailyPropertyMetrics[]
  channelProduction  ChannelProductionDaily[]
  // ── Sprint Mx-1 — Mantenimiento ──────────────────────────────────────────
  maintenanceTickets MaintenanceTicket[]

  @@index([organizationId])
  @@index([legalEntityId])
  @@map("properties")
}

model Room {
  id                String       @id @default(uuid())
  organizationId    String?      @map("organization_id")
  propertyId        String
  number            String
  floor             Int?
  category          RoomCategory
  capacity          Int
  status            RoomStatus   @default(AVAILABLE) @map("room_status")
  roomTypeId        String?      @map("room_type_id")
  channexRoomTypeId String?      @map("channex_room_type_id") // ID del room type en Channex.io (Sprint 8)
  notes             String?
  deletedAt         DateTime?    @map("deleted_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  property           Property            @relation(fields: [propertyId], references: [id])
  roomType           RoomType?           @relation(fields: [roomTypeId], references: [id])
  units              Unit[]
  checkouts          Checkout[]
  guestStays         GuestStay[]
  readinessTasks     RoomReadinessTask[]
  staySegments       StaySegment[]
  blocks             RoomBlock[]
  // ── Sprint 8H — quién cubre esta habitación por defecto ───────────────────
