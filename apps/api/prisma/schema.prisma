  maintenanceTickets MaintenanceTicket[] @relation("TicketUnit")

  @@index([organizationId])
  @@map("units")
}

/**
 * Staff — miembro del personal del hotel (cualquier área, cualquier nivel).
 * Renombrado desde `HousekeepingStaff` (2026-05-08, Sprint 9): el nombre
 * legacy era engañoso. Este modelo representa a TODO el personal:
 * recamaristas, recepcionistas, mantenimiento, áreas públicas, etc.
 * Industry standard naming:
 * - AHLEI / USALI 12ª: "Staff" o "Employee"
 * - Mews / Cloudbeds: "User" (mezclado con app account)
 * - Opera: "Employee"
 * Elegimos "Staff" — conciso, distinto de "User" (app account ≠ persona).
 * Tabla SQL `housekeeping_staff` permanece via @@map para evitar migración
 * destructiva. Renombrar la tabla cuando haya ventana de deploy controlada.
 * Tres ejes de identidad:
 * 1. department  (HOUSEKEEPING | MAINTENANCE | RECEPTION | ...)
 * 2. role        (HOUSEKEEPER | SUPERVISOR | RECEPTIONIST) — legacy
 * 3. level       (LEAD | COLLABORATOR) — nuevo Sprint 9, autoridad
 * Permission matrix derivada de (department, level) — ver
 * apps/api/src/common/permissions/staff-permissions.ts.
 */
model Staff {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  userId         String?      @map("user_id")
  propertyId     String
  name           String
  email          String       @unique
  passwordHash   String
  role           StaffRole
  department     Department   @default(HOUSEKEEPING) @map("department")
  // Sprint 9 — eje jerárquico ortogonal a role/department.
  // Default COLLABORATOR — el seed/migración promueve a LEAD a quienes
  // tenían role=SUPERVISOR en HOUSEKEEPING (mapeo legacy).
  level          StaffLevel   @default(COLLABORATOR) @map("level")
  // Self-referential FK para árbol jerárquico (futuro org-tree visual).
  // Null = no reporta a nadie (top of department o solo-staff property).
  reportsToId    String?      @map("reports_to_id")
  reportsTo      Staff?       @relation("StaffReports", fields: [reportsToId], references: [id])
  reports        Staff[]      @relation("StaffReports")
  active         Boolean      @default(true)
  capabilities   Capability[]
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now())

  organization            Organization?              @relation(fields: [organizationId], references: [id])
  user                    User?                      @relation(fields: [userId], references: [id])
  property                Property                   @relation(fields: [propertyId], references: [id])
  tasks                   CleaningTask[]             @relation("AssignedTasks")
  verifiedTasks           CleaningTask[]             @relation("VerifiedTasks")
  taskLogs                TaskLog[]
  cleaningNotes           CleaningNote[]
  pushTokens              PushToken[]
  checkouts               Checkout[]                 @relation("ManualCheckouts")
  issues                  MaintenanceIssue[]
  reportedDiscrepancies   UnitDiscrepancy[]          @relation("DiscrepancyReporter")
  resolvedDiscrepancies   UnitDiscrepancy[]          @relation("DiscrepancyResolver")
  requestedBlocks         RoomBlock[]                @relation("BlocksRequested")
  approvedBlocks          RoomBlock[]                @relation("BlocksApproved")
  blockLogs               BlockLog[]                 @relation("BlockLogs")
  contactLogs             GuestContactLog[]          @relation("ContactLogs")
  notificationsTriggered  AppNotification[]          @relation("NotifTriggeredBy")
  notificationReads       AppNotificationRead[]      @relation("NotifReadBy")
  notificationApprovals   AppNotificationApproval[]  @relation("NotifApprovedBy")
  collectedPayments       PaymentLog[]               @relation("PaymentCollectedBy")
  approvedPayments        PaymentLog[]               @relation("PaymentApprovedBy")
  voidedPayments          PaymentLog[]               @relation("PaymentVoidedBy")
  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  shifts                  StaffShift[]
  shiftExceptions         StaffShiftException[]      @relation("ShiftExceptionsForStaff")
  approvedShiftExceptions StaffShiftException[]      @relation("ShiftExceptionsApprovedBy")
  coverages               StaffCoverage[]
  shiftClocks             StaffShiftClock[]
  preferences             StaffPreferences?
  preferenceChangesMade   StaffPreferenceLog[]       @relation("PreferenceChangesByStaff")
  // ── Sprint 8I-J — Hub Recamarista gamificación (privacy-respecting) ─────
  streak                  StaffStreak?
  personalRecords         StaffPersonalRecord[]
  dailyActivity           StaffDailyActivity[]
  // ── Feature flags audit trail ────────────────────────────────────────────
  featureFlagsUpdated     FeatureFlag[]
  featureFlagAudits       FeatureFlagAuditLog[]
  // ── Sprint Mx-1 — Módulo de Mantenimiento ─────────────────────────────────
  // Un staff puede aparecer en múltiples roles dentro del ciclo de vida de un
  // ticket (reporta, asignado, resuelve, verifica) — cada relación es independiente.
  // Department.MAINTENANCE identifica al staff que es técnico de mantenimiento.
  ticketsReported         MaintenanceTicket[]        @relation("TicketsReported")
  ticketsAssigned         MaintenanceTicket[]        @relation("TicketsAssigned")
  ticketsResolved         MaintenanceTicket[]        @relation("TicketsResolved")
  ticketsVerified         MaintenanceTicket[]        @relation("TicketsVerified")
  ticketsApproved         MaintenanceTicket[]        @relation("TicketsApproved")
  ticketPhotosUploaded    MaintenanceTicketPhoto[]   @relation("TicketPhotoUploader")
  ticketCommentsAuthored  MaintenanceTicketComment[] @relation("TicketCommentAuthor")
  ticketLogsBy            MaintenanceTicketLog[]     @relation("TicketLogActor")

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("housekeeping_staff")
}

model Checkout {
  id                String         @id @default(uuid())
  organizationId    String?        @map("organization_id")
  roomId            String
  guestName         String?
  actualCheckoutAt  DateTime
  source            CheckoutSource
  isEarlyCheckout   Boolean        @default(false)
  hasSameDayCheckIn Boolean        @default(false)
  notes             String?
  enteredById       String?
  cancelled         Boolean        @default(false)
  cancelledAt       DateTime?
  createdAt         DateTime       @default(now())

  organization Organization?  @relation(fields: [organizationId], references: [id])
  room         Room           @relation(fields: [roomId], references: [id])
  enteredBy    Staff?         @relation("ManualCheckouts", fields: [enteredById], references: [id])
  tasks        CleaningTask[]

  @@index([organizationId])
  @@map("checkouts")
}

// TODO(hotel-room-granularity): CleaningTask fue diseñado hostel-first — unitId es NOT NULL
// y la tarea siempre se vincula a una unidad, nunca directamente a una habitación.
// Para hoteles con habitaciones dobles/twin (2 unidades, 1 unidad vendible), un bloqueo
// de habitación genera hoy N tareas MAINTENANCE (una por unidad) cuando debería ser 1.
// Refactor requerido:
//   1. Hacer unitId opcional: `unitId String?`
//   2. Añadir `roomId String?` (XOR con unitId — exactamente uno debe estar presente)
//   3. Actualizar TasksService, CleaningTaskDto, KanbanPage y mobile task/[id].tsx
//      para renderizar roomId cuando unitId sea null (tareas de bloqueo room-level)
//   4. Migración Prisma: no hay datos existentes de tipo MAINTENANCE, safe to migrate
model CleaningTask {
  id                 String         @id @default(uuid())
  organizationId     String?        @map("organization_id")
  unitId             String
  checkoutId         String?
  assignedToId       String?
  status             CleaningStatus @default(PENDING)
  taskType           TaskType       @default(CLEANING)
  // TODO(housekeeping-pms-bridge): agregar sourceType para distinguir el origen de la tarea.
  // Descomentar y migrar cuando se implemente el bridge PMS → Housekeeping (Sprint 7A/7B).
  // sourceType         CleaningTaskSource @default(CHECKOUT)
  // enum CleaningTaskSource { CHECKOUT, STAYOVER, ROOM_CHANGE, EXTENSION }
  requiredCapability Capability     @default(CLEANING)
  priority           Priority       @default(MEDIUM)
  hasSameDayCheckIn  Boolean        @default(false)
  startedAt          DateTime?
  finishedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // ── Sprint 8H — housekeeping scheduling ─────────────────────────────────
  scheduledFor        DateTime?             @map("scheduled_for") @db.Date // fecha lógica del roster (idempotencia + queries)
  carryoverFromDate   DateTime?             @map("carryover_from_date") @db.Date
  carryoverFromTaskId String?               @map("carryover_from_task_id")
  autoAssignmentRule  String?               @map("auto_assignment_rule") // 'COVERAGE_PRIMARY' | 'COVERAGE_BACKUP' | 'ROUND_ROBIN' | null
  cancelledReason     CleaningCancelReason? @map("cancelled_reason")
  cancelledAt         DateTime?             @map("cancelled_at")
  extensionFlag       ExtensionFlag?        @map("extension_flag") // D12 — re-etiqueta cuando extension aplica

  // ── Sprint 9 / EC-6 — Skip-and-retry (AHLEI Sec. 4.3) ────────────────────
  deferredAt     DateTime?            @map("deferred_at")
  deferredReason CleaningDeferReason? @map("deferred_reason")
  // Hora a la que la tarea debe re-promoverse a READY/UNASSIGNED automáticamente.
  // El cron `*/5 * * * *` la chequea contra `now`. Default 30 min post-defer (AHLEI).
  retryAt        DateTime?            @map("retry_at")
  // Contador acumulado de deferrals. ≥3 → status=BLOCKED + notif tier-2.5 supervisor.
  deferredCount  Int                  @default(0) @map("deferred_count")

  // ── Sprint 9 / EC-3 — Late checkout (huésped sale a hora distinta) ───────
  // Si la recepción aprobó late checkout, este timestamp guarda la nueva
  // hora prevista. Mobile lo usa para re-calcular prioridad: la tarea no
  // es URGENT hasta que `now >= lateCheckoutAt - 1h`.
  lateCheckoutAt DateTime? @map("late_checkout_at")

  // ── Sprint 9 / D15 — Override flags (OperationalOverridesPage) ────────────
  // Limpieza profunda — cambia el template de checklist + duración estimada.
  // Operativo: el housekeeper recibe pack diferente (sábanas + manta + cortinas
  // vs solo sábanas) y debe documentar más fotos.
  deepClean  Boolean   @default(false) @map("deep_clean")
  // Hold por extensión sin formalizar (huésped pidió quedarse pero aún no paga).
  // Estado: la tarea se mantiene PENDING (no se inicia limpieza). El housekeeper
  // ve el badge "⏸ En espera de extensión". Al formalizar la extensión: D12
  // resuelve (con/sin limpieza). Al cancelar el hold: vuelve a estado normal.
  holdReason String?   @map("hold_reason")
  heldAt     DateTime? @map("held_at")
  heldById   String?   @map("held_by_id")

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  unit               Unit                @relation(fields: [unitId], references: [id])
  checkout           Checkout?           @relation(fields: [checkoutId], references: [id])
  assignedTo         Staff?              @relation("AssignedTasks", fields: [assignedToId], references: [id])
  verifiedBy         Staff?              @relation("VerifiedTasks", fields: [verifiedById], references: [id])
  logs               TaskLog[]
  notes              CleaningNote[]
  issues             MaintenanceIssue[]
  block              RoomBlock?          @relation("BlockTask")
  // Self-relation for carryover audit chain (CleaningTask → original CleaningTask de ayer)
  carryoverFromTask  CleaningTask?       @relation("TaskCarryover", fields: [carryoverFromTaskId], references: [id])
  carryoverChildren  CleaningTask[]      @relation("TaskCarryover")
  // ── Sprint Mx-1 — Mantenimiento ────────────────────────────────────────
  // Tickets levantados durante esta tarea de limpieza (housekeeper detecta
  // problemas en cuarto). Vínculo via MaintenanceTicket.sourceTaskId.
  maintenanceTickets MaintenanceTicket[] @relation("TicketSourceTask")

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId, status])
  @@index([unitId])
  @@index([checkoutId])
  @@index([scheduledFor, status])
  @@index([carryoverFromDate])
  @@index([cancelledReason])
  @@map("cleaning_tasks")
}

model TaskLog {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  taskId         String
  staffId        String?
  event          TaskLogEvent
  note           String?
  // metadata: snapshot opcional del evento. Caso principal:
  //   COMPLETED { checklist: [{ id, label, completed }] }  → para reportes
  //   PAUSED    { reason: '...' }                         → opcional
  // Queryable con operadores JSONB de Postgres en reports.
  metadata       Json?
  createdAt      DateTime     @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  task         CleaningTask  @relation(fields: [taskId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@index([taskId])
  @@map("task_logs")
}

model CleaningNote {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  taskId         String
  staffId        String
  content        String
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  task         CleaningTask  @relation(fields: [taskId], references: [id])
  staff        Staff         @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("cleaning_notes")
}

model MaintenanceIssue {
  id             String              @id @default(uuid())
  organizationId String?             @map("organization_id")
  taskId         String
  reportedById   String
  category       MaintenanceCategory
  description    String
  photoUrl       String?
  resolved       Boolean             @default(false)
  createdAt      DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  task         CleaningTask  @relation(fields: [taskId], references: [id])
  reportedBy   Staff         @relation(fields: [reportedById], references: [id])

