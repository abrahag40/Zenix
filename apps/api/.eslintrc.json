{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "env": {
    "node": true,
    "jest": true,
    "es2022": true
  },
  "ignorePatterns": ["dist", "node_modules", "prisma/migrations", "*.config.js", "*.config.ts"],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-empty": "off",
    "no-useless-escape": "off",
    "no-prototype-builtins": "off",
    "no-async-promise-executor": "off",
    "no-case-declarations": "off"
  }
}
