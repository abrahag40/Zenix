{
  "expo": {
    "name": "Zenix",
    "slug": "zenix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zenix",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B1020"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zenix.pms",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1020"
      },
      "package": "com.zenix.pms",
      "permissions": [
        "USE_FULL_SCREEN_INTENT",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#10B981"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
