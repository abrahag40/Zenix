{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [],
      "env": [
        "DATABASE_URL",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
